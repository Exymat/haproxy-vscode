{
  "haproxy.version": "3.2",
  "haproxy.diagnostics.debounceMs": 100,
  "haproxy.diagnostics.enabled": true,
  "haproxy.diagnostics.deprecatedWarnings": true,
  "haproxy.diagnostics.maxLines": 4000,
  "haproxy.format.enabled": true,
  "haproxy.format.indent": "spaces-4",
  "haproxy.format.insertBlankLineBetweenSections": true,
  "haproxy.diagnostics.unusedSymbols": true,
  "haproxy.diagnostics.missingReferences": true,
  "haproxy.workspaceSymbols.enabled": true,
  "haproxy.workspaceSymbols.include": ["**/*.cfg"],
  "haproxy.workspaceSymbols.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "**/vendor/**"
  ],
  "haproxy.workspaceSymbols.maxFiles": 0,
  "haproxy.workspaceSymbols.maxTotalLines": 0,
  "haproxy.workspaceSymbols.maxFileBytes": 0,
  "haproxy.workspaceSymbols.maxTotalBytes": 0,
  "haproxy.workspaceSymbols.maxLineBytes": 0,
  "haproxy.workspaceSymbols.debounceMs": 750
}
