{
  "name": "haproxy-config",
  "displayName": "HAProxy Language Support",
  "description": "HAProxy config support: syntax highlighting, completion, hovers, diagnostics, formatting, and go-to-definition — LTS versions (2.6 - 3.4) supported.",
  "version": "0.18.2",
  "publisher": "Exymat",
  "icon": "icon.png",
  "license": "MIT",
  "keywords": [
    "haproxy",
    "load balancer",
    "reverse proxy",
    "proxy",
    "cfg",
    "configuration",
    "syntax highlighting",
    "autocomplete",
    "intellisense",
    "validation",
    "diagnostics",
    "hover",
    "documentation",
    "frontend",
    "backend",
    "acl",
    "devops",
    "networking",
    "formatting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Exymat/haproxy-vscode.git"
  },
  "homepage": "https://www.exymat.net",
  "bugs": {
    "url": "https://github.com/Exymat/haproxy-vscode/issues"
  },
  "author": {
    "name": "Exymat",
    "url": "https://github.com/Exymat"
  },
  "activationEvents": [
    "onLanguage:haproxy",
    "onLanguage:haproxy-2.6",
    "onLanguage:haproxy-2.8",
    "onLanguage:haproxy-3.0",
    "onLanguage:haproxy-3.2",
    "onLanguage:haproxy-3.4"
  ],
  "engines": {
    "node": ">=24",
    "vscode": "^1.125.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Other"
  ],
  "galleryBanner": {
    "color": "#101215",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "HAProxy",
      "properties": {
        "haproxy.version": {
          "type": "string",
          "scope": "resource",
          "enum": [
            "2.6",
            "2.8",
            "3.0",
            "3.2",
            "3.4"
          ],
          "default": "3.2",
          "description": "HAProxy release used for completion, diagnostics, hover, and syntax highlighting."
        },
        "haproxy.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema-based diagnostics for HAProxy configs. Turn off if opening .cfg files is slow."
        },
        "haproxy.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Milliseconds to wait after edits before recomputing diagnostics."
        },
        "haproxy.diagnostics.maxLines": {
          "type": "number",
          "default": 4000,
          "minimum": 100,
          "description": "Skip diagnostics above this line count to protect editor memory."
        },
        "haproxy.diagnostics.deprecatedWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a directive or rule action is marked deprecated in the official HAProxy documentation for the selected version. Suppressed when global expose-deprecated-directives is present."
        },
        "haproxy.diagnostics.unusedSymbols": {
          "type": "boolean",
          "default": true,
          "description": "Hint when ACLs or sections appear unused. Unused ACL lines and unreferenced section blocks use unnecessary-code diagnostics that fade the full line or section."
        },
        "haproxy.diagnostics.missingReferences": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a named HAProxy reference points to no definition in the current file, such as a missing ACL, backend, cache, peers, resolvers, userlist, or named defaults profile."
        },
        "haproxy.workspaceSymbols.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Build a workspace-level symbol graph for split HAProxy configurations."
        },
        "haproxy.workspaceSymbols.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.cfg"
          ],
          "description": "Glob patterns for HAProxy files that belong to the workspace symbol graph. Non-HAProxy `.cfg` files matched by the glob are skipped automatically; for monorepos, prefer a narrower pattern such as `**/haproxy/**/*.cfg`."
        },
        "haproxy.workspaceSymbols.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/vendor/**"
          ],
          "description": "Glob patterns excluded from workspace symbol indexing."
        },
        "haproxy.workspaceSymbols.maxFiles": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional maximum number of HAProxy files to index per VS Code workspace folder. Set to 0 for no file-count limit. When exceeded, cross-file navigation, rename, completions, and missing-reference checks in that folder fall back to single-file behavior and a warning is shown."
        },
        "haproxy.workspaceSymbols.maxTotalLines": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional maximum total HAProxy lines to index per VS Code workspace folder. Set to 0 for no line limit. When exceeded, cross-file navigation, rename, completions, and missing-reference checks in that folder fall back to single-file behavior and a warning is shown."
        },
        "haproxy.workspaceSymbols.maxFileBytes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional maximum bytes per HAProxy file to index. Set to 0 for no per-file byte limit. Files larger than this are skipped before being read into memory."
        },
        "haproxy.workspaceSymbols.maxTotalBytes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional maximum total indexed bytes per VS Code workspace folder. Set to 0 for no total byte limit. When exceeded, cross-file navigation, rename, completions, and missing-reference checks in that folder fall back to single-file behavior and a warning is shown."
        },
        "haproxy.workspaceSymbols.maxLineBytes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional maximum encoded bytes per line in an indexed HAProxy file. Set to 0 for no per-line byte limit. Files containing longer lines are skipped."
        },
        "haproxy.workspaceSymbols.debounceMs": {
          "type": "number",
          "default": 750,
          "minimum": 100,
          "maximum": 10000,
          "description": "Milliseconds to wait after workspace HAProxy file changes before rebuilding the workspace symbol graph."
        },
        "haproxy.format.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable document formatting for HAProxy configs (Format Document)."
        },
        "haproxy.format.indent": {
          "type": "string",
          "enum": [
            "spaces-4",
            "spaces-2",
            "tab"
          ],
          "enumDescriptions": [
            "Four spaces per indent level (recommended; common HAProxy style).",
            "Two spaces per indent level.",
            "Tab character per indent level. Not recommended: tabs copy-paste poorly per HAProxy documentation."
          ],
          "default": "spaces-4",
          "markdownDescription": "Indentation for directives inside a section. Section headers stay left-aligned.\n\nPer HAProxy configuration manual §2.1: use tabs or 2-4 spaces; spaces are preferred because tabs do not copy-paste well. The **tab** option is provided for compatibility but is not recommended."
        },
        "haproxy.format.insertBlankLineBetweenSections": {
          "type": "boolean",
          "default": true,
          "description": "Insert a blank line before each new section header."
        }
      }
    },
    "languages": [
      {
        "id": "haproxy",
        "aliases": [
          "HAProxy",
          "haproxy"
        ],
        "extensions": [
          ".cfg"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "haproxy-2.6",
        "aliases": [
          "HAProxy 2.6"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "haproxy-2.8",
        "aliases": [
          "HAProxy 2.8"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "haproxy-3.0",
        "aliases": [
          "HAProxy 3.0"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "haproxy-3.2",
        "aliases": [
          "HAProxy 3.2"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "haproxy-3.4",
        "aliases": [
          "HAProxy 3.4"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "haproxy",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-3.2.tmLanguage.json"
      },
      {
        "language": "haproxy-2.6",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-2.6.tmLanguage.json"
      },
      {
        "language": "haproxy-2.8",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-2.8.tmLanguage.json"
      },
      {
        "language": "haproxy-3.0",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-3.0.tmLanguage.json"
      },
      {
        "language": "haproxy-3.2",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-3.2.tmLanguage.json"
      },
      {
        "language": "haproxy-3.4",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-3.4.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "haproxy.selectVersion",
        "title": "Select HAProxy Version",
        "category": "HAProxy"
      },
      {
        "command": "haproxy.openWorkspaceSymbolSettings",
        "title": "Open Workspace Symbol Settings",
        "category": "HAProxy"
      }
    ]
  },
  "configurationDefaults": {
    "[haproxy]": {
      "editor.maxTokenizationLineLength": 20000
    },
    "[haproxy-2.6]": {
      "editor.maxTokenizationLineLength": 20000
    },
    "[haproxy-2.8]": {
      "editor.maxTokenizationLineLength": 20000
    },
    "[haproxy-3.0]": {
      "editor.maxTokenizationLineLength": 20000
    },
    "[haproxy-3.2]": {
      "editor.maxTokenizationLineLength": 20000
    },
    "[haproxy-3.4]": {
      "editor.maxTokenizationLineLength": 20000
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run verify:package-assets",
    "package": "vsce package",
    "typecheck": "tsc -p ./ --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:docs": "prettier --check \"**/*.md\"",
    "format:generated": "node scripts/normalize-generated-json.mjs",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "verify:package-assets": "node scripts/verify-package-assets.mjs",
    "clean:out": "node scripts/clean-out.mjs",
    "bundle": "node scripts/bundle.mjs",
    "compile": "npm run clean:out && npm run bundle",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "watch": "node scripts/bundle.mjs --watch",
    "verify:highlight": "node scripts/verify-highlight.mjs ../haproxy_git/haproxy-3.2/tests/conf",
    "verify:conf": "node scripts/validate-conf.mjs ../haproxy_git/haproxy-3.2/tests/conf",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:git-clean": "node scripts/check-git-clean.mjs",
    "test:integration": "npm run compile && npm run compile:integration && node scripts/run-integration-tests.mjs",
    "test:integration:smoke": "npm run compile && npm run compile:integration && node scripts/run-integration-tests.mjs --shard smoke",
    "test:integration:workspace": "npm run compile && npm run compile:integration && node scripts/run-integration-tests.mjs --shard workspace",
    "test:integration:settings": "npm run compile && npm run compile:integration && node scripts/run-integration-tests.mjs --shard settings",
    "bench": "vitest bench --config vitest.bench.config.ts --run",
    "bench:fixture": "node scripts/generate-bench-fixture.mjs",
    "bench:fixture:check": "node scripts/generate-bench-fixture.mjs --verify",
    "bench:report": "vitest bench --config vitest.bench.config.ts --run --outputJson scripts/reports/bench-latest.json",
    "bench:check": "node scripts/check-bench-thresholds.mjs scripts/reports/bench-latest.json",
    "bench:update-thresholds": "node scripts/update-bench-thresholds.mjs --downloads",
    "bench:ci": "npm run bench:fixture:check && npm run bench:report && npm run bench:check",
    "bench:integration": "node scripts/run-perf-integration.mjs",
    "bench:integration:check": "node scripts/check-perf-integration-thresholds.mjs scripts/reports/perf-integration.json",
    "bench:tags": "node scripts/bench-tags.mjs",
    "test:grammar-coverage": "node scripts/test-grammar-coverage.mjs",
    "test:upstream": "node scripts/test-diagnostics-upstream.mjs && node scripts/test-highlight-upstream.mjs",
    "compare:haproxy": "node scripts/compare-haproxy-c.mjs --version 3.2",
    "compare:haproxy:2.6": "node scripts/compare-haproxy-c.mjs --version 2.6",
    "compare:haproxy:2.8": "node scripts/compare-haproxy-c.mjs --version 2.8",
    "compare:haproxy:3.0": "node scripts/compare-haproxy-c.mjs --version 3.0",
    "compare:haproxy:3.2": "node scripts/compare-haproxy-c.mjs --version 3.2",
    "compare:haproxy:3.4": "node scripts/compare-haproxy-c.mjs --version 3.4",
    "compare:haproxy:matrix": "node scripts/compare-haproxy-matrix.mjs",
    "compare:haproxy:docker:matrix": "node scripts/compare-haproxy-matrix.mjs --runtime docker",
    "test:all": "npm run compile && npm run test:grammar-coverage && npm run test && npm run test:upstream && npm run compare:haproxy:matrix",
    "generate:schema": "npm run generate:schema:all",
    "generate:schema:all": "npm run generate:schema:2.6 && npm run generate:schema:2.8 && npm run generate:schema:3.0 && npm run generate:schema:3.2 && npm run generate:schema:3.4 && npm run format:generated",
    "generate:schema:3.2": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.2/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.2.txt --out ./schemas/haproxy-3.2.schema.json --language-data-out ./schemas/haproxy-3.2.language.json --grammar-out ./syntaxes/haproxy-3.2.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.2.json --metadata-provenance-out ../haproxy-schema/haproxy_schema/schema-metadata-provenance-3.2.json --version 3.2",
    "generate:dkall:2.6": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 2.6",
    "generate:dkall:2.8": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 2.8",
    "generate:dkall:3.4": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.4",
    "generate:dkall:3.2": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.2",
    "generate:dkall:3.0": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.0",
    "generate:schema:2.6": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-2.6/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-2.6.txt --out ./schemas/haproxy-2.6.schema.json --language-data-out ./schemas/haproxy-2.6.language.json --grammar-out ./syntaxes/haproxy-2.6.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-2.6.json --metadata-provenance-out ../haproxy-schema/haproxy_schema/schema-metadata-provenance-2.6.json --version 2.6",
    "generate:schema:2.8": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-2.8/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-2.8.txt --out ./schemas/haproxy-2.8.schema.json --language-data-out ./schemas/haproxy-2.8.language.json --grammar-out ./syntaxes/haproxy-2.8.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-2.8.json --metadata-provenance-out ../haproxy-schema/haproxy_schema/schema-metadata-provenance-2.8.json --version 2.8",
    "generate:schema:3.4": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.4/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.4.txt --out ./schemas/haproxy-3.4.schema.json --language-data-out ./schemas/haproxy-3.4.language.json --grammar-out ./syntaxes/haproxy-3.4.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.4.json --metadata-provenance-out ../haproxy-schema/haproxy_schema/schema-metadata-provenance-3.4.json --version 3.4",
    "generate:schema:3.0": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.0/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.0.txt --out ./schemas/haproxy-3.0.schema.json --language-data-out ./schemas/haproxy-3.0.language.json --grammar-out ./syntaxes/haproxy-3.0.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.0.json --metadata-provenance-out ../haproxy-schema/haproxy_schema/schema-metadata-provenance-3.0.json --version 3.0",
    "generate:grammar:3.0": "python -m haproxy_schema emit-grammar --schema ./schemas/haproxy-3.0.schema.json --out ./syntaxes/haproxy-3.0.tmLanguage.json",
    "generate:language-data": "npm run generate:schema"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.22",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.8",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.7"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
