{
  "name": "haproxy-config",
  "displayName": "HAProxy Language Support",
  "description": "HAProxy config highlighting, completion, hover docs, and schema diagnostics",
  "version": "0.7.0",
  "publisher": "Exymat",
  "icon": "icon.png",
  "license": "MIT",
  "keywords": [
    "haproxy",
    "load balancer",
    "reverse proxy",
    "proxy",
    "cfg",
    "configuration",
    "syntax highlighting",
    "autocomplete",
    "intellisense",
    "validation",
    "diagnostics",
    "hover",
    "documentation",
    "frontend",
    "backend",
    "acl",
    "devops",
    "networking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Exymat/haproxy-vscode.git"
  },
  "activationEvents": [
    "onLanguage:haproxy"
  ],
  "engines": {
    "node": ">=24",
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "HAProxy",
      "properties": {
        "haproxy.version": {
          "type": "string",
          "enum": [
            "2.6",
            "2.8",
            "3.0",
            "3.2",
            "3.4"
          ],
          "default": "3.2",
          "description": "HAProxy release used for completion, diagnostics, hover, and syntax highlighting."
        },
        "haproxy.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema-based diagnostics for HAProxy configs. Turn off if opening .cfg files is slow."
        },
        "haproxy.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Milliseconds to wait after edits before recomputing diagnostics."
        },
        "haproxy.diagnostics.maxLines": {
          "type": "number",
          "default": 4000,
          "minimum": 100,
          "description": "Skip diagnostics above this line count to protect editor memory."
        },
        "haproxy.diagnostics.deprecatedWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a directive or rule action is marked deprecated in the official HAProxy documentation for the selected version. Suppressed when global expose-deprecated-directives is present."
        },
        "haproxy.format.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable document formatting for HAProxy configs (Format Document)."
        },
        "haproxy.format.indent": {
          "type": "string",
          "enum": [
            "spaces-4",
            "spaces-2",
            "tab"
          ],
          "enumDescriptions": [
            "Four spaces per indent level (recommended; common HAProxy style).",
            "Two spaces per indent level.",
            "Tab character per indent level. Not recommended: tabs copy-paste poorly per HAProxy documentation."
          ],
          "default": "spaces-4",
          "markdownDescription": "Indentation for directives inside a section. Section headers stay left-aligned.\n\nPer HAProxy configuration manual §2.1: use tabs or 2–4 spaces; spaces are preferred because tabs do not copy-paste well. The **tab** option is provided for compatibility but is not recommended."
        },
        "haproxy.format.insertBlankLineBetweenSections": {
          "type": "boolean",
          "default": true,
          "description": "Insert a blank line before each new section header."
        }
      }
    },
    "languages": [
      {
        "id": "haproxy",
        "aliases": [
          "HAProxy",
          "haproxy"
        ],
        "extensions": [
          ".cfg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "haproxy",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy-active.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "haproxy.selectVersion",
        "title": "Select HAProxy Version",
        "category": "HAProxy"
      }
    ]
  },
  "configurationDefaults": {
    "[haproxy]": {
      "editor.maxTokenizationLineLength": 20000
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "compile": "tsc -p ./ && tsc -p tsconfig.integration.json && npm run sync:active-grammar -- 3.2",
    "watch": "tsc -watch -p ./",
    "verify:highlight": "node scripts/verify-highlight.mjs ../haproxy_git/haproxy-3.2/tests/conf",
    "verify:conf": "node scripts/validate-conf.mjs ../haproxy_git/haproxy-3.2/tests/conf",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "npm run compile && vscode-test",
    "test:grammar-coverage": "node scripts/test-grammar-coverage.mjs",
    "test:upstream": "node scripts/test-diagnostics-upstream.mjs && node scripts/test-highlight-upstream.mjs",
    "compare:haproxy": "node scripts/compare-haproxy-c.mjs",
    "test:all": "npm run compile && npm run test:grammar-coverage && npm run test && npm run test:upstream && npm run compare:haproxy",
    "generate:schema": "npm run generate:schema:3.2",
    "generate:schema:3.2": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.2/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.2.txt --out ./schemas/haproxy-3.2.schema.json --language-data-out ./schemas/haproxy-3.2.language.json --grammar-out ./syntaxes/haproxy-3.2.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.2.json --version 3.2",
    "generate:dkall:2.6": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 2.6",
    "generate:dkall:2.8": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 2.8",
    "generate:dkall:3.4": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.4",
    "generate:dkall:3.2": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.2",
    "generate:dkall:3.0": "powershell -ExecutionPolicy Bypass -File ../haproxy-schema/scripts/generate-dkall.ps1 -Version 3.0",
    "generate:schema:2.6": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-2.6/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-2.6.txt --out ./schemas/haproxy-2.6.schema.json --language-data-out ./schemas/haproxy-2.6.language.json --grammar-out ./syntaxes/haproxy-2.6.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-2.6.json --version 2.6",
    "generate:schema:2.8": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-2.8/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-2.8.txt --out ./schemas/haproxy-2.8.schema.json --language-data-out ./schemas/haproxy-2.8.language.json --grammar-out ./syntaxes/haproxy-2.8.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-2.8.json --version 2.8",
    "generate:schema:3.4": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.4/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.4.txt --out ./schemas/haproxy-3.4.schema.json --language-data-out ./schemas/haproxy-3.4.language.json --grammar-out ./syntaxes/haproxy-3.4.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.4.json --version 3.4",
    "generate:schema:3.0": "python -m haproxy_schema build --doc ../haproxy_git/haproxy-3.0/doc/configuration.txt --dkall ../haproxy-schema/haproxy_schema/dkall-3.0.txt --out ./schemas/haproxy-3.0.schema.json --language-data-out ./schemas/haproxy-3.0.language.json --grammar-out ./syntaxes/haproxy-3.0.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json --coverage-out ../haproxy-schema/haproxy_schema/coverage-3.0.json --version 3.0",
    "generate:grammar:3.0": "python -m haproxy_schema emit-grammar --schema ./schemas/haproxy-3.0.schema.json --out ./syntaxes/haproxy-3.0.tmLanguage.json --grammar-template ./syntaxes/haproxy.tmLanguage.json",
    "sync:active-grammar": "node scripts/sync-active-grammar.mjs",
    "generate:language-data": "npm run generate:schema"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.105.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
