{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2024",
    "lib": ["ES2024"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "test/unit/**/*.ts",
    "test/bench/**/*.ts",
    "test/helpers/**/*.ts",
    "test/__mocks__/**/*.ts",
    "src/**/*.ts"
  ]
}
