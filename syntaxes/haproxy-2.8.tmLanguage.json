            }
          }
        },
        {
          "match": "\\b(tcp\\-check)\\s+((?:send\\-binary\\-lf|set\\-var\\-fmt|send\\-binary|unset\\-var|comment|connect|set\\-var|send\\-lf|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(tcp\\-resposne)\\s+((?:content\\ sc\\-set\\-gpt0))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(timeout)\\s+((?:http\\-keep\\-alive|http\\-request|server\\-fin|client\\-fin|connect|server|tunnel|tarpit|client|queue|check|mail))\\b",
