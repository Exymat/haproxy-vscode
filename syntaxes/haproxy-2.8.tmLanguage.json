{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 2.8",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|fcgi\\-app|program|mailers|cache|peers|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|defaults|fcgi\\-app|frontend|program|mailers|backend|listen|global|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|httpclient\\.resolvers\\.disabled|tune\\.h2\\.be\\.glitches\\-threshold|ssl\\-default\\-bind\\-ciphersuites|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.ssl\\.ocsp\\-update\\.maxdelay|deviceatlas\\-properties\\-cookie|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.force\\-private\\-cache|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.listener\\.default\\-shards|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|ssl\\-default\\-server\\-options|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-ciphers|tune\\.disable\\-fast\\-forward|tune\\.listener\\.multi\\-queue|tune\\.vars\\.reqres\\-max\\-size|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.ssl\\.default\\-dh\\-param|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-options|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-sigalgs|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.proc\\-max\\-size|httpclient\\.resolvers\\.id|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pattern\\.cache\\-size|ssl\\-default\\-bind\\-curves|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pool\\-high\\-fd\\-ratio|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|tune\\.h2\\.max\\-frame\\-size|tune\\.lua\\.burst\\-timeout|tune\\.sched\\.low\\-latency|httpclient\\.ssl\\.ca\\-file|tune\\.pool\\-low\\-fd\\-ratio|server\\-state\\-file\\-name|tune\\.fd\\.edge\\-triggered|tune\\.vars\\.txn\\-max\\-size|ssl\\-load\\-extra\\-del\\-ext|accepted_payload_size|httpclient\\.ssl\\.verify|deviceatlas\\-json\\-file|deviceatlas\\-log\\-level|tune\\.idle\\-pool\\.shared|deviceatlas\\-separator|tune\\.lua\\.task\\-timeout|http\\-send\\-name\\-header|max\\-session\\-srv\\-conns|max\\-secondary\\-entries|tune\\.lua\\.forced\\-yield|max\\-keep\\-alive\\-queue|pp2\\-never\\-send\\-local|insecure\\-fork\\-wanted|ssl\\-load\\-extra\\-files|tune\\.zlib\\.windowsize|tune\\.buffers\\.reserve|tune\\.lua\\.log\\.loggers|tune\\.memory\\.hot\\-size|mworker\\-max\\-reloads|tune\\.http\\.logurilen|tune\\.runqueue\\-depth|http\\-after\\-response|h1\\-case\\-adjust\\-file|tune\\.http\\.cookielen|tune\\.stick\\-counters|tune\\.lua\\.log\\.stderr|lua\\-load\\-per\\-thread|hash\\-balance\\-factor|tune\\.maxpollevents|tune\\.comp\\.maxlevel|tune\\.ssl\\.cachesize|tune\\.ssl\\.maxrecord|tune\\.zlib\\.memlevel|dynamic\\-cookie\\-key|tune\\.rcvbuf\\.client|issuers\\-chain\\-path|httpclient\\.retries|no\\-memory\\-trimming|tune\\.sndbuf\\.server|tune\\.buffers\\.limit|tune\\.sndbuf\\.client|tune\\.rcvbuf\\.server|ssl\\-provider\\-path|log\\-send\\-hostname|ssl\\-server\\-verify|server\\-state\\-base|close\\-spread\\-time|tune\\.ssl\\.lifetime|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|parse\\-resolv\\-conf|wurfl\\-cache\\-size|error\\-log\\-format|unique\\-id\\-header|lua\\-prepend\\-path|unique\\-id\\-format|tune\\.recv_enough|profiling\\.memory|tune\\.http\\.maxhdr|numa\\-cpu\\-mapping|wurfl\\-patch\\-file|hard\\-stop\\-after|server\\-template|tune\\.fail\\-alloc|tune\\.maxrewrite|tune\\.lua\\.maxmem|max\\-object\\-size|profiling\\.tasks|resolve_retries|maxcompcpuusage|tune\\.ssl\\.keylog|default_backend|wurfl\\-data\\-file|default\\-server|total\\-max\\-size|cluster\\-secret|srvtcpka\\-intvl|ignore\\-persist|tune\\.idletimer|ssl\\-mode\\-async|clitcpka\\-intvl|tune\\.maxaccept|tune\\.pipesize|nogetaddrinfo|fd\\-hard\\-limit|srvtcpka\\-idle|strict\\-limits|saml\\-sso\\-load|spread\\-checks|master\\-worker|http\\-response|thread\\-groups|force\\-persist|clitcpka\\-idle|ssl\\-propquery|log\\-format\\-sd|busy\\-polling|limited\\-quic|http\\-request|srvtcpka\\-cnt|thread\\-group|clitcpka\\-cnt|default\\-path|use\\-fcgi\\-app|backing\\-file|tcp\\-response|set\\-dumpable|default\\-bind|zero\\-warning|tune\\.bufsize|process\\-vary|compression|prealloc\\-fd|use_backend|maxsessrate|module\\-load|description|tcp\\-request|log\\-forward|errorloc303|monitor\\-uri|maxcomprate|module\\-path|noreuseport|http\\-errors|errorloc302|maxconnrate|pass\\-header|quick\\-exit|maxzlibmem|clitimeout|http\\-error|use\\-server|rate\\-limit|http\\-reuse|maxsslrate|dgram\\-bind|http\\-check|maxsslconn|errorfiles|ssl\\-engine|nameserver|log\\-stderr|contimeout|srvtimeout|unix\\-bind|presetenv|path\\-info|set\\-param|noevports|hash\\-type|localpeer|errorfile|nokqueue|crt\\-base|fullconn|dispatch|nosplice|retry\\-on|resetenv|unsetenv|nbthread|maxpipes|ulimit\\-n|errorloc|userlist|anonkey|cpu\\-map|program|max\\-age|declare|mailers|balance|retries|timeout|pidfile|log\\-tag|ca\\-base|noepoll|no\\-quic|command|docroot|chroot|nopoll|setcap|setenv|option|format|daemon|filter|mailer|maxlen|trace|peers|grace|index|quiet|table|stats|peer|size|node|hold|mode|ring|bind|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|leastconn|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|type|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|comment|connect|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
