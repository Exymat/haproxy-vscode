          "match": "\\b(tcp\\-check)\\s+((?:send\\-binary\\-lf|set\\-var\\-fmt|send\\-binary|unset\\-var|set\\-var|connect|comment|send\\-lf|expect|send))\\b",
          "captures": {
            "1": {
