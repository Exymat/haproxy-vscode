          "match": "\\b(?:accept\\-invalid\\-http\\-response|h1\\-case\\-adjust\\-bogus\\-server|http\\-restrict\\-req\\-hdr\\-names|accept\\-invalid\\-http\\-request|h1\\-case\\-adjust\\-bogus\\-client|http\\-pretend\\-keepalive|idle\\-close\\-on\\-response|http\\-use\\-proxy\\-header|log\\-separate\\-errors|independent\\-streams|http\\-buffer\\-request|http\\-ignore\\-probes|unique\\-id\\-counters|disable\\-h2\\-upgrade|prefer\\-last\\-server|log\\-health\\-checks|http\\-server\\-close|tcp\\-smart\\-connect|proxy\\-v2\\-options|tcp\\-smart\\-accept|http\\-keep\\-alive|start\\-on\\-reload|splice\\-response|splice\\-request|dontlog\\-normal|external\\-check|ssl\\-hello\\-chk|send\\-proxy\\-v2|http\\-no\\-delay|socket\\-stats|abortonclose|accept\\-proxy|unique\\-id\\-id|http\\-version|clear\\-cookie|redis\\-check|splice\\-auto|mysql\\-check|transparent|dontlognull|roundrobin|send\\-proxy|drop\\-query|checkcache|forwardfor|redispatch|mpxs\\-conns|get\\-values|ldap\\-check|spop\\-check|set\\-cookie|originalto|allbackups|httpclose|url_param|keep\\-conn|forwarded|leastconn|contstats|static\\-rr|tcp\\-check|max\\-reqs|httpslog|nolinger|location|srvtcpka|clitcpka|rstring|smtpchk|httpchk|httplog|warning|logasap|comment|lstring|persist|local5|string|status|random|local2|local1|v4only|local4|header|method|local6|v6only|local3|binary|source|unless|health|cookie|tcplog|local7|local0|notice|scheme|prefix|bytes|first|false|FALSE|debug|alert|proto|emerg|tcpka|crit|code|alpn|body|info|http|true|date|proc|sess|TRUE|uuid|hash|rand|ssl|tcp|var|uri|src|hdr|err|dst|npn|env|be|fe|if)\\b"
        }
