{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 2.8",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|userlist|mailers|program|cache|peers|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|defaults|userlist|frontend|mailers|backend|program|listen|global|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.be\\.max\\-concurrent\\-streams|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.fe\\.glitches\\-threshold|ssl\\-default\\-bind\\-ciphersuites|httpclient\\.resolvers\\.disabled|tune\\.h2\\.be\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|tune\\.listener\\.default\\-shards|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-ciphers|ssl\\-default\\-server\\-options|tune\\.listener\\.multi\\-queue|tune\\.ssl\\.default\\-dh\\-param|tune\\.disable\\-fast\\-forward|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.reqres\\-max\\-size|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-options|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|ssl\\-skip\\-self\\-issued\\-ca|httpclient\\.resolvers\\.id|tune\\.vars\\.sess\\-max\\-size|tune\\.pattern\\.cache\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|tune\\.vars\\.proc\\-max\\-size|ssl\\-default\\-bind\\-curves|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.txn\\-max\\-size|tune\\.pool\\-low\\-fd\\-ratio|tune\\.sched\\.low\\-latency|insecure\\-setuid\\-wanted|ssl\\-load\\-extra\\-del\\-ext|tune\\.lua\\.burst\\-timeout|tune\\.h2\\.max\\-frame\\-size|server\\-state\\-file\\-name|tune\\.fd\\.edge\\-triggered|httpclient\\.ssl\\.ca\\-file|tune\\.quic\\.socket\\-owner|deviceatlas\\-json\\-file|tune\\.lua\\.task\\-timeout|deviceatlas\\-separator|http\\-send\\-name\\-header|tune\\.lua\\.forced\\-yield|max\\-secondary\\-entries|httpclient\\.ssl\\.verify|tune\\.idle\\-pool\\.shared|deviceatlas\\-log\\-level|accepted_payload_size|max\\-session\\-srv\\-conns|ssl\\-load\\-extra\\-files|insecure\\-fork\\-wanted|tune\\.memory\\.hot\\-size|max\\-keep\\-alive\\-queue|tune\\.buffers\\.reserve|tune\\.lua\\.log\\.loggers|pp2\\-never\\-send\\-local|tune\\.zlib\\.windowsize|tune\\.lua\\.log\\.stderr|mworker\\-max\\-reloads|hash\\-balance\\-factor|tune\\.http\\.cookielen|http\\-after\\-response|lua\\-load\\-per\\-thread|h1\\-case\\-adjust\\-file|tune\\.runqueue\\-depth|tune\\.stick\\-counters|tune\\.http\\.logurilen|tune\\.zlib\\.memlevel|tune\\.sndbuf\\.server|tune\\.buffers\\.limit|tune\\.maxpollevents|tune\\.sndbuf\\.client|tune\\.rcvbuf\\.client|tune\\.comp\\.maxlevel|tune\\.ssl\\.cachesize|httpclient\\.retries|no\\-memory\\-trimming|issuers\\-chain\\-path|tune\\.ssl\\.maxrecord|tune\\.rcvbuf\\.server|dynamic\\-cookie\\-key|server\\-state\\-base|tune\\.ssl\\.lifetime|log\\-send\\-hostname|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|close\\-spread\\-time|parse\\-resolv\\-conf|ssl\\-provider\\-path|ssl\\-server\\-verify|error\\-log\\-format|unique\\-id\\-format|wurfl\\-patch\\-file|profiling\\.memory|unique\\-id\\-header|numa\\-cpu\\-mapping|lua\\-prepend\\-path|tune\\.recv_enough|wurfl\\-cache\\-size|tune\\.http\\.maxhdr|wurfl\\-data\\-file|max\\-object\\-size|resolve_retries|profiling\\.tasks|tune\\.ssl\\.keylog|server\\-template|tune\\.fail\\-alloc|tune\\.lua\\.maxmem|hard\\-stop\\-after|default_backend|maxcompcpuusage|tune\\.maxrewrite|total\\-max\\-size|cluster\\-secret|srvtcpka\\-intvl|clitcpka\\-intvl|default\\-server|ignore\\-persist|ssl\\-mode\\-async|tune\\.idletimer|tune\\.maxaccept|master\\-worker|http\\-response|tune\\.pipesize|nogetaddrinfo|ssl\\-propquery|fd\\-hard\\-limit|spread\\-checks|force\\-persist|strict\\-limits|saml\\-sso\\-load|thread\\-groups|srvtcpka\\-idle|clitcpka\\-idle|log\\-format\\-sd|busy\\-polling|clitcpka\\-cnt|zero\\-warning|http\\-request|srvtcpka\\-cnt|tune\\.bufsize|tcp\\-response|default\\-path|process\\-vary|use\\-fcgi\\-app|thread\\-group|backing\\-file|limited\\-quic|default\\-bind|set\\-dumpable|maxcomprate|description|noreuseport|maxsessrate|module\\-path|errorloc302|monitor\\-uri|errorloc303|maxconnrate|pass\\-header|module\\-load|log\\-forward|use_backend|prealloc\\-fd|compression|http\\-errors|tcp\\-request|http\\-reuse|http\\-error|log\\-stderr|ssl\\-engine|http\\-check|maxsslconn|dgram\\-bind|clitimeout|quick\\-exit|errorfiles|maxzlibmem|use\\-server|contimeout|maxsslrate|srvtimeout|nameserver|rate\\-limit|errorfile|hash\\-type|set\\-param|localpeer|noevports|path\\-info|unix\\-bind|presetenv|nbthread|retry\\-on|ulimit\\-n|fullconn|unsetenv|resetenv|maxpipes|errorloc|userlist|nokqueue|nosplice|crt\\-base|dispatch|mailers|anonkey|max\\-age|pidfile|noepoll|program|ca\\-base|command|declare|balance|cpu\\-map|log\\-tag|retries|no\\-quic|timeout|docroot|setenv|mailer|format|chroot|nopoll|daemon|filter|setcap|option|maxlen|trace|table|peers|quiet|index|stats|grace|size|bind|ring|node|peer|hold|mode|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|url_param|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-res|algo\\-req|offload|type|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|set\\-var|connect|comment|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
