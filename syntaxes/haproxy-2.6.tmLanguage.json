{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 2.6",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|fcgi\\-app|mailers|program|cache|peers|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|fcgi\\-app|frontend|defaults|mailers|backend|program|global|listen|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.ssl\\.capture\\-cipherlist\\-size|ssl\\-default\\-server\\-ciphersuites|tune\\.peers\\.max\\-updates\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.ssl\\.force\\-private\\-cache|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|load\\-server\\-state\\-from\\-file|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-ciphers|tune\\.quic\\.retry\\-threshold|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.reqres\\-max\\-size|tune\\.listener\\.multi\\-queue|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-options|tune\\.vars\\.check\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.sess\\-max\\-size|tune\\.pattern\\.cache\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.ssl\\.hard\\-maxrecord|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|tune\\.vars\\.proc\\-max\\-size|tune\\.vars\\.txn\\-max\\-size|httpclient\\.ssl\\.ca\\-file|server\\-state\\-file\\-name|insecure\\-setuid\\-wanted|ssl\\-load\\-extra\\-del\\-ext|tune\\.fd\\.edge\\-triggered|tune\\.h2\\.max\\-frame\\-size|tune\\.sched\\.low\\-latency|tune\\.pool\\-low\\-fd\\-ratio|httpclient\\.ssl\\.verify|tune\\.lua\\.task\\-timeout|deviceatlas\\-separator|deviceatlas\\-json\\-file|max\\-session\\-srv\\-conns|max\\-secondary\\-entries|deviceatlas\\-log\\-level|http\\-send\\-name\\-header|tune\\.idle\\-pool\\.shared|tune\\.lua\\.forced\\-yield|accepted_payload_size|tune\\.zlib\\.windowsize|insecure\\-fork\\-wanted|ssl\\-load\\-extra\\-files|tune\\.buffers\\.reserve|pp2\\-never\\-send\\-local|max\\-keep\\-alive\\-queue|tune\\.runqueue\\-depth|hash\\-balance\\-factor|lua\\-load\\-per\\-thread|tune\\.http\\.logurilen|http\\-after\\-response|mworker\\-max\\-reloads|h1\\-case\\-adjust\\-file|tune\\.http\\.cookielen|tune\\.sndbuf\\.server|issuers\\-chain\\-path|tune\\.comp\\.maxlevel|tune\\.ssl\\.maxrecord|tune\\.maxpollevents|dynamic\\-cookie\\-key|tune\\.rcvbuf\\.server|tune\\.ssl\\.cachesize|tune\\.buffers\\.limit|tune\\.rcvbuf\\.client|no\\-memory\\-trimming|tune\\.sndbuf\\.client|tune\\.zlib\\.memlevel|log\\-send\\-hostname|parse\\-resolv\\-conf|ssl\\-server\\-verify|ssl\\-provider\\-path|tune\\.ssl\\.lifetime|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|close\\-spread\\-time|server\\-state\\-base|numa\\-cpu\\-mapping|error\\-log\\-format|tune\\.recv_enough|unique\\-id\\-format|unique\\-id\\-header|lua\\-prepend\\-path|profiling\\.memory|tune\\.http\\.maxhdr|tune\\.ssl\\.keylog|max\\-object\\-size|server\\-template|tune\\.fail\\-alloc|profiling\\.tasks|tune\\.maxrewrite|default_backend|resolve_retries|hard\\-stop\\-after|tune\\.lua\\.maxmem|maxcompcpuusage|total\\-max\\-size|tune\\.maxaccept|clitcpka\\-intvl|ssl\\-mode\\-async|srvtcpka\\-intvl|default\\-server|cluster\\-secret|tune\\.idletimer|ignore\\-persist|nogetaddrinfo|log\\-format\\-sd|http\\-response|saml\\-sso\\-load|ssl\\-propquery|clitcpka\\-idle|strict\\-limits|srvtcpka\\-idle|thread\\-groups|master\\-worker|tune\\.pipesize|force\\-persist|spread\\-checks|fd\\-hard\\-limit|thread\\-group|backing\\-file|busy\\-polling|tune\\.bufsize|http\\-request|srvtcpka\\-cnt|tcp\\-response|bind\\-process|default\\-path|clitcpka\\-cnt|use\\-fcgi\\-app|default\\-bind|zero\\-warning|process\\-vary|set\\-dumpable|log\\-forward|module\\-load|tcp\\-request|module\\-path|http\\-errors|maxcomprate|errorloc302|maxconnrate|pass\\-header|noreuseport|errorloc303|monitor\\-uri|use_backend|compression|maxsessrate|description|srvtimeout|log\\-stderr|http\\-check|use\\-server|clitimeout|rate\\-limit|errorfiles|dgram\\-bind|nameserver|maxzlibmem|http\\-error|maxsslconn|contimeout|ssl\\-engine|maxsslrate|http\\-reuse|unix\\-bind|presetenv|set\\-param|errorfile|noevports|localpeer|path\\-info|hash\\-type|retry\\-on|fullconn|nosplice|errorloc|nokqueue|resetenv|maxpipes|unsetenv|ulimit\\-n|dispatch|userlist|crt\\-base|nbthread|mailers|noepoll|declare|log\\-tag|timeout|docroot|retries|ca\\-base|balance|program|max\\-age|pidfile|cpu\\-map|command|filter|format|maxlen|option|daemon|mailer|nopoll|chroot|setenv|peers|stats|table|quiet|grace|index|mode|size|hold|peer|ring|node|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|connect|comment|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-invalid\\-http\\-response|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-pretend\\-keepalive|option\\ idle\\-close\\-on\\-response|option\\ http\\-use\\-proxy\\-header|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ log\\-separate\\-errors|option\\ http\\-ignore\\-probes|option\\ disable\\-h2\\-upgrade|option\\ prefer\\-last\\-server|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ http\\-keep\\-alive|option\\ splice\\-response|option\\ start\\-on\\-reload|option\\ splice\\-request|option\\ dontlog\\-normal|option\\ http\\-no\\-delay|option\\ abortonclose|option\\ socket\\-stats|option\\ dontlognull|option\\ transparent|option\\ splice\\-auto|option\\ allbackups|option\\ mpxs\\-conns|option\\ checkcache|option\\ redispatch|option\\ get\\-values|option\\ httpclose|option\\ keep\\-conn|option\\ clitcpka|option\\ srvtcpka|option\\ nolinger|option\\ logasap|option\\ persist|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(persist)\\s+((?:rdp\\-cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(rate\\-limit)\\s+((?:sessions))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+((?:location|scheme|prefix))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stats)\\s+((?:show\\-modules|show\\-legends|bind\\-process|hide\\-version|http\\-request|show\\-desc|show\\-node|maxconn|timeout|refresh|enable|socket|realm|scope|admin|auth|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stick)\\s+((?:store\\-response|store\\-request|match|on))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stick\\-table)\\s+((?:type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(tcp\\-check)\\s+((?:send\\-binary\\-lf|send\\-binary|set\\-var\\-fmt|unset\\-var|connect|send\\-lf|comment|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(tcp\\-resposne)\\s+((?:content\\ sc\\-set\\-gpt0))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(timeout)\\s+((?:http\\-keep\\-alive|http\\-request|client\\-fin|server\\-fin|connect|tarpit|tunnel|server|client|check|queue|mail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        }
      ]
    },
    "rule-actions": {
