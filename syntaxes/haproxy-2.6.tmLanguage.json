          "match": "\\b(?:accept\\-invalid\\-http\\-response|http\\-restrict\\-req\\-hdr\\-names|h1\\-case\\-adjust\\-bogus\\-server|h1\\-case\\-adjust\\-bogus\\-client|accept\\-invalid\\-http\\-request|http\\-pretend\\-keepalive|idle\\-close\\-on\\-response|http\\-use\\-proxy\\-header|log\\-separate\\-errors|http\\-buffer\\-request|independent\\-streams|prefer\\-last\\-server|http\\-ignore\\-probes|unique\\-id\\-counters|disable\\-h2\\-upgrade|tcp\\-smart\\-connect|http\\-server\\-close|log\\-health\\-checks|tcp\\-smart\\-accept|proxy\\-v2\\-options|splice\\-response|start\\-on\\-reload|http\\-keep\\-alive|dontlog\\-normal|splice\\-request|external\\-check|http\\-no\\-delay|ssl\\-hello\\-chk|send\\-proxy\\-v2|socket\\-stats|abortonclose|unique\\-id\\-id|http\\-version|accept\\-proxy|clear\\-cookie|redis\\-check|splice\\-auto|dontlognull|transparent|mysql\\-check|roundrobin|originalto|ldap\\-check|set\\-cookie|checkcache|mpxs\\-conns|redispatch|spop\\-check|drop\\-query|get\\-values|send\\-proxy|forwardfor|allbackups|httpclose|keep\\-conn|url_param|leastconn|tcp\\-check|static\\-rr|contstats|nolinger|max\\-reqs|location|clitcpka|srvtcpka|httpslog|httpchk|logasap|httplog|rstring|warning|lstring|comment|smtpchk|persist|unless|local0|local3|status|scheme|local5|cookie|random|v6only|local4|method|health|local6|source|header|binary|tcplog|prefix|v4only|local2|local1|local7|notice|string|proto|tcpka|bytes|alert|FALSE|false|emerg|first|debug|alpn|rand|info|true|hash|sess|TRUE|proc|http|body|code|date|crit|uuid|src|tcp|npn|uri|dst|err|var|env|hdr|ssl|be|fe|if)\\b"
        }
