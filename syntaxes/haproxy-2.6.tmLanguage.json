          "match": "\\b(?:accept\\-invalid\\-http\\-response|h1\\-case\\-adjust\\-bogus\\-client|accept\\-invalid\\-http\\-request|http\\-restrict\\-req\\-hdr\\-names|h1\\-case\\-adjust\\-bogus\\-server|idle\\-close\\-on\\-response|http\\-pretend\\-keepalive|http\\-use\\-proxy\\-header|log\\-separate\\-errors|independent\\-streams|http\\-buffer\\-request|prefer\\-last\\-server|http\\-ignore\\-probes|disable\\-h2\\-upgrade|unique\\-id\\-counters|log\\-health\\-checks|http\\-server\\-close|tcp\\-smart\\-connect|tcp\\-smart\\-accept|proxy\\-v2\\-options|start\\-on\\-reload|splice\\-response|http\\-keep\\-alive|dontlog\\-normal|splice\\-request|external\\-check|http\\-no\\-delay|send\\-proxy\\-v2|ssl\\-hello\\-chk|accept\\-proxy|socket\\-stats|abortonclose|clear\\-cookie|unique\\-id\\-id|http\\-version|redis\\-check|dontlognull|transparent|mysql\\-check|splice\\-auto|drop\\-query|forwardfor|ldap\\-check|checkcache|set\\-cookie|send\\-proxy|mpxs\\-conns|originalto|allbackups|spop\\-check|redispatch|get\\-values|roundrobin|contstats|leastconn|url_param|keep\\-conn|static\\-rr|tcp\\-check|httpclose|httpslog|srvtcpka|nolinger|location|max\\-reqs|clitcpka|httplog|lstring|logasap|comment|smtpchk|rstring|persist|httpchk|warning|local6|v6only|scheme|status|local4|local1|local0|notice|string|health|local2|tcplog|header|source|local5|v4only|binary|random|prefix|local7|local3|method|unless|cookie|FALSE|first|false|bytes|alert|tcpka|proto|emerg|debug|hash|date|crit|alpn|body|TRUE|uuid|rand|true|info|proc|http|sess|code|hdr|src|npn|dst|tcp|var|uri|env|ssl|err|be|if|fe)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "keyword.other.modifier.haproxy",
