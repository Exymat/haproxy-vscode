          "match": "\\b(?:accept\\-invalid\\-http\\-response|h1\\-case\\-adjust\\-bogus\\-server|http\\-restrict\\-req\\-hdr\\-names|accept\\-invalid\\-http\\-request|h1\\-case\\-adjust\\-bogus\\-client|idle\\-close\\-on\\-response|http\\-pretend\\-keepalive|http\\-use\\-proxy\\-header|log\\-separate\\-errors|http\\-buffer\\-request|independent\\-streams|prefer\\-last\\-server|disable\\-h2\\-upgrade|http\\-ignore\\-probes|unique\\-id\\-counters|tcp\\-smart\\-connect|http\\-server\\-close|log\\-health\\-checks|proxy\\-v2\\-options|tcp\\-smart\\-accept|start\\-on\\-reload|splice\\-response|http\\-keep\\-alive|splice\\-request|dontlog\\-normal|external\\-check|send\\-proxy\\-v2|http\\-no\\-delay|ssl\\-hello\\-chk|clear\\-cookie|socket\\-stats|unique\\-id\\-id|abortonclose|accept\\-proxy|http\\-version|splice\\-auto|dontlognull|mysql\\-check|redis\\-check|transparent|redispatch|checkcache|roundrobin|send\\-proxy|mpxs\\-conns|allbackups|forwardfor|originalto|get\\-values|set\\-cookie|drop\\-query|ldap\\-check|spop\\-check|leastconn|tcp\\-check|contstats|static\\-rr|url_param|keep\\-conn|httpclose|srvtcpka|location|max\\-reqs|clitcpka|httpslog|nolinger|lstring|rstring|comment|warning|smtpchk|logasap|httpchk|httplog|persist|local1|status|local5|string|random|tcplog|local3|local7|local6|health|unless|binary|source|header|local2|method|cookie|notice|prefix|local0|scheme|v6only|local4|v4only|bytes|alert|tcpka|emerg|proto|debug|FALSE|first|false|TRUE|hash|alpn|body|rand|uuid|info|crit|code|sess|true|http|date|proc|ssl|env|uri|tcp|npn|hdr|var|err|dst|src|fe|be|if)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "keyword.other.modifier.haproxy",
          "match": "\\b(?:no|(?<!from )default|!\\s*)\\b"
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "string.unquoted.haproxy",
          "match": "\\{[^}]*\\}"
        },
        {
          "name": "string.unquoted.haproxy",
          "match": "%\\[[^\\]]*\\]"
        },
        {
          "name": "string.unquoted.haproxy",
          "match": "\\[[^\\]]*\\]"
        },
        {
