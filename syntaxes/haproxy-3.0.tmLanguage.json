{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|userlist|mailers|program|peers|cache|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|defaults|frontend|fcgi\\-app|userlist|mailers|program|backend|listen|global|peers|cache|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.h2\\.fe\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.ssl\\.ocsp\\-update\\.maxdelay|httpclient\\.resolvers\\.disabled|tune\\.h2\\.fe\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.force\\-private\\-cache|tune\\.listener\\.default\\-shards|tune\\.quic\\.zero\\-copy\\-fwd\\-send|expose\\-deprecated\\-directives|tune\\.ssl\\.capture\\-buffer\\-size|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-ciphers|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|warn\\-blocked\\-traffic\\-after|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-sigalgs|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-curves|tune\\.listener\\.multi\\-queue|tune\\.h2\\.header\\-table\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.reqres\\-max\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.disable\\-fast\\-forward|tune\\.lua\\.session\\-timeout|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.service\\-timeout|ssl\\-skip\\-self\\-issued\\-ca|tune\\.vars\\.sess\\-max\\-size|tune\\.vars\\.proc\\-max\\-size|tune\\.quic\\.reorder\\-ratio|ssl\\-default\\-bind\\-curves|tune\\.pattern\\.cache\\-size|httpclient\\.resolvers\\.id|tune\\.ssl\\.hard\\-maxrecord|tune\\.pool\\-high\\-fd\\-ratio|tune\\.pool\\-low\\-fd\\-ratio|tune\\.sched\\.low\\-latency|tune\\.lua\\.burst\\-timeout|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|server\\-state\\-file\\-name|tune\\.vars\\.txn\\-max\\-size|tune\\.epoll\\.mask\\-events|tune\\.h2\\.max\\-frame\\-size|ssl\\-load\\-extra\\-del\\-ext|tune\\.fd\\.edge\\-triggered|httpclient\\.ssl\\.ca\\-file|max\\-session\\-srv\\-conns|deviceatlas\\-separator|http\\-send\\-name\\-header|tune\\.idle\\-pool\\.shared|deviceatlas\\-log\\-level|tune\\.lua\\.task\\-timeout|ocsp\\-update\\.httpproxy|tune\\.lua\\.forced\\-yield|httpclient\\.ssl\\.verify|accepted_payload_size|deviceatlas\\-json\\-file|max\\-secondary\\-entries|tune\\.memory\\.hot\\-size|tune\\.sndbuf\\.frontend|tune\\.buffers\\.reserve|tune\\.lua\\.log\\.loggers|pp2\\-never\\-send\\-local|tune\\.zlib\\.windowsize|ocsp\\-update\\.maxdelay|tune\\.rcvbuf\\.frontend|ocsp\\-update\\.mindelay|insecure\\-fork\\-wanted|tune\\.quic\\.cc\\-hystart|ssl\\-load\\-extra\\-files|max\\-keep\\-alive\\-queue|ocsp\\-update\\.disable|tune\\.stick\\-counters|hash\\-balance\\-factor|lua\\-load\\-per\\-thread|tune\\.rcvbuf\\.backend|tune\\.http\\.cookielen|http\\-after\\-response|mworker\\-max\\-reloads|tune\\.runqueue\\-depth|tune\\.lua\\.log\\.stderr|tune\\.http\\.logurilen|h1\\-case\\-adjust\\-file|tune\\.sndbuf\\.backend|issuers\\-chain\\-path|tune\\.ssl\\.maxrecord|tune\\.rcvbuf\\.client|ssl\\-security\\-level|dynamic\\-cookie\\-key|tune\\.comp\\.maxlevel|tune\\.sndbuf\\.client|tune\\.maxpollevents|no\\-memory\\-trimming|tune\\.rcvbuf\\.server|tune\\.zlib\\.memlevel|httpclient\\.retries|tune\\.sndbuf\\.server|tune\\.ssl\\.cachesize|tune\\.buffers\\.limit|close\\-spread\\-time|tune\\.ssl\\.lifetime|thread\\-hard\\-limit|ssl\\-provider\\-path|ssl\\-server\\-verify|server\\-state\\-base|log\\-send\\-hostname|ssl\\-dh\\-param\\-file|parse\\-resolv\\-conf|max\\-spread\\-checks|unique\\-id\\-format|unique\\-id\\-header|numa\\-cpu\\-mapping|lua\\-prepend\\-path|wurfl\\-patch\\-file|profiling\\.memory|tune\\.http\\.maxhdr|error\\-log\\-format|tune\\.ring\\.queues|tune\\.recv_enough|wurfl\\-cache\\-size|ocsp\\-update\\.mode|maxcompcpuusage|default_backend|hard\\-stop\\-after|max\\-object\\-size|tune\\.maxrewrite|profiling\\.tasks|wurfl\\-data\\-file|tune\\.fail\\-alloc|tune\\.lua\\.maxmem|http\\-fail\\-codes|server\\-template|resolve_retries|tune\\.ssl\\.keylog|srvtcpka\\-intvl|ignore\\-persist|cluster\\-secret|tune\\.maxaccept|http\\-err\\-codes|ssl\\-mode\\-async|total\\-max\\-size|tune\\.idletimer|default\\-server|clitcpka\\-intvl|tune\\.pipesize|nogetaddrinfo|saml\\-sso\\-load|master\\-worker|thread\\-groups|srvtcpka\\-idle|strict\\-limits|spread\\-checks|log\\-format\\-sd|clitcpka\\-idle|http\\-response|ssl\\-propquery|force\\-persist|fd\\-hard\\-limit|default\\-path|thread\\-group|use\\-fcgi\\-app|busy\\-polling|set\\-dumpable|default\\-bind|tcp\\-response|clitcpka\\-cnt|srvtcpka\\-cnt|tune\\.bufsize|zero\\-warning|http\\-request|limited\\-quic|process\\-vary|backing\\-file|maxcomprate|errorloc302|log\\-forward|prealloc\\-fd|compression|module\\-load|module\\-path|maxsessrate|tcp\\-request|noreuseport|pass\\-header|errorloc303|use_backend|http\\-errors|monitor\\-uri|ocsp\\-update|description|maxconnrate|dgram\\-bind|contimeout|http\\-check|maxsslrate|http\\-error|rate\\-limit|http\\-reuse|ssl\\-engine|stats\\-file|errorfiles|srvtimeout|quick\\-exit|nameserver|maxzlibmem|log\\-stderr|maxsslconn|use\\-server|clitimeout|errorfile|unix\\-bind|localpeer|set\\-param|presetenv|hash\\-type|noevports|path\\-info|crt\\-base|userlist|fullconn|resetenv|dispatch|nokqueue|maxpipes|ulimit\\-n|unsetenv|retry\\-on|errorloc|key\\-base|nosplice|nbthread|retries|noepoll|timeout|ca\\-base|program|no\\-quic|declare|balance|max\\-age|command|mailers|docroot|anonkey|cpu\\-map|log\\-tag|pidfile|nopoll|mailer|issuer|format|filter|setenv|setcap|chroot|daemon|option|maxlen|alias|table|peers|quiet|trace|index|grace|bind|ring|mode|sctl|peer|node|hold|size|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|url_param|leastconn|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|type|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
