{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|fcgi\\-app|mailers|program|cache|peers|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|defaults|userlist|crt\\-list|frontend|fcgi\\-app|mailers|program|backend|listen|global|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.tcp|h1\\-accept\\-payload\\-with\\-any\\-method|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.certificate\\-compression|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.events\\.max\\-events\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.fe\\.glitches\\-threshold|httpclient\\.resolvers\\.disabled|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|expose\\-deprecated\\-directives|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.ssl\\.force\\-private\\-cache|tune\\.listener\\.default\\-shards|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|httpclient\\.timeout\\.connect|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-options|warn\\-blocked\\-traffic\\-after|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-ciphers|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-sigalgs|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.multi\\-queue|tune\\.ssl\\.default\\-dh\\-param|tune\\.h2\\.header\\-table\\-size|tune\\.disable\\-fast\\-forward|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.global\\-max\\-size|ssl\\-default\\-server\\-curves|tune\\.vars\\.reqres\\-max\\-size|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.session\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-sigalgs|tune\\.vars\\.check\\-max\\-size|tune\\.pattern\\.cache\\-size|ssl\\-default\\-bind\\-curves|tune\\.vars\\.sess\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|tune\\.ssl\\.hard\\-maxrecord|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.proc\\-max\\-size|httpclient\\.resolvers\\.id|ssl\\-skip\\-self\\-issued\\-ca|tune\\.h2\\.max\\-frame\\-size|tune\\.fd\\.edge\\-triggered|ssl\\-load\\-extra\\-del\\-ext|httpclient\\.ssl\\.ca\\-file|tune\\.vars\\.txn\\-max\\-size|tune\\.epoll\\.mask\\-events|tune\\.sched\\.low\\-latency|tune\\.pool\\-low\\-fd\\-ratio|insecure\\-setuid\\-wanted|tune\\.quic\\.socket\\-owner|tune\\.lua\\.burst\\-timeout|server\\-state\\-file\\-name|deviceatlas\\-json\\-file|max\\-session\\-srv\\-conns|max\\-secondary\\-entries|ocsp\\-update\\.httpproxy|http\\-send\\-name\\-header|deviceatlas\\-separator|tune\\.idle\\-pool\\.shared|deviceatlas\\-log\\-level|accepted_payload_size|tune\\.lua\\.forced\\-yield|tune\\.lua\\.task\\-timeout|httpclient\\.ssl\\.verify|insecure\\-fork\\-wanted|tune\\.buffers\\.reserve|tune\\.quic\\.cc\\-hystart|tune\\.memory\\.hot\\-size|ocsp\\-update\\.mindelay|ssl\\-load\\-extra\\-files|tune\\.rcvbuf\\.frontend|tune\\.lua\\.log\\.loggers|tune\\.zlib\\.windowsize|pp2\\-never\\-send\\-local|max\\-keep\\-alive\\-queue|tune\\.sndbuf\\.frontend|ocsp\\-update\\.maxdelay|tune\\.rcvbuf\\.backend|mworker\\-max\\-reloads|hash\\-balance\\-factor|tune\\.http\\.logurilen|tune\\.sndbuf\\.backend|http\\-after\\-response|h1\\-case\\-adjust\\-file|tune\\.lua\\.log\\.stderr|ocsp\\-update\\.disable|lua\\-load\\-per\\-thread|tune\\.stick\\-counters|tune\\.runqueue\\-depth|tune\\.http\\.cookielen|dynamic\\-cookie\\-key|httpclient\\.retries|tune\\.ssl\\.cachesize|no\\-memory\\-trimming|tune\\.maxpollevents|tune\\.zlib\\.memlevel|tune\\.ssl\\.maxrecord|tune\\.sndbuf\\.server|ssl\\-security\\-level|tune\\.rcvbuf\\.client|tune\\.comp\\.maxlevel|issuers\\-chain\\-path|tune\\.sndbuf\\.client|tune\\.buffers\\.limit|tune\\.rcvbuf\\.server|tune\\.ssl\\.lifetime|server\\-state\\-base|parse\\-resolv\\-conf|max\\-spread\\-checks|close\\-spread\\-time|ssl\\-dh\\-param\\-file|ssl\\-server\\-verify|ssl\\-provider\\-path|log\\-send\\-hostname|thread\\-hard\\-limit|tune\\.ring\\.queues|profiling\\.memory|tune\\.recv_enough|lua\\-prepend\\-path|tune\\.http\\.maxhdr|numa\\-cpu\\-mapping|error\\-log\\-format|unique\\-id\\-header|ocsp\\-update\\.mode|unique\\-id\\-format|profiling\\.tasks|hard\\-stop\\-after|http\\-fail\\-codes|default_backend|tune\\.fail\\-alloc|maxcompcpuusage|tune\\.lua\\.maxmem|max\\-object\\-size|tune\\.ssl\\.keylog|resolve_retries|tune\\.maxrewrite|server\\-template|http\\-err\\-codes|tune\\.maxaccept|default\\-server|srvtcpka\\-intvl|ssl\\-mode\\-async|clitcpka\\-intvl|ignore\\-persist|tune\\.idletimer|cluster\\-secret|total\\-max\\-size|saml\\-sso\\-load|force\\-persist|tune\\.pipesize|http\\-response|spread\\-checks|thread\\-groups|strict\\-limits|ssl\\-propquery|nogetaddrinfo|srvtcpka\\-idle|log\\-format\\-sd|fd\\-hard\\-limit|clitcpka\\-idle|master\\-worker|process\\-vary|set\\-dumpable|thread\\-group|backing\\-file|limited\\-quic|tcp\\-response|tune\\.bufsize|zero\\-warning|use\\-fcgi\\-app|http\\-request|srvtcpka\\-cnt|default\\-path|busy\\-polling|default\\-bind|clitcpka\\-cnt|monitor\\-uri|prealloc\\-fd|compression|module\\-path|maxcomprate|maxsessrate|http\\-errors|noreuseport|use_backend|description|module\\-load|errorloc302|tcp\\-request|pass\\-header|errorloc303|maxconnrate|ocsp\\-update|log\\-forward|errorfiles|use\\-server|contimeout|maxzlibmem|nameserver|http\\-reuse|maxsslrate|quick\\-exit|clitimeout|srvtimeout|log\\-stderr|http\\-check|http\\-error|maxsslconn|stats\\-file|rate\\-limit|dgram\\-bind|ssl\\-engine|path\\-info|localpeer|hash\\-type|noevports|presetenv|set\\-param|unix\\-bind|errorfile|nosplice|nokqueue|crt\\-base|retry\\-on|userlist|unsetenv|nbthread|maxpipes|errorloc|fullconn|resetenv|key\\-base|dispatch|ulimit\\-n|log\\-tag|docroot|ca\\-base|mailers|no\\-quic|timeout|noepoll|anonkey|balance|max\\-age|command|retries|program|cpu\\-map|pidfile|declare|option|maxlen|chroot|issuer|filter|setenv|daemon|setcap|nopoll|mailer|format|table|peers|grace|quiet|index|alias|trace|bind|peer|hold|node|size|sctl|mode|ring|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|url_param|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
