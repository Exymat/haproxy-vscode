{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|userlist|mailers|program|peers|cache|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|frontend|userlist|defaults|mailers|backend|program|global|listen|peers|cache|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.be\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|httpclient\\.resolvers\\.disabled|expose\\-deprecated\\-directives|tune\\.listener\\.default\\-shards|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.capture\\-buffer\\-size|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-sigalgs|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-ciphers|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-options|tune\\.h1\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.multi\\-queue|ssl\\-default\\-server\\-curves|tune\\.vars\\.global\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.reqres\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.h2\\.header\\-table\\-size|tune\\.disable\\-fast\\-forward|ssl\\-default\\-bind\\-sigalgs|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-options|tune\\.lua\\.session\\-timeout|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.service\\-timeout|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|tune\\.vars\\.proc\\-max\\-size|tune\\.ssl\\.hard\\-maxrecord|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pattern\\.cache\\-size|ssl\\-default\\-bind\\-curves|ssl\\-load\\-extra\\-del\\-ext|tune\\.lua\\.burst\\-timeout|tune\\.fd\\.edge\\-triggered|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|server\\-state\\-file\\-name|tune\\.vars\\.txn\\-max\\-size|tune\\.sched\\.low\\-latency|tune\\.h2\\.max\\-frame\\-size|tune\\.epoll\\.mask\\-events|httpclient\\.ssl\\.ca\\-file|tune\\.pool\\-low\\-fd\\-ratio|accepted_payload_size|ocsp\\-update\\.httpproxy|http\\-send\\-name\\-header|max\\-session\\-srv\\-conns|tune\\.idle\\-pool\\.shared|tune\\.lua\\.forced\\-yield|deviceatlas\\-log\\-level|tune\\.lua\\.task\\-timeout|deviceatlas\\-separator|httpclient\\.ssl\\.verify|max\\-secondary\\-entries|deviceatlas\\-json\\-file|ocsp\\-update\\.mindelay|insecure\\-fork\\-wanted|tune\\.buffers\\.reserve|tune\\.zlib\\.windowsize|ocsp\\-update\\.maxdelay|max\\-keep\\-alive\\-queue|pp2\\-never\\-send\\-local|tune\\.quic\\.cc\\-hystart|tune\\.sndbuf\\.frontend|tune\\.memory\\.hot\\-size|ssl\\-load\\-extra\\-files|tune\\.lua\\.log\\.loggers|tune\\.rcvbuf\\.frontend|tune\\.runqueue\\-depth|mworker\\-max\\-reloads|tune\\.rcvbuf\\.backend|tune\\.stick\\-counters|tune\\.lua\\.log\\.stderr|ocsp\\-update\\.disable|tune\\.sndbuf\\.backend|tune\\.http\\.logurilen|http\\-after\\-response|tune\\.http\\.cookielen|h1\\-case\\-adjust\\-file|lua\\-load\\-per\\-thread|hash\\-balance\\-factor|tune\\.sndbuf\\.server|tune\\.sndbuf\\.client|tune\\.rcvbuf\\.server|issuers\\-chain\\-path|tune\\.ssl\\.cachesize|tune\\.comp\\.maxlevel|httpclient\\.retries|dynamic\\-cookie\\-key|no\\-memory\\-trimming|tune\\.buffers\\.limit|ssl\\-security\\-level|tune\\.maxpollevents|tune\\.rcvbuf\\.client|tune\\.ssl\\.maxrecord|tune\\.zlib\\.memlevel|ssl\\-server\\-verify|max\\-spread\\-checks|server\\-state\\-base|ssl\\-provider\\-path|thread\\-hard\\-limit|tune\\.ssl\\.lifetime|parse\\-resolv\\-conf|log\\-send\\-hostname|close\\-spread\\-time|ssl\\-dh\\-param\\-file|error\\-log\\-format|wurfl\\-patch\\-file|unique\\-id\\-header|lua\\-prepend\\-path|profiling\\.memory|unique\\-id\\-format|tune\\.http\\.maxhdr|numa\\-cpu\\-mapping|tune\\.ring\\.queues|tune\\.recv_enough|wurfl\\-cache\\-size|ocsp\\-update\\.mode|server\\-template|wurfl\\-data\\-file|max\\-object\\-size|tune\\.maxrewrite|tune\\.ssl\\.keylog|http\\-fail\\-codes|tune\\.lua\\.maxmem|maxcompcpuusage|tune\\.fail\\-alloc|resolve_retries|hard\\-stop\\-after|default_backend|profiling\\.tasks|ssl\\-mode\\-async|http\\-err\\-codes|tune\\.maxaccept|cluster\\-secret|ignore\\-persist|default\\-server|srvtcpka\\-intvl|clitcpka\\-intvl|total\\-max\\-size|tune\\.idletimer|thread\\-groups|strict\\-limits|tune\\.pipesize|log\\-format\\-sd|srvtcpka\\-idle|ssl\\-propquery|fd\\-hard\\-limit|nogetaddrinfo|master\\-worker|spread\\-checks|saml\\-sso\\-load|clitcpka\\-idle|force\\-persist|http\\-response|use\\-fcgi\\-app|http\\-request|srvtcpka\\-cnt|set\\-dumpable|tcp\\-response|backing\\-file|default\\-path|process\\-vary|tune\\.bufsize|busy\\-polling|zero\\-warning|clitcpka\\-cnt|thread\\-group|limited\\-quic|default\\-bind|pass\\-header|http\\-errors|maxsessrate|monitor\\-uri|ocsp\\-update|prealloc\\-fd|log\\-forward|module\\-path|maxcomprate|use_backend|noreuseport|errorloc302|description|tcp\\-request|compression|errorloc303|module\\-load|maxconnrate|clitimeout|contimeout|nameserver|errorfiles|rate\\-limit|http\\-error|stats\\-file|maxzlibmem|http\\-reuse|ssl\\-engine|dgram\\-bind|use\\-server|srvtimeout|http\\-check|maxsslrate|quick\\-exit|maxsslconn|log\\-stderr|localpeer|set\\-param|path\\-info|noevports|errorfile|hash\\-type|presetenv|unix\\-bind|maxpipes|dispatch|userlist|crt\\-base|resetenv|errorloc|nbthread|key\\-base|retry\\-on|ulimit\\-n|nosplice|unsetenv|fullconn|nokqueue|command|docroot|no\\-quic|ca\\-base|retries|log\\-tag|balance|max\\-age|cpu\\-map|pidfile|anonkey|timeout|program|declare|noepoll|mailers|mailer|issuer|option|setcap|daemon|filter|chroot|nopoll|setenv|format|maxlen|table|peers|index|grace|trace|quiet|alias|node|bind|peer|mode|ring|hold|sctl|size|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|leastconn|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-res|algo\\-req|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
