          "match": "\\b(stats)\\s+((?:http\\-request|show\\-legends|hide\\-version|show\\-modules|show\\-desc|show\\-node|maxconn|timeout|refresh|enable|socket|realm|scope|admin|auth|uri))\\b",
          "captures": {
