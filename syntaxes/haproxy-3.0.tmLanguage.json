        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|send\\-state|unset\\-var|connect|set\\-var|comment|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
