{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|userlist|crt\\-list|fcgi\\-app|program|mailers|peers|cache|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|frontend|userlist|crt\\-list|fcgi\\-app|defaults|backend|program|mailers|listen|global|peers|cache|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.disable\\-zero\\-copy\\-forwarding|ssl\\-default\\-server\\-client\\-sigalgs|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.fe\\.glitches\\-threshold|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|deviceatlas\\-properties\\-cookie|httpclient\\.resolvers\\.disabled|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.capture\\-buffer\\-size|expose\\-deprecated\\-directives|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.ssl\\.force\\-private\\-cache|tune\\.listener\\.default\\-shards|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h2\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-ciphers|ssl\\-default\\-server\\-sigalgs|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.max\\-checks\\-per\\-thread|warn\\-blocked\\-traffic\\-after|tune\\.quic\\.retry\\-threshold|tune\\.listener\\.multi\\-queue|tune\\.vars\\.reqres\\-max\\-size|tune\\.disable\\-fast\\-forward|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.global\\-max\\-size|tune\\.h2\\.header\\-table\\-size|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.session\\-timeout|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|ssl\\-skip\\-self\\-issued\\-ca|httpclient\\.resolvers\\.id|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.proc\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|ssl\\-default\\-bind\\-curves|tune\\.pattern\\.cache\\-size|tune\\.pool\\-low\\-fd\\-ratio|tune\\.lua\\.burst\\-timeout|tune\\.quic\\.socket\\-owner|tune\\.fd\\.edge\\-triggered|tune\\.vars\\.txn\\-max\\-size|tune\\.epoll\\.mask\\-events|server\\-state\\-file\\-name|tune\\.h2\\.max\\-frame\\-size|insecure\\-setuid\\-wanted|httpclient\\.ssl\\.ca\\-file|tune\\.sched\\.low\\-latency|ssl\\-load\\-extra\\-del\\-ext|accepted_payload_size|ocsp\\-update\\.httpproxy|tune\\.idle\\-pool\\.shared|tune\\.lua\\.forced\\-yield|max\\-session\\-srv\\-conns|max\\-secondary\\-entries|httpclient\\.ssl\\.verify|deviceatlas\\-log\\-level|deviceatlas\\-separator|deviceatlas\\-json\\-file|tune\\.lua\\.task\\-timeout|http\\-send\\-name\\-header|max\\-keep\\-alive\\-queue|insecure\\-fork\\-wanted|tune\\.rcvbuf\\.frontend|tune\\.quic\\.cc\\-hystart|tune\\.lua\\.log\\.loggers|ocsp\\-update\\.maxdelay|tune\\.sndbuf\\.frontend|tune\\.zlib\\.windowsize|ssl\\-load\\-extra\\-files|ocsp\\-update\\.mindelay|tune\\.memory\\.hot\\-size|tune\\.buffers\\.reserve|pp2\\-never\\-send\\-local|tune\\.http\\.logurilen|ocsp\\-update\\.disable|tune\\.rcvbuf\\.backend|tune\\.runqueue\\-depth|h1\\-case\\-adjust\\-file|tune\\.lua\\.log\\.stderr|tune\\.stick\\-counters|lua\\-load\\-per\\-thread|tune\\.sndbuf\\.backend|http\\-after\\-response|hash\\-balance\\-factor|tune\\.http\\.cookielen|mworker\\-max\\-reloads|no\\-memory\\-trimming|tune\\.comp\\.maxlevel|tune\\.sndbuf\\.client|tune\\.sndbuf\\.server|tune\\.buffers\\.limit|tune\\.zlib\\.memlevel|issuers\\-chain\\-path|httpclient\\.retries|ssl\\-security\\-level|tune\\.ssl\\.cachesize|tune\\.ssl\\.maxrecord|dynamic\\-cookie\\-key|tune\\.rcvbuf\\.client|tune\\.rcvbuf\\.server|tune\\.maxpollevents|tune\\.ssl\\.lifetime|thread\\-hard\\-limit|ssl\\-dh\\-param\\-file|ssl\\-provider\\-path|log\\-send\\-hostname|parse\\-resolv\\-conf|server\\-state\\-base|close\\-spread\\-time|max\\-spread\\-checks|ssl\\-server\\-verify|tune\\.ring\\.queues|lua\\-prepend\\-path|unique\\-id\\-format|numa\\-cpu\\-mapping|wurfl\\-patch\\-file|ocsp\\-update\\.mode|tune\\.recv_enough|unique\\-id\\-header|error\\-log\\-format|profiling\\.memory|wurfl\\-cache\\-size|tune\\.http\\.maxhdr|max\\-object\\-size|hard\\-stop\\-after|wurfl\\-data\\-file|maxcompcpuusage|tune\\.fail\\-alloc|tune\\.lua\\.maxmem|resolve_retries|tune\\.maxrewrite|tune\\.ssl\\.keylog|http\\-fail\\-codes|server\\-template|profiling\\.tasks|default_backend|total\\-max\\-size|cluster\\-secret|ssl\\-mode\\-async|ignore\\-persist|tune\\.maxaccept|srvtcpka\\-intvl|default\\-server|clitcpka\\-intvl|tune\\.idletimer|http\\-err\\-codes|tune\\.pipesize|nogetaddrinfo|saml\\-sso\\-load|log\\-format\\-sd|clitcpka\\-idle|ssl\\-propquery|srvtcpka\\-idle|thread\\-groups|http\\-response|fd\\-hard\\-limit|master\\-worker|spread\\-checks|strict\\-limits|force\\-persist|process\\-vary|backing\\-file|clitcpka\\-cnt|busy\\-polling|srvtcpka\\-cnt|thread\\-group|limited\\-quic|default\\-path|zero\\-warning|tcp\\-response|http\\-request|default\\-bind|tune\\.bufsize|set\\-dumpable|use\\-fcgi\\-app|http\\-errors|compression|ocsp\\-update|errorloc302|prealloc\\-fd|maxsessrate|tcp\\-request|noreuseport|use_backend|log\\-forward|errorloc303|monitor\\-uri|pass\\-header|module\\-load|maxcomprate|module\\-path|maxconnrate|description|maxzlibmem|http\\-check|nameserver|http\\-reuse|clitimeout|quick\\-exit|maxsslrate|http\\-error|ssl\\-engine|log\\-stderr|dgram\\-bind|errorfiles|maxsslconn|rate\\-limit|stats\\-file|srvtimeout|use\\-server|contimeout|unix\\-bind|path\\-info|errorfile|presetenv|noevports|set\\-param|localpeer|hash\\-type|ulimit\\-n|errorloc|crt\\-base|retry\\-on|unsetenv|nbthread|dispatch|fullconn|userlist|maxpipes|resetenv|nokqueue|key\\-base|nosplice|noepoll|pidfile|balance|log\\-tag|program|timeout|retries|ca\\-base|command|cpu\\-map|max\\-age|docroot|no\\-quic|mailers|anonkey|declare|mailer|format|setenv|option|setcap|maxlen|filter|nopoll|chroot|issuer|daemon|alias|peers|trace|table|quiet|index|grace|peer|hold|size|sctl|ring|node|mode|bind|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|url_param|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-res|algo\\-req|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
