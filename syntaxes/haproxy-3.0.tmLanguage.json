{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|fcgi\\-app|userlist|crt\\-list|program|mailers|peers|cache|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|frontend|fcgi\\-app|defaults|userlist|crt\\-list|backend|program|mailers|listen|global|peers|cache|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.disable\\-zero\\-copy\\-forwarding|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.peers\\.max\\-updates\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.be\\.initial\\-window\\-size|ssl\\-default\\-bind\\-ciphersuites|deviceatlas\\-properties\\-cookie|httpclient\\.resolvers\\.disabled|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.listener\\.default\\-shards|tune\\.ssl\\.force\\-private\\-cache|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.quic\\.zero\\-copy\\-fwd\\-send|expose\\-deprecated\\-directives|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-options|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-ciphers|httpclient\\.timeout\\.connect|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.quic\\.retry\\-threshold|tune\\.disable\\-fast\\-forward|tune\\.vars\\.global\\-max\\-size|tune\\.listener\\.multi\\-queue|tune\\.h2\\.header\\-table\\-size|tune\\.ssl\\.default\\-dh\\-param|ssl\\-default\\-server\\-curves|tune\\.vars\\.reqres\\-max\\-size|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.service\\-timeout|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-ciphers|tune\\.quic\\.reorder\\-ratio|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.proc\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|tune\\.vars\\.sess\\-max\\-size|tune\\.pattern\\.cache\\-size|tune\\.epoll\\.mask\\-events|tune\\.h2\\.max\\-frame\\-size|httpclient\\.ssl\\.ca\\-file|tune\\.fd\\.edge\\-triggered|server\\-state\\-file\\-name|tune\\.sched\\.low\\-latency|tune\\.lua\\.burst\\-timeout|tune\\.pool\\-low\\-fd\\-ratio|ssl\\-load\\-extra\\-del\\-ext|insecure\\-setuid\\-wanted|tune\\.quic\\.socket\\-owner|tune\\.vars\\.txn\\-max\\-size|tune\\.lua\\.forced\\-yield|deviceatlas\\-log\\-level|deviceatlas\\-separator|deviceatlas\\-json\\-file|tune\\.idle\\-pool\\.shared|accepted_payload_size|httpclient\\.ssl\\.verify|tune\\.lua\\.task\\-timeout|http\\-send\\-name\\-header|max\\-secondary\\-entries|ocsp\\-update\\.httpproxy|max\\-session\\-srv\\-conns|insecure\\-fork\\-wanted|tune\\.buffers\\.reserve|ocsp\\-update\\.maxdelay|tune\\.quic\\.cc\\-hystart|tune\\.lua\\.log\\.loggers|ssl\\-load\\-extra\\-files|tune\\.rcvbuf\\.frontend|tune\\.zlib\\.windowsize|tune\\.memory\\.hot\\-size|ocsp\\-update\\.mindelay|tune\\.sndbuf\\.frontend|max\\-keep\\-alive\\-queue|pp2\\-never\\-send\\-local|ocsp\\-update\\.disable|tune\\.http\\.logurilen|tune\\.stick\\-counters|tune\\.http\\.cookielen|http\\-after\\-response|lua\\-load\\-per\\-thread|hash\\-balance\\-factor|tune\\.lua\\.log\\.stderr|tune\\.rcvbuf\\.backend|tune\\.sndbuf\\.backend|h1\\-case\\-adjust\\-file|tune\\.runqueue\\-depth|mworker\\-max\\-reloads|tune\\.ssl\\.cachesize|tune\\.rcvbuf\\.client|tune\\.ssl\\.maxrecord|tune\\.zlib\\.memlevel|no\\-memory\\-trimming|tune\\.maxpollevents|tune\\.comp\\.maxlevel|tune\\.rcvbuf\\.server|tune\\.buffers\\.limit|dynamic\\-cookie\\-key|tune\\.sndbuf\\.server|ssl\\-security\\-level|tune\\.sndbuf\\.client|httpclient\\.retries|issuers\\-chain\\-path|close\\-spread\\-time|tune\\.ssl\\.lifetime|parse\\-resolv\\-conf|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|ssl\\-provider\\-path|log\\-send\\-hostname|ssl\\-server\\-verify|thread\\-hard\\-limit|server\\-state\\-base|tune\\.ring\\.queues|unique\\-id\\-format|tune\\.http\\.maxhdr|error\\-log\\-format|numa\\-cpu\\-mapping|unique\\-id\\-header|profiling\\.memory|lua\\-prepend\\-path|tune\\.recv_enough|ocsp\\-update\\.mode|tune\\.fail\\-alloc|tune\\.ssl\\.keylog|profiling\\.tasks|tune\\.lua\\.maxmem|server\\-template|maxcompcpuusage|max\\-object\\-size|tune\\.maxrewrite|default_backend|resolve_retries|hard\\-stop\\-after|http\\-fail\\-codes|tune\\.idletimer|ssl\\-mode\\-async|total\\-max\\-size|default\\-server|ignore\\-persist|srvtcpka\\-intvl|clitcpka\\-intvl|cluster\\-secret|tune\\.maxaccept|http\\-err\\-codes|thread\\-groups|saml\\-sso\\-load|master\\-worker|http\\-response|force\\-persist|strict\\-limits|fd\\-hard\\-limit|spread\\-checks|clitcpka\\-idle|srvtcpka\\-idle|log\\-format\\-sd|nogetaddrinfo|ssl\\-propquery|tune\\.pipesize|tcp\\-response|default\\-path|clitcpka\\-cnt|thread\\-group|busy\\-polling|backing\\-file|process\\-vary|set\\-dumpable|use\\-fcgi\\-app|limited\\-quic|zero\\-warning|default\\-bind|tune\\.bufsize|srvtcpka\\-cnt|http\\-request|monitor\\-uri|http\\-errors|maxconnrate|noreuseport|pass\\-header|module\\-path|use_backend|ocsp\\-update|maxcomprate|errorloc302|module\\-load|errorloc303|maxsessrate|description|prealloc\\-fd|log\\-forward|tcp\\-request|compression|http\\-error|clitimeout|http\\-reuse|contimeout|maxsslrate|use\\-server|rate\\-limit|log\\-stderr|stats\\-file|http\\-check|maxzlibmem|ssl\\-engine|srvtimeout|quick\\-exit|errorfiles|nameserver|maxsslconn|dgram\\-bind|unix\\-bind|hash\\-type|set\\-param|localpeer|presetenv|noevports|path\\-info|errorfile|errorloc|key\\-base|ulimit\\-n|retry\\-on|nosplice|unsetenv|nbthread|fullconn|crt\\-base|userlist|maxpipes|dispatch|nokqueue|resetenv|retries|balance|pidfile|timeout|max\\-age|command|log\\-tag|noepoll|docroot|program|no\\-quic|mailers|cpu\\-map|ca\\-base|anonkey|declare|option|filter|nopoll|format|setenv|mailer|chroot|issuer|setcap|maxlen|daemon|index|alias|peers|table|grace|trace|quiet|sctl|bind|mode|size|node|hold|peer|ring|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|leastconn|url_param|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|connect|comment|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-invalid\\-http\\-response|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ http\\-buffer\\-request|option\\ log\\-separate\\-errors|option\\ independent\\-streams|option\\ disable\\-h2\\-upgrade|option\\ prefer\\-last\\-server|option\\ http\\-ignore\\-probes|option\\ tcp\\-smart\\-connect|option\\ log\\-health\\-checks|option\\ http\\-server\\-close|option\\ tcp\\-smart\\-accept|option\\ splice\\-response|option\\ start\\-on\\-reload|option\\ http\\-keep\\-alive|option\\ dontlog\\-normal|option\\ splice\\-request|option\\ http\\-no\\-delay|option\\ socket\\-stats|option\\ abortonclose|option\\ dontlognull|option\\ splice\\-auto|option\\ transparent|option\\ get\\-values|option\\ allbackups|option\\ checkcache|option\\ redispatch|option\\ mpxs\\-conns|option\\ forwarded|option\\ httpclose|option\\ keep\\-conn|option\\ nolinger|option\\ srvtcpka|option\\ clitcpka|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(persist)\\s+((?:rdp\\-cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(rate\\-limit)\\s+((?:sessions))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+((?:location|prefix|scheme))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stats)\\s+((?:show\\-legends|show\\-modules|hide\\-version|http\\-request|show\\-desc|show\\-node|refresh|maxconn|timeout|enable|socket|admin|scope|realm|auth|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stick)\\s+((?:store\\-response|store\\-request|match|on))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
