{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:resolvers|userlist|fcgi\\-app|crt\\-list|peers|cache))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:resolvers|userlist|defaults|frontend|fcgi\\-app|crt\\-list|backend|listen|global|peers|cache))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|httpclient\\.resolvers\\.disabled|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.ssl\\.force\\-private\\-cache|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.listener\\.default\\-shards|expose\\-deprecated\\-directives|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|load\\-server\\-state\\-from\\-file|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|tune\\.h1\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-options|tune\\.vars\\.global\\-max\\-size|ssl\\-default\\-server\\-curves|tune\\.listener\\.multi\\-queue|tune\\.quic\\.retry\\-threshold|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.reqres\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.disable\\-fast\\-forward|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-options|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-ciphers|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.session\\-timeout|tune\\.lua\\.service\\-timeout|tune\\.vars\\.proc\\-max\\-size|tune\\.ssl\\.hard\\-maxrecord|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pattern\\.cache\\-size|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|server\\-state\\-file\\-name|tune\\.pool\\-low\\-fd\\-ratio|tune\\.quic\\.socket\\-owner|tune\\.fd\\.edge\\-triggered|tune\\.epoll\\.mask\\-events|insecure\\-setuid\\-wanted|tune\\.sched\\.low\\-latency|tune\\.lua\\.burst\\-timeout|httpclient\\.ssl\\.ca\\-file|tune\\.vars\\.txn\\-max\\-size|ssl\\-load\\-extra\\-del\\-ext|tune\\.h2\\.max\\-frame\\-size|tune\\.idle\\-pool\\.shared|ocsp\\-update\\.httpproxy|max\\-session\\-srv\\-conns|deviceatlas\\-json\\-file|max\\-secondary\\-entries|tune\\.lua\\.task\\-timeout|tune\\.lua\\.forced\\-yield|accepted_payload_size|deviceatlas\\-log\\-level|httpclient\\.ssl\\.verify|http\\-send\\-name\\-header|deviceatlas\\-separator|ocsp\\-update\\.mindelay|tune\\.memory\\.hot\\-size|tune\\.rcvbuf\\.frontend|tune\\.zlib\\.windowsize|insecure\\-fork\\-wanted|tune\\.lua\\.log\\.loggers|tune\\.sndbuf\\.frontend|ocsp\\-update\\.maxdelay|tune\\.quic\\.cc\\-hystart|max\\-keep\\-alive\\-queue|tune\\.buffers\\.reserve|pp2\\-never\\-send\\-local|ssl\\-load\\-extra\\-files|http\\-after\\-response|mworker\\-max\\-reloads|tune\\.runqueue\\-depth|tune\\.sndbuf\\.backend|hash\\-balance\\-factor|ocsp\\-update\\.disable|h1\\-case\\-adjust\\-file|tune\\.stick\\-counters|tune\\.http\\.cookielen|tune\\.rcvbuf\\.backend|tune\\.http\\.logurilen|tune\\.lua\\.log\\.stderr|lua\\-load\\-per\\-thread|dynamic\\-cookie\\-key|tune\\.maxpollevents|tune\\.sndbuf\\.server|tune\\.buffers\\.limit|tune\\.ssl\\.maxrecord|tune\\.ssl\\.cachesize|issuers\\-chain\\-path|tune\\.sndbuf\\.client|httpclient\\.retries|no\\-memory\\-trimming|ssl\\-security\\-level|tune\\.rcvbuf\\.server|tune\\.comp\\.maxlevel|tune\\.zlib\\.memlevel|tune\\.rcvbuf\\.client|server\\-state\\-base|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|ssl\\-server\\-verify|close\\-spread\\-time|ssl\\-provider\\-path|parse\\-resolv\\-conf|tune\\.ssl\\.lifetime|log\\-send\\-hostname|thread\\-hard\\-limit|lua\\-prepend\\-path|wurfl\\-cache\\-size|tune\\.recv_enough|profiling\\.memory|unique\\-id\\-header|tune\\.ring\\.queues|error\\-log\\-format|unique\\-id\\-format|numa\\-cpu\\-mapping|tune\\.http\\.maxhdr|ocsp\\-update\\.mode|wurfl\\-patch\\-file|server\\-template|wurfl\\-data\\-file|default_backend|resolve_retries|profiling\\.tasks|tune\\.ssl\\.keylog|tune\\.lua\\.maxmem|maxcompcpuusage|hard\\-stop\\-after|http\\-fail\\-codes|max\\-object\\-size|tune\\.fail\\-alloc|tune\\.maxrewrite|total\\-max\\-size|tune\\.maxaccept|clitcpka\\-intvl|ignore\\-persist|tune\\.idletimer|srvtcpka\\-intvl|http\\-err\\-codes|default\\-server|cluster\\-secret|ssl\\-mode\\-async|spread\\-checks|srvtcpka\\-idle|tune\\.pipesize|fd\\-hard\\-limit|ssl\\-propquery|nogetaddrinfo|saml\\-sso\\-load|master\\-worker|thread\\-groups|force\\-persist|strict\\-limits|log\\-format\\-sd|clitcpka\\-idle|http\\-response|process\\-vary|clitcpka\\-cnt|http\\-request|zero\\-warning|busy\\-polling|set\\-dumpable|tcp\\-response|default\\-bind|srvtcpka\\-cnt|tune\\.bufsize|limited\\-quic|backing\\-file|use\\-fcgi\\-app|default\\-path|thread\\-group|use_backend|errorloc302|tcp\\-request|noreuseport|maxcomprate|errorloc303|description|prealloc\\-fd|maxconnrate|pass\\-header|maxsessrate|ocsp\\-update|module\\-load|module\\-path|http\\-errors|monitor\\-uri|compression|log\\-forward|clitimeout|log\\-stderr|maxsslrate|http\\-error|stats\\-file|rate\\-limit|contimeout|maxsslconn|nameserver|errorfiles|ssl\\-engine|maxzlibmem|srvtimeout|quick\\-exit|http\\-check|use\\-server|http\\-reuse|dgram\\-bind|unix\\-bind|noevports|path\\-info|presetenv|localpeer|errorfile|hash\\-type|set\\-param|fullconn|dispatch|resetenv|unsetenv|userlist|maxpipes|crt\\-base|nosplice|retry\\-on|errorloc|nokqueue|ulimit\\-n|key\\-base|nbthread|program|command|log\\-tag|pidfile|balance|anonkey|timeout|retries|max\\-age|declare|docroot|ca\\-base|cpu\\-map|noepoll|no\\-quic|mailers|maxlen|setcap|option|setenv|chroot|mailer|daemon|filter|issuer|nopoll|format|trace|grace|alias|table|peers|index|quiet|mode|hold|peer|ring|sctl|size|node|bind|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|url_param|static\\-rr|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
