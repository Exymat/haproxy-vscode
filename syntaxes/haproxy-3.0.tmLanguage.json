{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*((?:defaults|frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.label.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.label.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:resolvers|crt\\-list|userlist|fcgi\\-app|peers|cache))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.label.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:resolvers|crt\\-list|defaults|userlist|fcgi\\-app|frontend|backend|listen|global|peers|cache))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|rfc7239_is_valid|max\\-object\\-size|x509_v_err_str|total\\-max\\-size|mqtt_is_valid|process\\-vary|fix_is_valid|rfc7239_n2nn|rfc7239_n2np|host_only|port_only|srv_queue|cut_crlf|max\\-age|ub64dec|ub64enc|b64dec|base64|length|hex2i|htonl|lower|upper|nbsrv|bool|sha1|even|neg|hex|cpl|odd|not)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.tcp|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.ssl\\.capture\\-cipherlist\\-size|wurfl\\-information\\-list\\-separator|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.certificate\\-compression|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.peers\\.max\\-updates\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.fe\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|httpclient\\.resolvers\\.disabled|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.listener\\.default\\-shards|tune\\.ssl\\.force\\-private\\-cache|tune\\.pt\\.zero\\-copy\\-forwarding|expose\\-deprecated\\-directives|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-ciphers|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-sigalgs|httpclient\\.timeout\\.connect|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-options|warn\\-blocked\\-traffic\\-after|tune\\.listener\\.multi\\-queue|tune\\.vars\\.reqres\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.h2\\.header\\-table\\-size|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.global\\-max\\-size|tune\\.disable\\-fast\\-forward|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-sigalgs|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|ssl\\-skip\\-self\\-issued\\-ca|httpclient\\.resolvers\\.id|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.proc\\-max\\-size|ssl\\-default\\-bind\\-curves|tune\\.pool\\-high\\-fd\\-ratio|tune\\.pattern\\.cache\\-size|tune\\.ssl\\.hard\\-maxrecord|tune\\.epoll\\.mask\\-events|tune\\.h2\\.max\\-frame\\-size|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|tune\\.pool\\-low\\-fd\\-ratio|server\\-state\\-file\\-name|httpclient\\.ssl\\.ca\\-file|ssl\\-load\\-extra\\-del\\-ext|tune\\.vars\\.txn\\-max\\-size|tune\\.lua\\.burst\\-timeout|tune\\.sched\\.low\\-latency|tune\\.fd\\.edge\\-triggered|tune\\.idle\\-pool\\.shared|tune\\.lua\\.forced\\-yield|max\\-session\\-srv\\-conns|max\\-secondary\\-entries|http\\-send\\-name\\-header|tune\\.lua\\.task\\-timeout|accepted_payload_size|deviceatlas\\-separator|httpclient\\.ssl\\.verify|deviceatlas\\-json\\-file|ocsp\\-update\\.httpproxy|deviceatlas\\-log\\-level|pp2\\-never\\-send\\-local|tune\\.zlib\\.windowsize|tune\\.sndbuf\\.frontend|tune\\.memory\\.hot\\-size|ssl\\-load\\-extra\\-files|tune\\.buffers\\.reserve|tune\\.quic\\.cc\\-hystart|max\\-keep\\-alive\\-queue|ocsp\\-update\\.maxdelay|ocsp\\-update\\.mindelay|tune\\.rcvbuf\\.frontend|insecure\\-fork\\-wanted|tune\\.lua\\.log\\.loggers|lua\\-load\\-per\\-thread|tune\\.http\\.cookielen|tune\\.lua\\.log\\.stderr|tune\\.sndbuf\\.backend|tune\\.stick\\-counters|tune\\.rcvbuf\\.backend|hash\\-balance\\-factor|tune\\.http\\.logurilen|tune\\.runqueue\\-depth|http\\-after\\-response|mworker\\-max\\-reloads|h1\\-case\\-adjust\\-file|ocsp\\-update\\.disable|issuers\\-chain\\-path|tune\\.comp\\.maxlevel|tune\\.maxpollevents|tune\\.sndbuf\\.client|dynamic\\-cookie\\-key|ssl\\-security\\-level|tune\\.ssl\\.maxrecord|tune\\.ssl\\.cachesize|httpclient\\.retries|tune\\.buffers\\.limit|tune\\.zlib\\.memlevel|no\\-memory\\-trimming|tune\\.rcvbuf\\.client|ssl\\-provider\\-path|log\\-send\\-hostname|tune\\.ssl\\.lifetime|server\\-state\\-base|close\\-spread\\-time|thread\\-hard\\-limit|ssl\\-dh\\-param\\-file|max\\-spread\\-checks|ssl\\-server\\-verify|parse\\-resolv\\-conf|unique\\-id\\-format|tune\\.http\\.maxhdr|unique\\-id\\-header|lua\\-prepend\\-path|error\\-log\\-format|wurfl\\-cache\\-size|wurfl\\-patch\\-file|rfc7239_is_valid|ocsp\\-update\\.mode|tune\\.recv_enough|tune\\.ring\\.queues|numa\\-cpu\\-mapping|profiling\\.memory|tune\\.maxrewrite|maxcompcpuusage|tune\\.ssl\\.keylog|wurfl\\-data\\-file|resolve_retries|profiling\\.tasks|tune\\.fail\\-alloc|max\\-object\\-size|server\\-template|hard\\-stop\\-after|default_backend|tune\\.lua\\.maxmem|http\\-fail\\-codes|default\\-server|ignore\\-persist|total\\-max\\-size|x509_v_err_str|srvtcpka\\-intvl|http\\-err\\-codes|cluster\\-secret|clitcpka\\-intvl|tune\\.idletimer|ssl\\-mode\\-async|tune\\.maxaccept|nogetaddrinfo|ssl\\-propquery|master\\-worker|spread\\-checks|clitcpka\\-idle|srvtcpka\\-idle|saml\\-sso\\-load|http\\-response|thread\\-groups|log\\-format\\-sd|tune\\.pipesize|mqtt_is_valid|strict\\-limits|fd\\-hard\\-limit|force\\-persist|http\\-request|rfc7239_n2nn|use\\-fcgi\\-app|limited\\-quic|zero\\-warning|tcp\\-response|default\\-bind|rfc7239_n2np|default\\-path|fix_is_valid|tune\\.bufsize|set\\-dumpable|clitcpka\\-cnt|busy\\-polling|process\\-vary|thread\\-group|backing\\-file|srvtcpka\\-cnt|compression|ocsp\\-update|errorloc303|stick\\-table|maxcomprate|description|http\\-errors|module\\-path|use_backend|maxconnrate|errorloc302|maxsessrate|prealloc\\-fd|module\\-load|pass\\-header|noreuseport|log\\-forward|tcp\\-request|monitor\\-uri|errorfiles|ssl\\-engine|rate\\-limit|http\\-error|http\\-reuse|clitimeout|stats\\-file|dgram\\-bind|use\\-server|maxsslconn|http\\-check|maxzlibmem|maxsslrate|contimeout|nameserver|srvtimeout|quick\\-exit|localpeer|noevports|path\\-info|unix\\-bind|host_only|srv_queue|errorfile|set\\-param|hash\\-type|presetenv|port_only|userlist|crt\\-base|retry\\-on|nokqueue|dispatch|errorloc|key\\-base|fullconn|ulimit\\-n|nbthread|nosplice|resetenv|maxpipes|cut_crlf|unsetenv|max\\-age|log\\-tag|ca\\-base|program|ub64enc|docroot|balance|cpu\\-map|mailers|timeout|noepoll|anonkey|no\\-quic|declare|pidfile|retries|command|ub64dec|option|filter|maxlen|nopoll|format|base64|daemon|issuer|setenv|setcap|b64dec|mailer|chroot|length|alias|table|nbsrv|upper|index|grace|peers|trace|htonl|hex2i|quiet|lower|ring|mode|bind|bool|even|size|hold|node|sha1|peer|sctl|acl|cpl|hex|odd|neg|not)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.label.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.label.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.label.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|url_param|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|offload|algo))\\b",
