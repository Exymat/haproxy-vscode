          "match": "\\b(timeout)\\s+((?:http\\-keep\\-alive|http\\-request|client\\-fin|server\\-fin|client\\-hs|connect|tunnel|tarpit|server|client|queue|check|mail))\\b",
          "captures": {
            "1": {
