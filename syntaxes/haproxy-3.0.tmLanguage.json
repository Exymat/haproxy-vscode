{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|defaults|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:resolvers|fcgi\\-app|userlist|crt\\-list|cache|peers))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:resolvers|fcgi\\-app|userlist|defaults|frontend|crt\\-list|backend|listen|global|cache|peers))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.disable\\-zero\\-copy\\-forwarding|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|httpclient\\.resolvers\\.disabled|deviceatlas\\-properties\\-cookie|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.glitches\\-threshold|expose\\-deprecated\\-directives|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.listener\\.default\\-shards|tune\\.ssl\\.force\\-private\\-cache|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-options|tune\\.h1\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|warn\\-blocked\\-traffic\\-after|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.disable\\-fast\\-forward|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.reqres\\-max\\-size|tune\\.listener\\.multi\\-queue|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.service\\-timeout|tune\\.vars\\.proc\\-max\\-size|httpclient\\.resolvers\\.id|tune\\.pattern\\.cache\\-size|tune\\.pool\\-high\\-fd\\-ratio|ssl\\-default\\-bind\\-curves|tune\\.ssl\\.hard\\-maxrecord|ssl\\-skip\\-self\\-issued\\-ca|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|insecure\\-setuid\\-wanted|server\\-state\\-file\\-name|tune\\.pool\\-low\\-fd\\-ratio|httpclient\\.ssl\\.ca\\-file|tune\\.fd\\.edge\\-triggered|tune\\.sched\\.low\\-latency|tune\\.h2\\.max\\-frame\\-size|tune\\.epoll\\.mask\\-events|ssl\\-load\\-extra\\-del\\-ext|tune\\.lua\\.burst\\-timeout|tune\\.vars\\.txn\\-max\\-size|tune\\.quic\\.socket\\-owner|max\\-secondary\\-entries|deviceatlas\\-separator|tune\\.lua\\.forced\\-yield|deviceatlas\\-log\\-level|httpclient\\.ssl\\.verify|deviceatlas\\-json\\-file|ocsp\\-update\\.httpproxy|http\\-send\\-name\\-header|tune\\.idle\\-pool\\.shared|accepted_payload_size|max\\-session\\-srv\\-conns|tune\\.lua\\.task\\-timeout|ssl\\-load\\-extra\\-files|ocsp\\-update\\.mindelay|pp2\\-never\\-send\\-local|tune\\.lua\\.log\\.loggers|tune\\.quic\\.cc\\-hystart|insecure\\-fork\\-wanted|max\\-keep\\-alive\\-queue|tune\\.sndbuf\\.frontend|tune\\.buffers\\.reserve|ocsp\\-update\\.maxdelay|tune\\.memory\\.hot\\-size|tune\\.rcvbuf\\.frontend|tune\\.zlib\\.windowsize|mworker\\-max\\-reloads|h1\\-case\\-adjust\\-file|lua\\-load\\-per\\-thread|tune\\.lua\\.log\\.stderr|tune\\.runqueue\\-depth|tune\\.http\\.cookielen|tune\\.http\\.logurilen|ocsp\\-update\\.disable|tune\\.stick\\-counters|hash\\-balance\\-factor|tune\\.sndbuf\\.backend|tune\\.rcvbuf\\.backend|http\\-after\\-response|no\\-memory\\-trimming|ssl\\-security\\-level|tune\\.ssl\\.cachesize|issuers\\-chain\\-path|dynamic\\-cookie\\-key|tune\\.buffers\\.limit|tune\\.rcvbuf\\.server|tune\\.maxpollevents|tune\\.rcvbuf\\.client|tune\\.comp\\.maxlevel|tune\\.zlib\\.memlevel|tune\\.sndbuf\\.server|tune\\.sndbuf\\.client|tune\\.ssl\\.maxrecord|httpclient\\.retries|parse\\-resolv\\-conf|log\\-send\\-hostname|server\\-state\\-base|ssl\\-provider\\-path|close\\-spread\\-time|ssl\\-dh\\-param\\-file|tune\\.ssl\\.lifetime|max\\-spread\\-checks|ssl\\-server\\-verify|thread\\-hard\\-limit|numa\\-cpu\\-mapping|wurfl\\-patch\\-file|tune\\.recv_enough|unique\\-id\\-header|wurfl\\-cache\\-size|tune\\.http\\.maxhdr|unique\\-id\\-format|lua\\-prepend\\-path|ocsp\\-update\\.mode|error\\-log\\-format|profiling\\.memory|tune\\.ring\\.queues|default_backend|tune\\.ssl\\.keylog|wurfl\\-data\\-file|maxcompcpuusage|tune\\.maxrewrite|hard\\-stop\\-after|tune\\.lua\\.maxmem|tune\\.fail\\-alloc|resolve_retries|server\\-template|http\\-fail\\-codes|profiling\\.tasks|max\\-object\\-size|default\\-server|ssl\\-mode\\-async|clitcpka\\-intvl|total\\-max\\-size|cluster\\-secret|tune\\.maxaccept|srvtcpka\\-intvl|http\\-err\\-codes|ignore\\-persist|tune\\.idletimer|tune\\.pipesize|fd\\-hard\\-limit|spread\\-checks|nogetaddrinfo|master\\-worker|http\\-response|saml\\-sso\\-load|log\\-format\\-sd|clitcpka\\-idle|thread\\-groups|force\\-persist|srvtcpka\\-idle|ssl\\-propquery|strict\\-limits|zero\\-warning|busy\\-polling|limited\\-quic|tcp\\-response|thread\\-group|http\\-request|srvtcpka\\-cnt|use\\-fcgi\\-app|clitcpka\\-cnt|set\\-dumpable|default\\-bind|tune\\.bufsize|process\\-vary|backing\\-file|default\\-path|noreuseport|use_backend|description|monitor\\-uri|errorloc303|log\\-forward|module\\-path|ocsp\\-update|prealloc\\-fd|maxconnrate|errorloc302|maxcomprate|http\\-errors|tcp\\-request|maxsessrate|pass\\-header|compression|module\\-load|stats\\-file|ssl\\-engine|contimeout|dgram\\-bind|http\\-reuse|quick\\-exit|nameserver|use\\-server|http\\-error|maxsslrate|rate\\-limit|maxzlibmem|clitimeout|maxsslconn|srvtimeout|log\\-stderr|errorfiles|http\\-check|localpeer|unix\\-bind|set\\-param|hash\\-type|errorfile|presetenv|path\\-info|noevports|key\\-base|nbthread|fullconn|crt\\-base|maxpipes|retry\\-on|ulimit\\-n|resetenv|nosplice|unsetenv|userlist|errorloc|dispatch|nokqueue|pidfile|retries|command|ca\\-base|program|noepoll|cpu\\-map|declare|anonkey|timeout|mailers|log\\-tag|max\\-age|no\\-quic|balance|docroot|daemon|setenv|setcap|filter|option|nopoll|maxlen|chroot|issuer|format|mailer|grace|quiet|index|trace|alias|peers|table|node|peer|hold|ring|mode|bind|size|sctl|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|static\\-rr|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
