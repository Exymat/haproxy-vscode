{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|fcgi\\-app|userlist|mailers|program|cache|peers|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|defaults|crt\\-list|fcgi\\-app|frontend|userlist|backend|mailers|program|listen|global|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.quic\\.backend\\.max\\-idle\\-timeou|ssl\\-default\\-server\\-client\\-sigalgs|h1\\-accept\\-payload\\-with\\-any\\-method|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|httpclient\\.resolvers\\.disabled|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.ssl\\.force\\-private\\-cache|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.default\\-shards|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.h2\\.fe\\.max\\-total\\-streams|expose\\-deprecated\\-directives|httpclient\\.resolvers\\.prefer|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.max\\-checks\\-per\\-thread|warn\\-blocked\\-traffic\\-after|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-options|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|httpclient\\.timeout\\.connect|tune\\.listener\\.multi\\-queue|ssl\\-default\\-server\\-curves|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.disable\\-fast\\-forward|tune\\.vars\\.reqres\\-max\\-size|tune\\.quic\\.retry\\-threshold|ssl\\-default\\-bind\\-options|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|httpclient\\.resolvers\\.id|tune\\.pattern\\.cache\\-size|tune\\.ssl\\.hard\\-maxrecord|ssl\\-default\\-bind\\-curves|tune\\.vars\\.sess\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.vars\\.proc\\-max\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|tune\\.vars\\.txn\\-max\\-size|tune\\.h2\\.max\\-frame\\-size|tune\\.lua\\.burst\\-timeout|tune\\.pool\\-low\\-fd\\-ratio|ssl\\-load\\-extra\\-del\\-ext|tune\\.fd\\.edge\\-triggered|tune\\.epoll\\.mask\\-events|insecure\\-setuid\\-wanted|httpclient\\.ssl\\.ca\\-file|server\\-state\\-file\\-name|tune\\.quic\\.socket\\-owner|tune\\.sched\\.low\\-latency|deviceatlas\\-json\\-file|tune\\.lua\\.task\\-timeout|tune\\.lua\\.forced\\-yield|http\\-send\\-name\\-header|deviceatlas\\-separator|accepted_payload_size|max\\-session\\-srv\\-conns|deviceatlas\\-log\\-level|httpclient\\.ssl\\.verify|max\\-secondary\\-entries|tune\\.idle\\-pool\\.shared|ocsp\\-update\\.httpproxy|tune\\.sndbuf\\.frontend|tune\\.rcvbuf\\.frontend|tune\\.memory\\.hot\\-size|ocsp\\-update\\.maxdelay|max\\-keep\\-alive\\-queue|tune\\.zlib\\.windowsize|tune\\.lua\\.log\\.loggers|ocsp\\-update\\.mindelay|tune\\.quic\\.cc\\-hystart|pp2\\-never\\-send\\-local|ssl\\-load\\-extra\\-files|tune\\.buffers\\.reserve|insecure\\-fork\\-wanted|tune\\.sndbuf\\.backend|mworker\\-max\\-reloads|hash\\-balance\\-factor|tune\\.http\\.logurilen|tune\\.lua\\.log\\.stderr|tune\\.stick\\-counters|h1\\-case\\-adjust\\-file|http\\-after\\-response|tune\\.runqueue\\-depth|tune\\.http\\.cookielen|ocsp\\-update\\.disable|lua\\-load\\-per\\-thread|tune\\.rcvbuf\\.backend|tune\\.sndbuf\\.client|tune\\.rcvbuf\\.client|tune\\.ssl\\.maxrecord|tune\\.sndbuf\\.server|tune\\.buffers\\.limit|tune\\.rcvbuf\\.server|no\\-memory\\-trimming|tune\\.comp\\.maxlevel|dynamic\\-cookie\\-key|tune\\.zlib\\.memlevel|httpclient\\.retries|tune\\.ssl\\.cachesize|issuers\\-chain\\-path|tune\\.maxpollevents|ssl\\-security\\-level|ssl\\-server\\-verify|thread\\-hard\\-limit|ssl\\-provider\\-path|server\\-state\\-base|parse\\-resolv\\-conf|max\\-spread\\-checks|close\\-spread\\-time|ssl\\-dh\\-param\\-file|log\\-send\\-hostname|tune\\.ssl\\.lifetime|profiling\\.memory|tune\\.recv_enough|unique\\-id\\-header|unique\\-id\\-format|wurfl\\-patch\\-file|numa\\-cpu\\-mapping|tune\\.http\\.maxhdr|tune\\.ring\\.queues|ocsp\\-update\\.mode|lua\\-prepend\\-path|error\\-log\\-format|wurfl\\-cache\\-size|profiling\\.tasks|tune\\.lua\\.maxmem|max\\-object\\-size|tune\\.ssl\\.keylog|default_backend|hard\\-stop\\-after|resolve_retries|maxcompcpuusage|tune\\.maxrewrite|wurfl\\-data\\-file|server\\-template|http\\-fail\\-codes|tune\\.fail\\-alloc|clitcpka\\-intvl|ignore\\-persist|http\\-err\\-codes|total\\-max\\-size|cluster\\-secret|tune\\.maxaccept|srvtcpka\\-intvl|default\\-server|tune\\.idletimer|ssl\\-mode\\-async|saml\\-sso\\-load|clitcpka\\-idle|force\\-persist|strict\\-limits|ssl\\-propquery|thread\\-groups|http\\-response|log\\-format\\-sd|tune\\.pipesize|srvtcpka\\-idle|fd\\-hard\\-limit|spread\\-checks|master\\-worker|nogetaddrinfo|http\\-request|limited\\-quic|use\\-fcgi\\-app|backing\\-file|tcp\\-response|default\\-path|busy\\-polling|default\\-bind|zero\\-warning|thread\\-group|tune\\.bufsize|srvtcpka\\-cnt|clitcpka\\-cnt|process\\-vary|set\\-dumpable|log\\-forward|ocsp\\-update|http\\-errors|monitor\\-uri|prealloc\\-fd|maxconnrate|errorloc302|maxsessrate|errorloc303|module\\-load|maxcomprate|module\\-path|compression|pass\\-header|tcp\\-request|noreuseport|use_backend|description|ssl\\-engine|maxsslconn|stats\\-file|log\\-stderr|errorfiles|dgram\\-bind|quick\\-exit|contimeout|srvtimeout|http\\-check|rate\\-limit|nameserver|maxzlibmem|maxsslrate|http\\-reuse|use\\-server|clitimeout|http\\-error|presetenv|unix\\-bind|set\\-param|path\\-info|localpeer|hash\\-type|errorfile|noevports|resetenv|key\\-base|errorloc|nokqueue|nosplice|crt\\-base|dispatch|retry\\-on|ulimit\\-n|userlist|maxpipes|fullconn|nbthread|unsetenv|docroot|no\\-quic|max\\-age|pidfile|declare|log\\-tag|mailers|timeout|balance|command|retries|anonkey|program|ca\\-base|noepoll|cpu\\-map|daemon|maxlen|filter|format|mailer|setcap|chroot|setenv|issuer|option|nopoll|table|alias|grace|trace|peers|index|quiet|mode|peer|sctl|node|hold|size|bind|ring|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
