            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|comment|connect|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-invalid\\-http\\-response|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-pretend\\-keepalive|option\\ idle\\-close\\-on\\-response|option\\ http\\-use\\-proxy\\-header|option\\ log\\-separate\\-errors|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ disable\\-h2\\-upgrade|option\\ http\\-ignore\\-probes|option\\ prefer\\-last\\-server|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-connect|option\\ tcp\\-smart\\-accept|option\\ http\\-keep\\-alive|option\\ start\\-on\\-reload|option\\ splice\\-response|option\\ splice\\-request|option\\ dontlog\\-normal|option\\ http\\-no\\-delay|option\\ socket\\-stats|option\\ abortonclose|option\\ splice\\-auto|option\\ dontlognull|option\\ transparent|option\\ checkcache|option\\ redispatch|option\\ mpxs\\-conns|option\\ get\\-values|option\\ allbackups|option\\ httpclose|option\\ forwarded|option\\ keep\\-conn|option\\ srvtcpka|option\\ nolinger|option\\ clitcpka|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(persist)\\s+((?:rdp\\-cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(rate\\-limit)\\s+((?:sessions))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+((?:location|prefix|scheme))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stats)\\s+((?:show\\-legends|hide\\-version|http\\-request|show\\-modules|show\\-node|show\\-desc|timeout|maxconn|refresh|socket|enable|scope|admin|realm|auth|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(stick)\\s+((?:store\\-response|store\\-request|match|on))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
