{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.0",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-list|userlist|fcgi\\-app|mailers|program|peers|cache|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|frontend|crt\\-list|userlist|defaults|fcgi\\-app|mailers|program|backend|global|listen|cache|peers|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.quic\\.backend\\.max\\-idle\\-timeou|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.ssl\\.certificate\\-compression|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|deviceatlas\\-properties\\-cookie|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.fe\\.glitches\\-threshold|httpclient\\.resolvers\\.disabled|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.listener\\.default\\-shards|tune\\.ssl\\.force\\-private\\-cache|tune\\.pt\\.zero\\-copy\\-forwarding|expose\\-deprecated\\-directives|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|httpclient\\.resolvers\\.prefer|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-options|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-ciphers|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-sigalgs|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.quic\\.retry\\-threshold|tune\\.h2\\.header\\-table\\-size|tune\\.disable\\-fast\\-forward|tune\\.listener\\.multi\\-queue|tune\\.vars\\.reqres\\-max\\-size|ssl\\-default\\-server\\-curves|tune\\.lua\\.session\\-timeout|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-options|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-ciphers|tune\\.vars\\.sess\\-max\\-size|tune\\.vars\\.proc\\-max\\-size|tune\\.ssl\\.hard\\-maxrecord|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|tune\\.pattern\\.cache\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|tune\\.fd\\.edge\\-triggered|tune\\.sched\\.low\\-latency|tune\\.pool\\-low\\-fd\\-ratio|tune\\.quic\\.socket\\-owner|tune\\.lua\\.burst\\-timeout|ssl\\-load\\-extra\\-del\\-ext|tune\\.vars\\.txn\\-max\\-size|httpclient\\.ssl\\.ca\\-file|tune\\.epoll\\.mask\\-events|insecure\\-setuid\\-wanted|server\\-state\\-file\\-name|tune\\.h2\\.max\\-frame\\-size|deviceatlas\\-separator|tune\\.lua\\.task\\-timeout|http\\-send\\-name\\-header|ocsp\\-update\\.httpproxy|deviceatlas\\-json\\-file|accepted_payload_size|tune\\.idle\\-pool\\.shared|max\\-secondary\\-entries|httpclient\\.ssl\\.verify|max\\-session\\-srv\\-conns|tune\\.lua\\.forced\\-yield|deviceatlas\\-log\\-level|tune\\.zlib\\.windowsize|max\\-keep\\-alive\\-queue|ocsp\\-update\\.maxdelay|pp2\\-never\\-send\\-local|tune\\.quic\\.cc\\-hystart|ocsp\\-update\\.mindelay|tune\\.buffers\\.reserve|ssl\\-load\\-extra\\-files|insecure\\-fork\\-wanted|tune\\.sndbuf\\.frontend|tune\\.lua\\.log\\.loggers|tune\\.memory\\.hot\\-size|tune\\.rcvbuf\\.frontend|tune\\.lua\\.log\\.stderr|tune\\.rcvbuf\\.backend|http\\-after\\-response|tune\\.runqueue\\-depth|ocsp\\-update\\.disable|tune\\.http\\.cookielen|hash\\-balance\\-factor|tune\\.sndbuf\\.backend|lua\\-load\\-per\\-thread|h1\\-case\\-adjust\\-file|tune\\.http\\.logurilen|mworker\\-max\\-reloads|tune\\.stick\\-counters|tune\\.ssl\\.cachesize|tune\\.comp\\.maxlevel|tune\\.buffers\\.limit|ssl\\-security\\-level|tune\\.rcvbuf\\.client|tune\\.sndbuf\\.client|tune\\.sndbuf\\.server|issuers\\-chain\\-path|tune\\.zlib\\.memlevel|no\\-memory\\-trimming|httpclient\\.retries|tune\\.rcvbuf\\.server|tune\\.ssl\\.maxrecord|dynamic\\-cookie\\-key|tune\\.maxpollevents|max\\-spread\\-checks|log\\-send\\-hostname|ssl\\-provider\\-path|thread\\-hard\\-limit|ssl\\-dh\\-param\\-file|parse\\-resolv\\-conf|tune\\.ssl\\.lifetime|server\\-state\\-base|close\\-spread\\-time|ssl\\-server\\-verify|numa\\-cpu\\-mapping|profiling\\.memory|ocsp\\-update\\.mode|unique\\-id\\-format|tune\\.recv_enough|unique\\-id\\-header|wurfl\\-patch\\-file|lua\\-prepend\\-path|tune\\.ring\\.queues|wurfl\\-cache\\-size|tune\\.http\\.maxhdr|error\\-log\\-format|wurfl\\-data\\-file|max\\-object\\-size|tune\\.lua\\.maxmem|server\\-template|tune\\.maxrewrite|tune\\.ssl\\.keylog|profiling\\.tasks|maxcompcpuusage|default_backend|http\\-fail\\-codes|hard\\-stop\\-after|tune\\.fail\\-alloc|resolve_retries|srvtcpka\\-intvl|clitcpka\\-intvl|tune\\.maxaccept|cluster\\-secret|total\\-max\\-size|http\\-err\\-codes|default\\-server|ignore\\-persist|tune\\.idletimer|ssl\\-mode\\-async|saml\\-sso\\-load|log\\-format\\-sd|srvtcpka\\-idle|tune\\.pipesize|nogetaddrinfo|spread\\-checks|http\\-response|force\\-persist|ssl\\-propquery|strict\\-limits|fd\\-hard\\-limit|clitcpka\\-idle|master\\-worker|thread\\-groups|clitcpka\\-cnt|use\\-fcgi\\-app|thread\\-group|backing\\-file|set\\-dumpable|tcp\\-response|limited\\-quic|zero\\-warning|busy\\-polling|default\\-bind|process\\-vary|default\\-path|srvtcpka\\-cnt|http\\-request|tune\\.bufsize|monitor\\-uri|maxsessrate|errorloc302|noreuseport|maxconnrate|maxcomprate|errorloc303|module\\-path|use_backend|compression|http\\-errors|ocsp\\-update|description|log\\-forward|tcp\\-request|pass\\-header|module\\-load|prealloc\\-fd|http\\-check|maxzlibmem|contimeout|ssl\\-engine|errorfiles|srvtimeout|rate\\-limit|maxsslrate|quick\\-exit|maxsslconn|stats\\-file|http\\-error|clitimeout|nameserver|http\\-reuse|use\\-server|log\\-stderr|dgram\\-bind|errorfile|noevports|unix\\-bind|presetenv|localpeer|hash\\-type|set\\-param|path\\-info|nokqueue|maxpipes|nbthread|unsetenv|key\\-base|ulimit\\-n|fullconn|dispatch|crt\\-base|userlist|nosplice|errorloc|resetenv|retry\\-on|pidfile|mailers|max\\-age|declare|docroot|no\\-quic|timeout|balance|ca\\-base|noepoll|cpu\\-map|retries|log\\-tag|anonkey|command|program|daemon|option|setenv|chroot|issuer|setcap|maxlen|nopoll|filter|mailer|format|index|alias|peers|trace|quiet|table|grace|ring|size|mode|sctl|node|peer|hold|bind|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|static\\-rr|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:direction|algo\\-req|algo\\-res|offload|type|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
