{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|userlist|crt\\-list|program|mailers|traces|peers|cache|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|frontend|userlist|defaults|crt\\-list|program|mailers|backend|listen|traces|global|peers|cache|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|wurfl\\-information\\-list\\-separator|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|deviceatlas\\-properties\\-cookie|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.maxdelay|httpclient\\.resolvers\\.disabled|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.h2\\.fe\\.glitches\\-threshold|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.capture\\-buffer\\-size|expose\\-deprecated\\-directives|tune\\.ssl\\.force\\-private\\-cache|tune\\.listener\\.default\\-shards|tune\\.quic\\.disable\\-tx\\-pacing|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|ssl\\-default\\-server\\-sigalgs|tune\\.h1\\.zero\\-copy\\-fwd\\-send|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-ciphers|tune\\.max\\-checks\\-per\\-thread|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-options|tune\\.vars\\.reqres\\-max\\-size|tune\\.notsent\\-lowat\\.client|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.notsent\\-lowat\\.server|tune\\.listener\\.multi\\-queue|tune\\.disable\\-fast\\-forward|tune\\.quic\\.disable\\-udp\\-gso|tune\\.quic\\.retry\\-threshold|ssl\\-default\\-server\\-curves|tune\\.h2\\.header\\-table\\-size|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-options|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-ciphers|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.service\\-timeout|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.proc\\-max\\-size|tune\\.vars\\.sess\\-max\\-size|tune\\.ssl\\.hard\\-maxrecord|tune\\.pool\\-high\\-fd\\-ratio|tune\\.pattern\\.cache\\-size|ssl\\-skip\\-self\\-issued\\-ca|httpclient\\.ssl\\.ca\\-file|ssl\\-load\\-extra\\-del\\-ext|hash\\-preserve\\-affinity|force\\-cfg\\-parser\\-pause|tune\\.h2\\.max\\-frame\\-size|tune\\.sched\\.low\\-latency|server\\-state\\-file\\-name|tune\\.fd\\.edge\\-triggered|tune\\.epoll\\.mask\\-events|tune\\.pool\\-low\\-fd\\-ratio|tune\\.lua\\.burst\\-timeout|tune\\.max\\-rules\\-at\\-once|tune\\.quic\\.socket\\-owner|tune\\.vars\\.txn\\-max\\-size|insecure\\-setuid\\-wanted|deviceatlas\\-log\\-level|max\\-secondary\\-entries|tune\\.lua\\.task\\-timeout|max\\-session\\-srv\\-conns|accepted_payload_size|ocsp\\-update\\.httpproxy|http\\-send\\-name\\-header|deviceatlas\\-json\\-file|httpclient\\.ssl\\.verify|tune\\.lua\\.forced\\-yield|tune\\.idle\\-pool\\.shared|deviceatlas\\-separator|pp2\\-never\\-send\\-local|insecure\\-fork\\-wanted|tune\\.sndbuf\\.frontend|ocsp\\-update\\.maxdelay|ocsp\\-update\\.mindelay|tune\\.buffers\\.reserve|tune\\.zlib\\.windowsize|tune\\.memory\\.hot\\-size|tune\\.lua\\.log\\.loggers|tune\\.quic\\.cc\\-hystart|ssl\\-load\\-extra\\-files|max\\-keep\\-alive\\-queue|tune\\.rcvbuf\\.frontend|mworker\\-max\\-reloads|tune\\.http\\.cookielen|tune\\.renice\\.runtime|tune\\.renice\\.startup|http\\-after\\-response|hash\\-balance\\-factor|lua\\-load\\-per\\-thread|ocsp\\-update\\.disable|tune\\.rcvbuf\\.backend|tune\\.lua\\.log\\.stderr|tune\\.http\\.logurilen|h1\\-case\\-adjust\\-file|tune\\.sndbuf\\.backend|tune\\.runqueue\\-depth|tune\\.stick\\-counters|tune\\.buffers\\.limit|issuers\\-chain\\-path|tune\\.zlib\\.memlevel|no\\-memory\\-trimming|ssl\\-security\\-level|tune\\.rcvbuf\\.server|tune\\.sndbuf\\.server|tune\\.rcvbuf\\.client|httpclient\\.retries|tune\\.bufsize\\.small|tune\\.sndbuf\\.client|dynamic\\-cookie\\-key|tune\\.comp\\.maxlevel|tune\\.ssl\\.cachesize|tune\\.h2\\.log\\-errors|tune\\.maxpollevents|tune\\.ssl\\.maxrecord|tune\\.ssl\\.lifetime|max\\-spread\\-checks|ssl\\-provider\\-path|dns\\-accept\\-family|ssl\\-server\\-verify|log\\-send\\-hostname|ssl\\-dh\\-param\\-file|parse\\-resolv\\-conf|thread\\-hard\\-limit|close\\-spread\\-time|server\\-state\\-base|wurfl\\-cache\\-size|numa\\-cpu\\-mapping|tune\\.recv_enough|tune\\.ring\\.queues|unique\\-id\\-format|tune\\.h2\\.fe\\.rxbuf|profiling\\.memory|tune\\.h2\\.be\\.rxbuf|tune\\.http\\.maxhdr|error\\-log\\-format|lua\\-prepend\\-path|ocsp\\-update\\.mode|wurfl\\-patch\\-file|unique\\-id\\-header|max\\-object\\-size|profiling\\.tasks|server\\-template|default_backend|tune\\.lua\\.maxmem|maxcompcpuusage|tune\\.fail\\-alloc|resolve_retries|hard\\-stop\\-after|tune\\.maxrewrite|http\\-fail\\-codes|tune\\.ssl\\.keylog|wurfl\\-data\\-file|ssl\\-mode\\-async|ignore\\-persist|default\\-server|tune\\.idletimer|total\\-max\\-size|acme\\.scheduler|debug\\.counters|cluster\\-secret|srvtcpka\\-intvl|clitcpka\\-intvl|tune\\.maxaccept|http\\-err\\-codes|provider\\-name|thread\\-groups|nogetaddrinfo|force\\-persist|ssl\\-propquery|strict\\-limits|saml\\-sso\\-load|spread\\-checks|http\\-response|log\\-format\\-sd|master\\-worker|fd\\-hard\\-limit|tune\\.pipesize|clitcpka\\-idle|srvtcpka\\-idle|zero\\-warning|http\\-request|busy\\-polling|stress\\-level|set\\-dumpable|use\\-fcgi\\-app|backing\\-file|limited\\-quic|process\\-vary|default\\-bind|tune\\.bufsize|tune\\.chksize|clitcpka\\-cnt|quic\\-initial|tcp\\-response|thread\\-group|default\\-path|srvtcpka\\-cnt|module\\-path|maxcomprate|maxconnrate|use_backend|account\\-key|monitor\\-uri|maxsessrate|description|prealloc\\-fd|noreuseport|errorloc302|module\\-load|http\\-errors|pass\\-header|tcp\\-request|ocsp\\-update|compression|errorloc303|stats\\-file|http\\-reuse|cpu\\-policy|http\\-check|clitimeout|maxsslrate|maxzlibmem|errorfiles|log\\-stderr|srvtimeout|ssl\\-engine|contimeout|nameserver|quick\\-exit|use\\-server|rate\\-limit|http\\-error|maxsslconn|acme\\-vars|log\\-steps|errorfile|unix\\-bind|localpeer|challenge|path\\-info|hash\\-type|noevports|ssl\\-f\\-use|directory|set\\-param|reuse\\-key|presetenv|unsetenv|nokqueue|retry\\-on|nbthread|crt\\-base|dispatch|ulimit\\-n|resetenv|errorloc|key\\-base|nosplice|maxpipes|fullconn|noepoll|log\\-tag|balance|contact|pidfile|docroot|max\\-age|cpu\\-map|declare|timeout|command|keytype|domains|anonkey|cpu\\-set|no\\-quic|ca\\-base|retries|nbproc|chroot|daemon|mailer|nopoll|setcap|option|issuer|format|maxlen|setenv|filter|table|trace|alias|quiet|index|grace|hold|size|mode|sctl|peer|bind|bits|node|acl|map)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|url_param|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-req|minsize\\-res|direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|set\\-var|comment|connect|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-response\\-trailers|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ accept\\-invalid\\-http\\-request|option\\ http\\-drop\\-request\\-trailers|option\\ http\\-pretend\\-keepalive|option\\ idle\\-close\\-on\\-response|option\\ http\\-use\\-proxy\\-header|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ log\\-separate\\-errors|option\\ disable\\-h2\\-upgrade|option\\ prefer\\-last\\-server|option\\ http\\-ignore\\-probes|option\\ tcp\\-smart\\-connect|option\\ log\\-health\\-checks|option\\ http\\-server\\-close|option\\ tcp\\-smart\\-accept|option\\ start\\-on\\-reload|option\\ http\\-keep\\-alive|option\\ splice\\-response|option\\ dontlog\\-normal|option\\ splice\\-request|option\\ http\\-no\\-delay|option\\ socket\\-stats|option\\ abortonclose|option\\ transparent|option\\ dontlognull|option\\ splice\\-auto|option\\ mpxs\\-conns|option\\ redispatch|option\\ get\\-values|option\\ allbackups|option\\ checkcache|option\\ httpclose|option\\ keep\\-conn|option\\ forwarded|option\\ clitcpka|option\\ srvtcpka|option\\ nolinger|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
