{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*((?:defaults|frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|userlist|crt\\-list|program|mailers|traces|peers|cache|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|userlist|defaults|frontend|crt\\-list|program|mailers|backend|listen|global|traces|peers|cache|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|rfc7239_is_valid|max\\-object\\-size|x509_v_err_str|total\\-max\\-size|mqtt_is_valid|rfc7239_n2nn|rfc7239_n2np|fix_is_valid|process\\-vary|log\\-profile|rfc7239_nn|rfc7239_np|host_only|srv_queue|port_only|srv_is_up|cut_crlf|max\\-age|ub64enc|ub64dec|log\\-tag|base64|length|b64dec|lower|base2|htonl|hex2i|upper|nbsrv|date|sha1|even|bool|odd|cpl|hex|neg|not|on)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.takeover\\-other\\-tg\\-connections|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.h2\\.be\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.quic\\.frontend\\.max\\-data\\-size|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|httpclient\\.resolvers\\.disabled|tune\\.quic\\.frontend\\.max\\-tx\\-mem|deviceatlas\\-properties\\-cookie|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|expose\\-deprecated\\-directives|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.listener\\.default\\-shards|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.quic\\.disable\\-tx\\-pacing|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|ssl\\-default\\-server\\-sigalgs|warn\\-blocked\\-traffic\\-after|httpclient\\.timeout\\.connect|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-options|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-ciphers|tune\\.max\\-checks\\-per\\-thread|tune\\.listener\\.multi\\-queue|tune\\.quic\\.retry\\-threshold|tune\\.disable\\-fast\\-forward|tune\\.vars\\.reqres\\-max\\-size|tune\\.h2\\.header\\-table\\-size|tune\\.notsent\\-lowat\\.client|tune\\.quic\\.disable\\-udp\\-gso|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.notsent\\-lowat\\.server|ssl\\-default\\-server\\-curves|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|tune\\.vars\\.check\\-max\\-size|tune\\.quic\\.reorder\\-ratio|ssl\\-default\\-bind\\-curves|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|ssl\\-skip\\-self\\-issued\\-ca|tune\\.ssl\\.hard\\-maxrecord|tune\\.pattern\\.cache\\-size|tune\\.vars\\.sess\\-max\\-size|tune\\.vars\\.proc\\-max\\-size|tune\\.max\\-rules\\-at\\-once|tune\\.vars\\.txn\\-max\\-size|tune\\.pool\\-low\\-fd\\-ratio|ssl\\-load\\-extra\\-del\\-ext|tune\\.epoll\\.mask\\-events|insecure\\-setuid\\-wanted|tune\\.fd\\.edge\\-triggered|tune\\.sched\\.low\\-latency|tune\\.h2\\.max\\-frame\\-size|hash\\-preserve\\-affinity|httpclient\\.ssl\\.ca\\-file|tune\\.quic\\.socket\\-owner|server\\-state\\-file\\-name|force\\-cfg\\-parser\\-pause|tune\\.lua\\.burst\\-timeout|tune\\.lua\\.task\\-timeout|max\\-secondary\\-entries|deviceatlas\\-json\\-file|httpclient\\.ssl\\.verify|tune\\.idle\\-pool\\.sha