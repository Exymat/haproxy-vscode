{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|userlist|fcgi\\-app|crt\\-list|program|mailers|traces|cache|peers|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|userlist|frontend|fcgi\\-app|crt\\-list|defaults|program|backend|mailers|global|listen|traces|cache|peers|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|wurfl\\-information\\-list\\-separator|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.quic\\.frontend\\.max\\-data\\-size|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.lua\\.bool\\-sample\\-conversion|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|httpclient\\.resolvers\\.disabled|deviceatlas\\-properties\\-cookie|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.h2\\.fe\\.max\\-total\\-streams|expose\\-deprecated\\-directives|tune\\.ssl\\.force\\-private\\-cache|tune\\.listener\\.default\\-shards|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|tune\\.quic\\.disable\\-tx\\-pacing|tune\\.h2\\.initial\\-window\\-size|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|tune\\.max\\-checks\\-per\\-thread|warn\\-blocked\\-traffic\\-after|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-ciphers|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-sigalgs|httpclient\\.timeout\\.connect|ssl\\-default\\-server\\-options|tune\\.notsent\\-lowat\\.client|tune\\.disable\\-fast\\-forward|tune\\.vars\\.global\\-max\\-size|tune\\.vars\\.reqres\\-max\\-size|tune\\.listener\\.multi\\-queue|tune\\.h2\\.header\\-table\\-size|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.quic\\.retry\\-threshold|tune\\.quic\\.disable\\-udp\\-gso|tune\\.notsent\\-lowat\\.server|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-options|tune\\.vars\\.check\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pattern\\.cache\\-size|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.sess\\-max\\-size|tune\\.quic\\.reorder\\-ratio|ssl\\-default\\-bind\\-curves|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|tune\\.vars\\.proc\\-max\\-size|tune\\.pool\\-low\\-fd\\-ratio|insecure\\-setuid\\-wanted|tune\\.h2\\.max\\-frame\\-size|tune\\.quic\\.socket\\-owner|hash\\-preserve\\-affinity|server\\-state\\-file\\-name|tune\\.vars\\.txn\\-max\\-size|ssl\\-load\\-extra\\-del\\-ext|tune\\.fd\\.edge\\-triggered|tune\\.max\\-rules\\-at\\-once|tune\\.epoll\\.mask\\-events|force\\-cfg\\-parser\\-pause|tune\\.sched\\.low\\-latency|tune\\.lua\\.burst\\-timeout|httpclient\\.ssl\\.ca\\-file|tune\\.lua\\.forced\\-yield|tune\\.lua\\.task\\-timeout|max\\-session\\-srv\\-conns|deviceatlas\\-log\\-level|deviceatlas\\-separator|http\\-send\\-name\\-header|httpclient\\.ssl\\.verify|max\\-secondary\\-entries|accepted_payload_size|ocsp\\-update\\.httpproxy|deviceatlas\\-json\\-file|tune\\.idle\\-pool\\.shared|tune\\.sndbuf\\.frontend|ssl\\-load\\-extra\\-files|ocsp\\-update\\.maxdelay|pp2\\-never\\-send\\-local|ocsp\\-update\\.mindelay|tune\\.lua\\.log\\.loggers|tune\\.zlib\\.windowsize|tune\\.buffers\\.reserve|tune\\.memory\\.hot\\-size|max\\-keep\\-alive\\-queue|tune\\.rcvbuf\\.frontend|tune\\.quic\\.cc\\-hystart|insecure\\-fork\\-wanted|tune\\.http\\.cookielen|lua\\-load\\-per\\-thread|tune\\.renice\\.runtime|http\\-after\\-response|ocsp\\-update\\.disable|h1\\-case\\-adjust\\-file|tune\\.renice\\.startup|tune\\.http\\.logurilen|tune\\.runqueue\\-depth|tune\\.sndbuf\\.backend|hash\\-balance\\-factor|mworker\\-max\\-reloads|tune\\.rcvbuf\\.backend|tune\\.lua\\.log\\.stderr|tune\\.stick\\-counters|tune\\.rcvbuf\\.client|tune\\.h2\\.log\\-errors|tune\\.bufsize\\.small|tune\\.buffers\\.limit|issuers\\-chain\\-path|tune\\.ssl\\.maxrecord|tune\\.rcvbuf\\.server|tune\\.zlib\\.memlevel|no\\-memory\\-trimming|tune\\.ssl\\.cachesize|tune\\.sndbuf\\.client|tune\\.maxpollevents|ssl\\-security\\-level|dynamic\\-cookie\\-key|httpclient\\.retries|tune\\.sndbuf\\.server|tune\\.comp\\.maxlevel|max\\-spread\\-checks|log\\-send\\-hostname|parse\\-resolv\\-conf|ssl\\-provider\\-path|tune\\.ssl\\.lifetime|dns\\-accept\\-family|ssl\\-dh\\-param\\-file|close\\-spread\\-time|ssl\\-server\\-verify|thread\\-hard\\-limit|server\\-state\\-base|tune\\.recv_enough|tune\\.http\\.maxhdr|wurfl\\-patch\\-file|unique\\-id\\-format|tune\\.h2\\.fe\\.rxbuf|error\\-log\\-format|tune\\.ring\\.queues|unique\\-id\\-header|tune\\.h2\\.be\\.rxbuf|numa\\-cpu\\-mapping|ocsp\\-update\\.mode|wurfl\\-cache\\-size|profiling\\.memory|lua\\-prepend\\-path|wurfl\\-data\\-file|tune\\.lua\\.maxmem|hard\\-stop\\-after|resolve_retries|http\\-fail\\-codes|tune\\.maxrewrite|max\\-object\\-size|server\\-template|maxcompcpuusage|tune\\.ssl\\.keylog|default_backend|tune\\.fail\\-alloc|profiling\\.tasks|ssl\\-mode\\-async|http\\-err\\-codes|srvtcpka\\-intvl|total\\-max\\-size|cluster\\-secret|default\\-server|tune\\.maxaccept|clitcpka\\-intvl|tune\\.idletimer|debug\\.counters|acme\\.scheduler|ignore\\-persist|clitcpka\\-idle|fd\\-hard\\-limit|provider\\-name|srvtcpka\\-idle|strict\\-limits|http\\-response|ssl\\-propquery|thread\\-groups|log\\-format\\-sd|tune\\.pipesize|spread\\-checks|force\\-persist|nogetaddrinfo|saml\\-sso\\-load|master\\-worker|clitcpka\\-cnt|quic\\-initial|limited\\-quic|zero\\-warning|default\\-bind|stress\\-level|thread\\-group|busy\\-polling|backing\\-file|srvtcpka\\-cnt|process\\-vary|tcp\\-response|http\\-request|default\\-path|set\\-dumpable|tune\\.chksize|use\\-fcgi\\-app|tune\\.bufsize|ocsp\\-update|errorloc303|account\\-key|maxsessrate|maxconnrate|module\\-load|description|prealloc\\-fd|tcp\\-request|maxcomprate|noreuseport|pass\\-header|errorloc302|http\\-errors|module\\-path|monitor\\-uri|use_backend|compression|cpu\\-policy|maxzlibmem|contimeout|log\\-stderr|srvtimeout|stats\\-file|maxsslrate|use\\-server|http\\-check|nameserver|errorfiles|maxsslconn|http\\-error|quick\\-exit|clitimeout|ssl\\-engine|http\\-reuse|rate\\-limit|set\\-param|challenge|directory|path\\-info|reuse\\-key|localpeer|presetenv|acme\\-vars|errorfile|ssl\\-f\\-use|noevports|unix\\-bind|log\\-steps|hash\\-type|maxpipes|resetenv|key\\-base|retry\\-on|nbthread|nokqueue|ulimit\\-n|errorloc|fullconn|unsetenv|dispatch|crt\\-base|nosplice|docroot|contact|retries|declare|pidfile|command|ca\\-base|max\\-age|noepoll|balance|cpu\\-set|domains|log\\-tag|cpu\\-map|anonkey|timeout|keytype|no\\-quic|nopoll|setenv|mailer|daemon|issuer|setcap|filter|chroot|format|maxlen|option|nbproc|table|grace|alias|quiet|trace|index|hold|mode|peer|node|bits|bind|sctl|size|acl|map)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|static\\-rr|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-req|minsize\\-res|direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|connect|comment|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-response\\-trailers|option\\ http\\-drop\\-request\\-trailers|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ log\\-separate\\-errors|option\\ http\\-buffer\\-request|option\\ independent\\-streams|option\\ prefer\\-last\\-server|option\\ http\\-ignore\\-probes|option\\ disable\\-h2\\-upgrade|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ splice\\-response|option\\ http\\-keep\\-alive|option\\ start\\-on\\-reload|option\\ dontlog\\-normal|option\\ splice\\-request|option\\ http\\-no\\-delay|option\\ socket\\-stats|option\\ abortonclose|option\\ splice\\-auto|option\\ dontlognull|option\\ transparent|option\\ redispatch|option\\ mpxs\\-conns|option\\ allbackups|option\\ get\\-values|option\\ checkcache|option\\ forwarded|option\\ keep\\-conn|option\\ httpclose|option\\ srvtcpka|option\\ clitcpka|option\\ nolinger|option\\ logasap|option\\ persist|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
