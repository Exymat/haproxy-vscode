        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-res|minsize\\-req|direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
