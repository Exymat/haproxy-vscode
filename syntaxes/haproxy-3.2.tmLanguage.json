{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|crt\\-list|userlist|fcgi\\-app|mailers|program|traces|cache|peers|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|crt\\-list|frontend|defaults|userlist|fcgi\\-app|mailers|backend|program|global|traces|listen|cache|peers|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.disable\\-zero\\-copy\\-forwarding|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|deviceatlas\\-properties\\-cookie|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.quic\\.frontend\\.max\\-tx\\-mem|httpclient\\.resolvers\\.disabled|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|ssl\\-default\\-bind\\-ciphersuites|expose\\-deprecated\\-directives|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.listener\\.default\\-shards|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|load\\-server\\-state\\-from\\-file|tune\\.quic\\.disable\\-tx\\-pacing|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|tune\\.max\\-checks\\-per\\-thread|ssl\\-default\\-server\\-options|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-ciphers|ssl\\-default\\-server\\-sigalgs|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|httpclient\\.timeout\\.connect|tune\\.notsent\\-lowat\\.client|tune\\.vars\\.reqres\\-max\\-size|ssl\\-default\\-server\\-curves|tune\\.quic\\.disable\\-udp\\-gso|tune\\.vars\\.global\\-max\\-size|tune\\.quic\\.retry\\-threshold|tune\\.listener\\.multi\\-queue|tune\\.h2\\.header\\-table\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.notsent\\-lowat\\.server|tune\\.disable\\-fast\\-forward|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-options|tune\\.lua\\.service\\-timeout|tune\\.vars\\.check\\-max\\-size|tune\\.pattern\\.cache\\-size|ssl\\-default\\-bind\\-curves|tune\\.pool\\-high\\-fd\\-ratio|tune\\.vars\\.proc\\-max\\-size|tune\\.ssl\\.hard\\-maxrecord|httpclient\\.resolvers\\.id|tune\\.quic\\.reorder\\-ratio|ssl\\-skip\\-self\\-issued\\-ca|tune\\.vars\\.sess\\-max\\-size|tune\\.pool\\-low\\-fd\\-ratio|httpclient\\.ssl\\.ca\\-file|ssl\\-load\\-extra\\-del\\-ext|tune\\.h2\\.max\\-frame\\-size|tune\\.fd\\.edge\\-triggered|server\\-state\\-file\\-name|force\\-cfg\\-parser\\-pause|tune\\.quic\\.socket\\-owner|tune\\.epoll\\.mask\\-events|tune\\.sched\\.low\\-latency|hash\\-preserve\\-affinity|tune\\.lua\\.burst\\-timeout|tune\\.max\\-rules\\-at\\-once|tune\\.vars\\.txn\\-max\\-size|insecure\\-setuid\\-wanted|deviceatlas\\-json\\-file|tune\\.lua\\.forced\\-yield|max\\-secondary\\-entries|tune\\.lua\\.task\\-timeout|http\\-send\\-name\\-header|accepted_payload_size|max\\-session\\-srv\\-conns|tune\\.idle\\-pool\\.shared|ocsp\\-update\\.httpproxy|deviceatlas\\-log\\-level|httpclient\\.ssl\\.verify|deviceatlas\\-separator|tune\\.rcvbuf\\.frontend|insecure\\-fork\\-wanted|ssl\\-load\\-extra\\-files|tune\\.buffers\\.reserve|tune\\.memory\\.hot\\-size|max\\-keep\\-alive\\-queue|ocsp\\-update\\.maxdelay|pp2\\-never\\-send\\-local|tune\\.quic\\.cc\\-hystart|ocsp\\-update\\.mindelay|tune\\.lua\\.log\\.loggers|tune\\.sndbuf\\.frontend|tune\\.zlib\\.windowsize|http\\-after\\-response|tune\\.lua\\.log\\.stderr|tune\\.renice\\.startup|tune\\.http\\.cookielen|tune\\.stick\\-counters|ocsp\\-update\\.disable|h1\\-case\\-adjust\\-file|tune\\.sndbuf\\.backend|tune\\.http\\.logurilen|mworker\\-max\\-reloads|tune\\.rcvbuf\\.backend|hash\\-balance\\-factor|lua\\-load\\-per\\-thread|tune\\.renice\\.runtime|tune\\.runqueue\\-depth|tune\\.ssl\\.maxrecord|issuers\\-chain\\-path|tune\\.h2\\.log\\-errors|tune\\.ssl\\.cachesize|httpclient\\.retries|tune\\.buffers\\.limit|no\\-memory\\-trimming|tune\\.rcvbuf\\.client|tune\\.comp\\.maxlevel|tune\\.sndbuf\\.client|tune\\.zlib\\.memlevel|tune\\.bufsize\\.small|tune\\.maxpollevents|dynamic\\-cookie\\-key|tune\\.rcvbuf\\.server|tune\\.sndbuf\\.server|ssl\\-security\\-level|tune\\.ssl\\.lifetime|log\\-send\\-hostname|server\\-state\\-base|thread\\-hard\\-limit|ssl\\-server\\-verify|dns\\-accept\\-family|parse\\-resolv\\-conf|close\\-spread\\-time|max\\-spread\\-checks|ssl\\-dh\\-param\\-file|ssl\\-provider\\-path|tune\\.http\\.maxhdr|tune\\.h2\\.fe\\.rxbuf|tune\\.ring\\.queues|lua\\-prepend\\-path|tune\\.recv_enough|wurfl\\-patch\\-file|wurfl\\-cache\\-size|profiling\\.memory|ocsp\\-update\\.mode|tune\\.h2\\.be\\.rxbuf|error\\-log\\-format|numa\\-cpu\\-mapping|unique\\-id\\-header|unique\\-id\\-format|tune\\.fail\\-alloc|profiling\\.tasks|max\\-object\\-size|hard\\-stop\\-after|wurfl\\-data\\-file|http\\-fail\\-codes|server\\-template|maxcompcpuusage|tune\\.ssl\\.keylog|default_backend|resolve_retries|tune\\.maxrewrite|tune\\.lua\\.maxmem|tune\\.maxaccept|debug\\.counters|clitcpka\\-intvl|tune\\.idletimer|total\\-max\\-size|ignore\\-persist|ssl\\-mode\\-async|cluster\\-secret|srvtcpka\\-intvl|acme\\.scheduler|http\\-err\\-codes|default\\-server|ssl\\-propquery|fd\\-hard\\-limit|strict\\-limits|master\\-worker|saml\\-sso\\-load|thread\\-groups|log\\-format\\-sd|srvtcpka\\-idle|nogetaddrinfo|provider\\-name|spread\\-checks|force\\-persist|clitcpka\\-idle|tune\\.pipesize|http\\-response|busy\\-polling|http\\-request|backing\\-file|tune\\.bufsize|tcp\\-response|thread\\-group|default\\-path|stress\\-level|srvtcpka\\-cnt|set\\-dumpable|process\\-vary|zero\\-warning|limited\\-quic|tune\\.chksize|quic\\-initial|clitcpka\\-cnt|default\\-bind|use\\-fcgi\\-app|errorloc302|pass\\-header|maxcomprate|description|maxsessrate|http\\-errors|errorloc303|compression|module\\-load|prealloc\\-fd|monitor\\-uri|use_backend|account\\-key|ocsp\\-update|noreuseport|maxconnrate|module\\-path|tcp\\-request|nameserver|errorfiles|maxsslconn|maxzlibmem|stats\\-file|log\\-stderr|cpu\\-policy|use\\-server|maxsslrate|http\\-error|srvtimeout|ssl\\-engine|rate\\-limit|contimeout|clitimeout|http\\-reuse|http\\-check|quick\\-exit|presetenv|ssl\\-f\\-use|hash\\-type|noevports|challenge|reuse\\-key|acme\\-vars|set\\-param|directory|errorfile|unix\\-bind|localpeer|path\\-info|log\\-steps|nosplice|nokqueue|crt\\-base|dispatch|retry\\-on|resetenv|maxpipes|unsetenv|nbthread|errorloc|fullconn|ulimit\\-n|key\\-base|ca\\-base|domains|timeout|declare|balance|noepoll|no\\-quic|docroot|log\\-tag|max\\-age|pidfile|cpu\\-set|cpu\\-map|contact|command|retries|anonkey|keytype|daemon|filter|issuer|mailer|maxlen|nbproc|format|chroot|setenv|nopoll|option|setcap|quiet|trace|table|grace|index|alias|node|sctl|mode|bits|peer|size|bind|hold|acl|map)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|static\\-rr|leastconn|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-res|minsize\\-req|direction|algo\\-res|algo\\-req|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|set\\-var|comment|connect|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-response\\-trailers|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ http\\-drop\\-request\\-trailers|option\\ http\\-pretend\\-keepalive|option\\ idle\\-close\\-on\\-response|option\\ http\\-use\\-proxy\\-header|option\\ http\\-buffer\\-request|option\\ independent\\-streams|option\\ log\\-separate\\-errors|option\\ http\\-ignore\\-probes|option\\ disable\\-h2\\-upgrade|option\\ prefer\\-last\\-server|option\\ http\\-server\\-close|option\\ tcp\\-smart\\-connect|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ start\\-on\\-reload|option\\ splice\\-response|option\\ http\\-keep\\-alive|option\\ splice\\-request|option\\ dontlog\\-normal|option\\ http\\-no\\-delay|option\\ socket\\-stats|option\\ abortonclose|option\\ splice\\-auto|option\\ dontlognull|option\\ transparent|option\\ redispatch|option\\ mpxs\\-conns|option\\ allbackups|option\\ checkcache|option\\ get\\-values|option\\ forwarded|option\\ keep\\-conn|option\\ httpclose|option\\ clitcpka|option\\ nolinger|option\\ srvtcpka|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
