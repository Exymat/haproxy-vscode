une\\.fail\\-alloc|http\\-fail\\-codes|wurfl\\-data\\-file|resolve_retries|total\\-max\\-size|ssl\\-mode\\-async|srvtcpka\\-intvl|http\\-err\\-codes|tune\\.idletimer|cluster\\-secret|default\\-server|clitcpka\\-intvl|debug\\.counters|acme\\.scheduler|ignore\\-persist|tune\\.maxaccept|x509_v_err_str|spread\\-checks|thread\\-groups|ssl\\-propquery|strict\\-limits|http\\-response|master\\-worker|clitcpka\\-idle|fd\\-hard\\-limit|saml\\-sso\\-load|mqtt_is_valid|nogetaddrinfo|force\\-persist|tune\\.pipesize|provider\\-name|log\\-format\\-sd|srvtcpka\\-idle|quic\\-initial|tune\\.bufsize|stress\\-level|zero\\-warning|default\\-bind|srvtcpka\\-cnt|rfc7239_n2nn|set\\-dumpable|use\\-fcgi\\-app|clitcpka\\-cnt|limited\\-quic|process\\-vary|thread\\-group|busy\\-polling|rfc7239_n2np|tcp\\-response|tune\\.chksize|http\\-request|backing\\-file|default\\-path|fix_is_valid|ocsp\\-update|module\\-path|description|use_backend|maxconnrate|prealloc\\-fd|noreuseport|stick\\-table|maxsessrate|monitor\\-uri|log\\-forward|compression|pass\\-header|errorloc303|http\\-errors|tcp\\-request|log\\-profile|errorloc302|module\\-load|maxcomprate|account\\-key|clitimeout|rfc7239_np|dgram\\-bind|http\\-check|quick\\-exit|stats\\-file|rate\\-limit|cpu\\-policy|maxsslconn|rfc7239_nn|maxzlibmem|contimeout|ssl\\-engine|maxsslrate|srvtimeout|errorfiles|nameserver|http\\-error|use\\-server|http\\-reuse|log\\-steps|hash\\-type|challenge|localpeer|path\\-info|reuse\\-key|srv_is_up|directory|noevports|srv_queue|port_only|acme\\-vars|set\\-param|presetenv|ssl\\-f\\-use|errorfile|host_only|unix\\-bind|nosplice|resetenv|maxpipes|ulimit\\-n|key\\-base|nokqueue|unsetenv|nbthread|dispatch|crt\\-base|fullconn|errorloc|retry\\-on|cut_crlf|log\\-tag|anonkey|ca\\-base|noepoll|cpu\\-map|domains|ub64enc|keytype|ub64dec|pidfile|max\\-age|no\\-quic|retries|cpu\\-set|balance|timeout|docroot|command|declare|contact|setenv|nopoll|format|daemon|b64dec|base64|setcap|maxlen|chroot|length|mailer|issuer|filter|nbproc|option|hex2i|base2|alias|htonl|table|lower|nbsrv|quiet|trace|grace|upper|index|even|mode|peer|hold|bind|date|sha1|bool|size|node|bits|sctl|acl|neg|odd|hex|map|not|cpl|on)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|leastconn|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
