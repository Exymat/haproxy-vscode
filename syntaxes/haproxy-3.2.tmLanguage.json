{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|userlist|crt\\-list|program|mailers|traces|cache|peers|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|fcgi\\-app|frontend|defaults|userlist|crt\\-list|backend|program|mailers|global|listen|traces|cache|peers|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.takeover\\-other\\-tg\\-connections|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|expose\\-experimental\\-directives|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|deviceatlas\\-properties\\-cookie|tune\\.quic\\.cc\\.cubic\\.min\\-losses|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.h2\\.fe\\.glitches\\-threshold|httpclient\\.resolvers\\.disabled|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|expose\\-deprecated\\-directives|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.default\\-shards|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.ssl\\.force\\-private\\-cache|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.ssl\\.capture\\-buffer\\-size|load\\-server\\-state\\-from\\-file|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|tune\\.quic\\.disable\\-tx\\-pacing|tune\\.max\\-checks\\-per\\-thread|warn\\-blocked\\-traffic\\-after|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|httpclient\\.timeout\\.connect|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-options|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.disable\\-fast\\-forward|tune\\.notsent\\-lowat\\.server|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.notsent\\-lowat\\.client|tune\\.h2\\.header\\-table\\-size|tune\\.listener\\.multi\\-queue|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.reqres\\-max\\-size|tune\\.quic\\.disable\\-udp\\-gso|ssl\\-default\\-server\\-curves|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-sigalgs|httpclient\\.resolvers\\.id|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.sess\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|tune\\.vars\\.proc\\-max\\-size|tune\\.pattern\\.cache\\-size|tune\\.quic\\.reorder\\-ratio|ssl\\-skip\\-self\\-issued\\-ca|ssl\\-default\\-bind\\-curves|insecure\\-setuid\\-wanted|tune\\.fd\\.edge\\-triggered|tune\\.lua\\.burst\\-timeout|tune\\.pool\\-low\\-fd\\-ratio|tune\\.quic\\.socket\\-owner|httpclient\\.ssl\\.ca\\-file|tune\\.sched\\.low\\-latency|tune\\.epoll\\.mask\\-events|hash\\-preserve\\-affinity|tune\\.vars\\.txn\\-max\\-size|tune\\.h2\\.max\\-frame\\-size|tune\\.max\\-rules\\-at\\-once|ssl\\-load\\-extra\\-del\\-ext|force\\-cfg\\-parser\\-pause|server\\-state\\-file\\-name|max\\-session\\-srv\\-conns|deviceatlas\\-json\\-file|tune\\.lua\\.task\\-timeout|deviceatlas\\-log\\-level|ocsp\\-update\\.httpproxy|max\\-secondary\\-entries|httpclient\\.ssl\\.verify|http\\-send\\-name\\-header|tune\\.idle\\-pool\\.shared|deviceatlas\\-separator|accepted_payload_size|tune\\.lua\\.forced\\-yield|tune\\.lua\\.log\\.loggers|ssl\\-load\\-extra\\-files|pp2\\-never\\-send\\-local|tune\\.rcvbuf\\.frontend|tune\\.buffers\\.reserve|tune\\.zlib\\.windowsize|tune\\.memory\\.hot\\-size|max\\-keep\\-alive\\-queue|ocsp\\-update\\.maxdelay|insecure\\-fork\\-wanted|tune\\.sndbuf\\.frontend|ocsp\\-update\\.mindelay|tune\\.quic\\.cc\\-hystart|tune\\.renice\\.startup|hash\\-balance\\-factor|tune\\.runqueue\\-depth|tune\\.http\\.cookielen|tune\\.sndbuf\\.backend|tune\\.http\\.logurilen|ocsp\\-update\\.disable|h1\\-case\\-adjust\\-file|tune\\.rcvbuf\\.backend|mworker\\-max\\-reloads|lua\\-load\\-per\\-thread|http\\-after\\-response|tune\\.lua\\.log\\.stderr|tune\\.stick\\-counters|tune\\.renice\\.runtime|tune\\.buffers\\.limit|tune\\.maxpollevents|tune\\.bufsize\\.small|tune\\.rcvbuf\\.server|tune\\.zlib\\.memlevel|ssl\\-security\\-level|httpclient\\.retries|tune\\.sndbuf\\.client|tune\\.ssl\\.maxrecord|dynamic\\-cookie\\-key|no\\-memory\\-trimming|tune\\.comp\\.maxlevel|tune\\.ssl\\.cachesize|tune\\.sndbuf\\.server|issuers\\-chain\\-path|tune\\.rcvbuf\\.client|tune\\.h2\\.log\\-errors|ssl\\-dh\\-param\\-file|thread\\-hard\\-limit|server\\-state\\-base|tune\\.ssl\\.lifetime|log\\-send\\-hostname|ssl\\-server\\-verify|parse\\-resolv\\-conf|dns\\-accept\\-family|max\\-spread\\-checks|ssl\\-provider\\-path|close\\-spread\\-time|numa\\-cpu\\-mapping|error\\-log\\-format|tune\\.h2\\.be\\.rxbuf|lua\\-prepend\\-path|wurfl\\-cache\\-size|ocsp\\-update\\.mode|tune\\.h2\\.fe\\.rxbuf|unique\\-id\\-header|wurfl\\-patch\\-file|profiling\\.memory|tune\\.recv_enough|tune\\.http\\.maxhdr|unique\\-id\\-format|tune\\.ring\\.queues|maxcompcpuusage|hard\\-stop\\-after|tune\\.ssl\\.keylog|max\\-object\\-size|server\\-template|wurfl\\-data\\-file|http\\-fail\\-codes|tune\\.maxrewrite|default_backend|profiling\\.tasks|resolve_retries|tune\\.lua\\.maxmem|tune\\.fail\\-alloc|debug\\.counters|ignore\\-persist|cluster\\-secret|default\\-server|tune\\.maxaccept|acme\\.scheduler|total\\-max\\-size|clitcpka\\-intvl|srvtcpka\\-intvl|tune\\.idletimer|ssl\\-mode\\-async|http\\-err\\-codes|clitcpka\\-idle|provider\\-name|tune\\.pipesize|spread\\-checks|master\\-worker|http\\-response|ssl\\-propquery|fd\\-hard\\-limit|log\\-format\\-sd|force\\-persist|strict\\-limits|saml\\-sso\\-load|thread\\-groups|nogetaddrinfo|srvtcpka\\-idle|busy\\-polling|srvtcpka\\-cnt|thread\\-group|tune\\.chksize|clitcpka\\-cnt|http\\-request|tune\\.bufsize|backing\\-file|stress\\-level|zero\\-warning|default\\-path|tcp\\-response|process\\-vary|quic\\-initial|use\\-fcgi\\-app|limited\\-quic|default\\-bind|set\\-dumpable|errorloc302|compression|maxconnrate|account\\-key|noreuseport|prealloc\\-fd|maxcomprate|use_backend|errorloc303|tcp\\-request|module\\-path|pass\\-header|maxsessrate|monitor\\-uri|module\\-load|description|http\\-errors|ocsp\\-update|http\\-error|stats\\-file|quick\\-exit|http\\-check|use\\-server|nameserver|errorfiles|ssl\\-engine|clitimeout|srvtimeout|rate\\-limit|maxsslconn|log\\-stderr|http\\-reuse|maxsslrate|contimeout|cpu\\-policy|maxzlibmem|hash\\-type|errorfile|log\\-steps|unix\\-bind|challenge|localpeer|ssl\\-f\\-use|acme\\-vars|reuse\\-key|presetenv|path\\-info|set\\-param|directory|noevports|errorloc|key\\-base|ulimit\\-n|unsetenv|resetenv|nosplice|retry\\-on|fullconn|nbthread|dispatch|crt\\-base|nokqueue|maxpipes|docroot|log\\-tag|retries|command|anonkey|pidfile|timeout|no\\-quic|max\\-age|declare|balance|contact|domains|cpu\\-set|cpu\\-map|noepoll|ca\\-base|keytype|mailer|chroot|nopoll|option|issuer|format|maxlen|nbproc|setcap|filter|setenv|daemon|index|trace|table|grace|quiet|alias|mode|node|bits|peer|bind|hold|sctl|size|map|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-res|minsize\\-req|direction|algo\\-req|algo\\-res|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|connect|comment|set\\-var|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-response\\-trailers|option\\ http\\-drop\\-request\\-trailers|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ http\\-buffer\\-request|option\\ log\\-separate\\-errors|option\\ independent\\-streams|option\\ http\\-ignore\\-probes|option\\ prefer\\-last\\-server|option\\ disable\\-h2\\-upgrade|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ splice\\-response|option\\ http\\-keep\\-alive|option\\ start\\-on\\-reload|option\\ dontlog\\-normal|option\\ splice\\-request|option\\ http\\-no\\-delay|option\\ abortonclose|option\\ socket\\-stats|option\\ splice\\-auto|option\\ transparent|option\\ dontlognull|option\\ get\\-values|option\\ redispatch|option\\ allbackups|option\\ checkcache|option\\ mpxs\\-conns|option\\ keep\\-conn|option\\ httpclose|option\\ forwarded|option\\ srvtcpka|option\\ clitcpka|option\\ nolinger|option\\ logasap|option\\ persist|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
