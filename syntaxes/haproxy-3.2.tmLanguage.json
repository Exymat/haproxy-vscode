{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*((?:defaults|frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|crt\\-list|fcgi\\-app|userlist|mailers|program|traces|cache|peers|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|defaults|crt\\-list|frontend|fcgi\\-app|userlist|backend|mailers|program|traces|global|listen|cache|peers|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.takeover\\-other\\-tg\\-connections|tune\\.disable\\-zero\\-copy\\-forwarding|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.certificate\\-compression|wurfl\\-information\\-list\\-separator|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|expose\\-experimental\\-directives|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.quic\\.frontend\\.max\\-tx\\-mem|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|httpclient\\.resolvers\\.disabled|tune\\.h2\\.be\\.glitches\\-threshold|deviceatlas\\-properties\\-cookie|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.ssl\\.force\\-private\\-cache|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.listener\\.default\\-shards|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-buffer\\-size|expose\\-deprecated\\-directives|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.quic\\.disable\\-tx\\-pacing|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|httpclient\\.resolvers\\.prefer|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|ssl\\-default\\-server\\-ciphers|tune\\.h2\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-sigalgs|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-options|tune\\.vars\\.global\\-max\\-size|tune\\.disable\\-fast\\-forward|tune\\.quic\\.retry\\-threshold|tune\\.notsent\\-lowat\\.server|tune\\.h2\\.header\\-table\\-size|tune\\.quic\\.disable\\-udp\\-gso|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.notsent\\-lowat\\.client|tune\\.vars\\.reqres\\-max\\-size|tune\\.listener\\.multi\\-queue|tune\\.lua\\.service\\-timeout|tune\\.vars\\.check\\-max\\-size|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-options|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-curves|ssl\\-skip\\-self\\-issued\\-ca|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.proc\\-max\\-size|tune\\.quic\\.reorder\\-ratio|httpclient\\.resolvers\\.id|tune\\.vars\\.sess\\-max\\-size|tune\\.pattern\\.cache\\-size|tune\\.pool\\-high\\-fd\\-ratio|tune\\.h2\\.max\\-frame\\-size|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|tune\\.pool\\-low\\-fd\\-ratio|tune\\.lua\\.burst\\-timeout|server\\-state\\-file\\-name|tune\\.max\\-rules\\-at\\-once|hash\\-preserve\\-affinity|tune\\.fd\\.edge\\-triggered|force\\-cfg\\-parser\\-pause|ssl\\-load\\-extra\\-del\\-ext|httpclient\\.ssl\\.ca\\-file|tune\\.epoll\\.mask\\-events|tune\\.vars\\.txn\\-max\\-size|tune\\.sched\\.low\\-latency|ocsp\\-update\\.httpproxy|accepted_payload_size|deviceatlas\\-log\\-level|deviceatlas\\-separator|tune\\.lua\\.forced\\-yield|httpclient\\.ssl\\.verify|max\\-session\\-srv\\-conns|tune\\.lua\\.task\\-timeout|max\\-secondary\\-entries|http\\-send\\-name\\-header|tune\\.idle\\-pool\\.shared|deviceatlas\\-json\\-file|tune\\.sndbuf\\.frontend|ocsp\\-update\\.mindelay|max\\-keep\\-alive\\-queue|tune\\.memory\\.hot\\-size|tune\\.buffers\\.reserve|tune\\.zlib\\.windowsize|tune\\.lua\\.log\\.loggers|insecure\\-fork\\-wanted|tune\\.quic\\.cc\\-hystart|tune\\.rcvbuf\\.frontend|ssl\\-load\\-extra\\-files|pp2\\-never\\-send\\-local|ocsp\\-update\\.maxdelay|lua\\-load\\-per\\-thread|tune\\.runqueue\\-depth|tune\\.renice\\.startup|tune\\.stick\\-counters|tune\\.renice\\.runtime|http\\-after\\-response|tune\\.rcvbuf\\.backend|tune\\.sndbuf\\.backend|ocsp\\-update\\.disable|tune\\.lua\\.log\\.stderr|tune\\.http\\.logurilen|hash\\-balance\\-factor|h1\\-case\\-adjust\\-file|tune\\.http\\.cookielen|mworker\\-max\\-reloads|tune\\.zlib\\.memlevel|tune\\.ssl\\.cachesize|tune\\.rcvbuf\\.client|dynamic\\-cookie\\-key|ssl\\-security\\-level|tune\\.buffers\\.limit|tune\\.h2\\.log\\-errors|httpclient\\.retries|tune\\.sndbuf\\.client|tune\\.comp\\.maxlevel|tune\\.ssl\\.maxrecord|no\\-memory\\-trimming|tune\\.bufsize\\.small|tune\\.sndbuf\\.server|tune\\.rcvbuf\\.server|issuers\\-chain\\-path|tune\\.maxpollevents|ssl\\-provider\\-path|ssl\\-server\\-verify|ssl\\-dh\\-param\\-file|dns\\-accept\\-family|max\\-spread\\-checks|log\\-send\\-hostname|server\\-state\\-base|tune\\.ssl\\.lifetime|parse\\-resolv\\-conf|thread\\-hard\\-limit|close\\-spread\\-time|numa\\-cpu\\-mapping|wurfl\\-cache\\-size|tune\\.recv_enough|unique\\-id\\-format|error\\-log\\-format|lua\\-prepend\\-path|profiling\\.memory|tune\\.h2\\.be\\.rxbuf|tune\\.h2\\.fe\\.rxbuf|tune\\.ring\\.queues|unique\\-id\\-header|ocsp\\-update\\.mode|tune\\.http\\.maxhdr|wurfl\\-patch\\-file|hard\\-stop\\-after|maxcompcpuusage|wurfl\\-data\\-file|tune\\.maxrewrite|tune\\.fail\\-alloc|tune\\.lua\\.maxmem|tune\\.ssl\\.keylog|http\\-fail\\-codes|default_backend|profiling\\.tasks|max\\-object\\-size|server\\-template|resolve_retries|clitcpka\\-intvl|http\\-err\\-codes|tune\\.idletimer|acme\\.scheduler|ignore\\-persist|srvtcpka\\-intvl|tune\\.maxaccept|total\\-max\\-size|default\\-server|debug\\.counters|ssl\\-mode\\-async|cluster\\-secret|saml\\-sso\\-load|nogetaddrinfo|strict\\-limits|fd\\-hard\\-limit|master\\-worker|clitcpka\\-idle|provider\\-name|spread\\-checks|log\\-format\\-sd|ssl\\-propquery|tune\\.pipesize|http\\-response|srvtcpka\\-idle|force\\-persist|thread\\-groups|default\\-path|busy\\-polling|srvtcpka\\-cnt|tune\\.chksize|set\\-dumpable|tcp\\-response|backing\\-file|clitcpka\\-cnt|thread\\-group|use\\-fcgi\\-app|stress\\-level|process\\-vary|limited\\-quic|zero\\-warning|http\\-request|tune\\.bufsize|default\\-bind|quic\\-initial|maxconnrate|maxcomprate|pass\\-header|description|module\\-path|errorloc302|compression|module\\-load|tcp\\-request|noreuseport|errorloc303|use_backend|http\\-errors|ocsp\\-update|monitor\\-uri|account\\-key|maxsessrate|prealloc\\-fd|http\\-check|maxsslrate|cpu\\-policy|log\\-stderr|contimeout|nameserver|errorfiles|maxzlibmem|http\\-reuse|rate\\-limit|stats\\-file|srvtimeout|use\\-server|ssl\\-engine|maxsslconn|quick\\-exit|clitimeout|http\\-error|directory|localpeer|presetenv|errorfile|unix\\-bind|set\\-param|noevports|challenge|log\\-steps|acme\\-vars|reuse\\-key|hash\\-type|path\\-info|ssl\\-f\\-use|resetenv|crt\\-base|errorloc|unsetenv|fullconn|nokqueue|dispatch|ulimit\\-n|retry\\-on|nbthread|maxpipes|nosplice|key\\-base|declare|contact|max\\-age|pidfile|command|log\\-tag|no\\-quic|timeout|noepoll|keytype|anonkey|balance|retries|docroot|cpu\\-map|ca\\-base|cpu\\-set|domains|mailer|daemon|setenv|maxlen|issuer|setcap|nbproc|nopoll|filter|format|option|chroot|table|alias|trace|index|quiet|grace|hold|node|sctl|size|bind|bits|mode|peer|map|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|leastconn|static\\-rr|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
