{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*((?:defaults|frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|fcgi\\-app|userlist|crt\\-list|mailers|program|traces|peers|cache|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|defaults|fcgi\\-app|userlist|crt\\-list|frontend|backend|mailers|program|global|traces|listen|peers|cache|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|rfc7239_is_valid|max\\-object\\-size|total\\-max\\-size|x509_v_err_str|mqtt_is_valid|rfc7239_n2nn|process\\-vary|fix_is_valid|rfc7239_n2np|log\\-profile|rfc7239_np|rfc7239_nn|srv_queue|srv_is_up|host_only|port_only|cut_crlf|ub64enc|log\\-tag|max\\-age|ub64dec|base64|length|b64dec|upper|htonl|base2|hex2i|nbsrv|lower|date|bool|sha1|even|hex|odd|not|cpl|neg|on)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|tune\\.quic\\.frontend\\.glitches\\-threshold|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.applet\\.zero\\-copy\\-forwarding|wurfl\\-information\\-list\\-separator|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.events\\.max\\-events\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.quic\\.frontend\\.max\\-tx\\-mem|httpclient\\.resolvers\\.disabled|ssl\\-default\\-bind\\-ciphersuites|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|deviceatlas\\-properties\\-cookie|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.ssl\\.force\\-private\\-cache|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.default\\-shards|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-buffer\\-size|expose\\-deprecated\\-directives|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.quic\\.disable\\-tx\\-pacing|load\\-server\\-state\\-from\\-file|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|httpclient\\.resolvers\\.prefer|tune\\.max\\-checks\\-per\\-thread|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|tune\\.h2\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|warn\\-blocked\\-traffic\\-after|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.header\\-table\\-size|tune\\.quic\\.retry\\-threshold|tune\\.vars\\.global\\-max\\-size|tune\\.notsent\\-lowat\\.server|tune\\.vars\\.reqres\\-max\\-size|tune\\.notsent\\-lowat\\.client|tune\\.listener\\.multi\\-queue|tune\\.quic\\.disable\\-udp\\-gso|ssl\\-default\\-server\\-curves|tune\\.disable\\-fast\\-forward|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-options|tune\\.pool\\-high\\-fd\\-ratio|tune\\.pattern\\.cache\\-size|tune\\.vars\\.sess\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|httpclient\\.resolvers\\.id|tune\\.quic\\.reorder\\-ratio|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.proc\\-max\\-size|ssl\\-default\\-bind\\-curves|tune\\.sched\\.low\\-latency|tune\\.vars\\.txn\\-max\\-size|tune\\.epoll\\.mask\\-events|tune\\.h2\\.max\\-frame\\-size|tune\\.max\\-rules\\-at\\-once|server\\-state\\-file\\-name|tune\\.pool\\-low\\-fd\\-ratio|tune\\.lua\\.burst\\-timeout|tune\\.quic\\.socket\\-owner|ssl\\-load\\-extra\\-del\\-ext|force\\-cfg\\-parser\\-pause|httpclient\\.ssl\\.ca\\-file|hash\\-preserve\\-affinity|tune\\.fd\\.edge\\-triggered|insecure\\-setuid\\-wanted|max\\-secondary\\-entries|tune\\.lua\\.task\\-timeout|httpclient\\.ssl\\.verify|tune\\.idle\\-pool\\.shared|deviceatlas\\-json\\-f