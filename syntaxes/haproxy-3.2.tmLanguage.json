{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|fcgi\\-app|crt\\-list|mailers|program|traces|peers|cache|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|fcgi\\-app|frontend|crt\\-list|defaults|program|backend|mailers|listen|traces|global|peers|cache|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.takeover\\-other\\-tg\\-connections|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.h2\\.be\\.max\\-concurrent\\-streams|h1\\-accept\\-payload\\-with\\-any\\-method|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.certificate\\-compression|tune\\.quic\\.frontend\\.max\\-data\\-size|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.lua\\.bool\\-sample\\-conversion|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.events\\.max\\-events\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|ssl\\-default\\-bind\\-ciphersuites|deviceatlas\\-properties\\-cookie|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.ssl\\.ocsp\\-update\\.mindelay|httpclient\\.resolvers\\.disabled|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.listener\\.default\\-shards|tune\\.quic\\.zero\\-copy\\-fwd\\-send|expose\\-deprecated\\-directives|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.ssl\\.force\\-private\\-cache|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.h2\\.initial\\-window\\-size|tune\\.quic\\.disable\\-tx\\-pacing|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|load\\-server\\-state\\-from\\-file|ssl\\-default\\-server\\-options|warn\\-blocked\\-traffic\\-after|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-ciphers|httpclient\\.timeout\\.connect|tune\\.h1\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-sigalgs|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|tune\\.max\\-checks\\-per\\-thread|tune\\.h2\\.header\\-table\\-size|tune\\.notsent\\-lowat\\.client|tune\\.quic\\.disable\\-udp\\-gso|tune\\.quic\\.retry\\-threshold|ssl\\-default\\-server\\-curves|tune\\.ssl\\.default\\-dh\\-param|tune\\.listener\\.multi\\-queue|tune\\.disable\\-fast\\-forward|tune\\.notsent\\-lowat\\.server|tune\\.vars\\.global\\-max\\-size|tune\\.vars\\.reqres\\-max\\-size|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-options|tune\\.lua\\.service\\-timeout|tune\\.vars\\.check\\-max\\-size|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|ssl\\-skip\\-self\\-issued\\-ca|tune\\.vars\\.proc\\-max\\-size|tune\\.vars\\.sess\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|tune\\.quic\\.reorder\\-ratio|httpclient\\.resolvers\\.id|tune\\.pattern\\.cache\\-size|ssl\\-default\\-bind\\-curves|tune\\.ssl\\.hard\\-maxrecord|tune\\.h2\\.max\\-frame\\-size|tune\\.sched\\.low\\-latency|tune\\.lua\\.burst\\-timeout|tune\\.max\\-rules\\-at\\-once|tune\\.vars\\.txn\\-max\\-size|force\\-cfg\\-parser\\-pause|httpclient\\.ssl\\.ca\\-file|tune\\.epoll\\.mask\\-events|tune\\.fd\\.edge\\-triggered|server\\-state\\-file\\-name|ssl\\-load\\-extra\\-del\\-ext|hash\\-preserve\\-affinity|tune\\.quic\\.socket\\-owner|insecure\\-setuid\\-wanted|tune\\.pool\\-low\\-fd\\-ratio|ocsp\\-update\\.httpproxy|max\\-secondary\\-entries|deviceatlas\\-log\\-level|max\\-session\\-srv\\-conns|deviceatlas\\-json\\-file|tune\\.idle\\-pool\\.shared|httpclient\\.ssl\\.verify|deviceatlas\\-separator|http\\-send\\-name\\-header|accepted_payload_size|tune\\.lua\\.forced\\-yield|tune\\.lua\\.task\\-timeout|ocsp\\-update\\.mindelay|tune\\.quic\\.cc\\-hystart|tune\\.sndbuf\\.frontend|tune\\.lua\\.log\\.loggers|tune\\.zlib\\.windowsize|tune\\.buffers\\.reserve|tune\\.memory\\.hot\\-size|ocsp\\-update\\.maxdelay|max\\-keep\\-alive\\-queue|tune\\.rcvbuf\\.frontend|ssl\\-load\\-extra\\-files|pp2\\-never\\-send\\-local|insecure\\-fork\\-wanted|mworker\\-max\\-reloads|tune\\.stick\\-counters|h1\\-case\\-adjust\\-file|tune\\.sndbuf\\.backend|tune\\.rcvbuf\\.backend|tune\\.lua\\.log\\.stderr|lua\\-load\\-per\\-thread|hash\\-balance\\-factor|tune\\.renice\\.runtime|tune\\.runqueue\\-depth|ocsp\\-update\\.disable|tune\\.renice\\.startup|http\\-after\\-response|tune\\.http\\.logurilen|tune\\.http\\.cookielen|tune\\.bufsize\\.small|tune\\.rcvbuf\\.server|tune\\.ssl\\.cachesize|tune\\.zlib\\.memlevel|tune\\.comp\\.maxlevel|tune\\.h2\\.log\\-errors|tune\\.maxpollevents|issuers\\-chain\\-path|ssl\\-security\\-level|no\\-memory\\-trimming|httpclient\\.retries|tune\\.sndbuf\\.client|tune\\.buffers\\.limit|tune\\.ssl\\.maxrecord|dynamic\\-cookie\\-key|tune\\.rcvbuf\\.client|tune\\.sndbuf\\.server|max\\-spread\\-checks|log\\-send\\-hostname|close\\-spread\\-time|tune\\.ssl\\.lifetime|thread\\-hard\\-limit|server\\-state\\-base|ssl\\-provider\\-path|parse\\-resolv\\-conf|ssl\\-dh\\-param\\-file|ssl\\-server\\-verify|dns\\-accept\\-family|tune\\.h2\\.fe\\.rxbuf|ocsp\\-update\\.mode|lua\\-prepend\\-path|error\\-log\\-format|unique\\-id\\-format|profiling\\.memory|wurfl\\-patch\\-file|wurfl\\-cache\\-size|unique\\-id\\-header|tune\\.ring\\.queues|tune\\.http\\.maxhdr|numa\\-cpu\\-mapping|tune\\.recv_enough|tune\\.h2\\.be\\.rxbuf|tune\\.ssl\\.keylog|server\\-template|max\\-object\\-size|default_backend|profiling\\.tasks|http\\-fail\\-codes|wurfl\\-data\\-file|hard\\-stop\\-after|resolve_retries|tune\\.fail\\-alloc|maxcompcpuusage|tune\\.maxrewrite|tune\\.lua\\.maxmem|debug\\.counters|total\\-max\\-size|default\\-server|tune\\.idletimer|ignore\\-persist|ssl\\-mode\\-async|tune\\.maxaccept|clitcpka\\-intvl|srvtcpka\\-intvl|cluster\\-secret|acme\\.scheduler|http\\-err\\-codes|master\\-worker|thread\\-groups|strict\\-limits|srvtcpka\\-idle|log\\-format\\-sd|tune\\.pipesize|fd\\-hard\\-limit|clitcpka\\-idle|saml\\-sso\\-load|nogetaddrinfo|force\\-persist|ssl\\-propquery|spread\\-checks|http\\-response|provider\\-name|tune\\.bufsize|limited\\-quic|busy\\-polling|default\\-path|tune\\.chksize|zero\\-warning|http\\-request|stress\\-level|srvtcpka\\-cnt|thread\\-group|default\\-bind|tcp\\-response|set\\-dumpable|backing\\-file|quic\\-initial|use\\-fcgi\\-app|process\\-vary|clitcpka\\-cnt|maxcomprate|module\\-path|prealloc\\-fd|maxconnrate|ocsp\\-update|noreuseport|module\\-load|tcp\\-request|maxsessrate|use_backend|account\\-key|monitor\\-uri|errorloc302|compression|description|errorloc303|pass\\-header|http\\-errors|http\\-check|nameserver|maxzlibmem|maxsslconn|quick\\-exit|stats\\-file|maxsslrate|contimeout|cpu\\-policy|http\\-reuse|srvtimeout|ssl\\-engine|rate\\-limit|clitimeout|use\\-server|http\\-error|errorfiles|log\\-stderr|log\\-steps|ssl\\-f\\-use|noevports|hash\\-type|presetenv|reuse\\-key|errorfile|acme\\-vars|set\\-param|path\\-info|unix\\-bind|challenge|directory|localpeer|fullconn|nosplice|retry\\-on|crt\\-base|ulimit\\-n|maxpipes|resetenv|errorloc|nbthread|unsetenv|key\\-base|nokqueue|dispatch|timeout|contact|retries|domains|anonkey|ca\\-base|log\\-tag|keytype|cpu\\-map|declare|command|docroot|balance|noepoll|no\\-quic|cpu\\-set|max\\-age|pidfile|nopoll|maxlen|filter|issuer|chroot|daemon|format|option|setcap|mailer|nbproc|setenv|alias|trace|grace|index|quiet|table|bits|size|sctl|mode|node|peer|bind|hold|map|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-res|minsize\\-req|direction|algo\\-res|algo\\-req|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|comment|set\\-var|connect|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-response\\-trailers|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ accept\\-invalid\\-http\\-request|option\\ http\\-drop\\-request\\-trailers|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ log\\-separate\\-errors|option\\ prefer\\-last\\-server|option\\ disable\\-h2\\-upgrade|option\\ http\\-ignore\\-probes|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ start\\-on\\-reload|option\\ http\\-keep\\-alive|option\\ splice\\-response|option\\ splice\\-request|option\\ dontlog\\-normal|option\\ http\\-no\\-delay|option\\ abortonclose|option\\ socket\\-stats|option\\ transparent|option\\ splice\\-auto|option\\ dontlognull|option\\ redispatch|option\\ get\\-values|option\\ allbackups|option\\ checkcache|option\\ mpxs\\-conns|option\\ httpclose|option\\ forwarded|option\\ keep\\-conn|option\\ srvtcpka|option\\ nolinger|option\\ clitcpka|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
