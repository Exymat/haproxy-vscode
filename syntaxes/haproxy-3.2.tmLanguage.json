{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|userlist|crt\\-list|fcgi\\-app|mailers|program|traces|peers|cache|acme|ring))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|crt\\-store|resolvers|userlist|crt\\-list|fcgi\\-app|defaults|frontend|mailers|backend|program|traces|global|listen|peers|cache|acme|ring))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|httpclient\\.resolvers\\.disabled|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.maxdelay|deviceatlas\\-properties\\-cookie|ssl\\-default\\-bind\\-ciphersuites|expose\\-deprecated\\-directives|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.listener\\.default\\-shards|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.quic\\.zero\\-copy\\-fwd\\-send|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|httpclient\\.resolvers\\.prefer|tune\\.quic\\.disable\\-tx\\-pacing|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-ciphers|ssl\\-default\\-server\\-sigalgs|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|tune\\.h1\\.zero\\-copy\\-fwd\\-send|httpclient\\.timeout\\.connect|warn\\-blocked\\-traffic\\-after|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.quic\\.retry\\-threshold|tune\\.h2\\.header\\-table\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.notsent\\-lowat\\.client|tune\\.disable\\-fast\\-forward|tune\\.notsent\\-lowat\\.server|ssl\\-default\\-server\\-curves|tune\\.vars\\.reqres\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.listener\\.multi\\-queue|tune\\.quic\\.disable\\-udp\\-gso|tune\\.lua\\.session\\-timeout|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-sigalgs|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-ciphers|tune\\.vars\\.check\\-max\\-size|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|tune\\.pattern\\.cache\\-size|tune\\.vars\\.proc\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.quic\\.reorder\\-ratio|tune\\.ssl\\.hard\\-maxrecord|tune\\.vars\\.sess\\-max\\-size|ssl\\-default\\-bind\\-curves|tune\\.quic\\.socket\\-owner|tune\\.epoll\\.mask\\-events|tune\\.pool\\-low\\-fd\\-ratio|insecure\\-setuid\\-wanted|tune\\.vars\\.txn\\-max\\-size|tune\\.lua\\.burst\\-timeout|hash\\-preserve\\-affinity|tune\\.h2\\.max\\-frame\\-size|force\\-cfg\\-parser\\-pause|tune\\.sched\\.low\\-latency|tune\\.max\\-rules\\-at\\-once|ssl\\-load\\-extra\\-del\\-ext|httpclient\\.ssl\\.ca\\-file|tune\\.fd\\.edge\\-triggered|server\\-state\\-file\\-name|ocsp\\-update\\.httpproxy|tune\\.lua\\.forced\\-yield|tune\\.idle\\-pool\\.shared|http\\-send\\-name\\-header|tune\\.lua\\.task\\-timeout|httpclient\\.ssl\\.verify|max\\-session\\-srv\\-conns|deviceatlas\\-log\\-level|deviceatlas\\-separator|max\\-secondary\\-entries|deviceatlas\\-json\\-file|accepted_payload_size|ssl\\-load\\-extra\\-files|tune\\.buffers\\.reserve|pp2\\-never\\-send\\-local|tune\\.sndbuf\\.frontend|insecure\\-fork\\-wanted|tune\\.lua\\.log\\.loggers|tune\\.zlib\\.windowsize|ocsp\\-update\\.mindelay|tune\\.rcvbuf\\.frontend|tune\\.memory\\.hot\\-size|tune\\.quic\\.cc\\-hystart|max\\-keep\\-alive\\-queue|ocsp\\-update\\.maxdelay|tune\\.renice\\.runtime|tune\\.stick\\-counters|tune\\.http\\.logurilen|hash\\-balance\\-factor|mworker\\-max\\-reloads|tune\\.http\\.cookielen|tune\\.lua\\.log\\.stderr|lua\\-load\\-per\\-thread|tune\\.rcvbuf\\.backend|tune\\.runqueue\\-depth|h1\\-case\\-adjust\\-file|tune\\.renice\\.startup|tune\\.sndbuf\\.backend|http\\-after\\-response|ocsp\\-update\\.disable|tune\\.h2\\.log\\-errors|issuers\\-chain\\-path|tune\\.comp\\.maxlevel|tune\\.bufsize\\.small|tune\\.ssl\\.maxrecord|no\\-memory\\-trimming|tune\\.zlib\\.memlevel|tune\\.rcvbuf\\.client|tune\\.maxpollevents|tune\\.sndbuf\\.server|tune\\.sndbuf\\.client|ssl\\-security\\-level|tune\\.buffers\\.limit|httpclient\\.retries|tune\\.rcvbuf\\.server|tune\\.ssl\\.cachesize|dynamic\\-cookie\\-key|ssl\\-provider\\-path|max\\-spread\\-checks|thread\\-hard\\-limit|ssl\\-server\\-verify|server\\-state\\-base|close\\-spread\\-time|dns\\-accept\\-family|log\\-send\\-hostname|tune\\.ssl\\.lifetime|parse\\-resolv\\-conf|ssl\\-dh\\-param\\-file|tune\\.http\\.maxhdr|profiling\\.memory|tune\\.recv_enough|tune\\.ring\\.queues|ocsp\\-update\\.mode|numa\\-cpu\\-mapping|unique\\-id\\-format|tune\\.h2\\.fe\\.rxbuf|error\\-log\\-format|tune\\.h2\\.be\\.rxbuf|unique\\-id\\-header|lua\\-prepend\\-path|default_backend|tune\\.lua\\.maxmem|maxcompcpuusage|http\\-fail\\-codes|resolve_retries|profiling\\.tasks|server\\-template|hard\\-stop\\-after|tune\\.maxrewrite|tune\\.fail\\-alloc|tune\\.ssl\\.keylog|max\\-object\\-size|cluster\\-secret|tune\\.idletimer|srvtcpka\\-intvl|total\\-max\\-size|ssl\\-mode\\-async|http\\-err\\-codes|clitcpka\\-intvl|default\\-server|acme\\.scheduler|debug\\.counters|tune\\.maxaccept|ignore\\-persist|master\\-worker|thread\\-groups|ssl\\-propquery|spread\\-checks|nogetaddrinfo|strict\\-limits|http\\-response|force\\-persist|provider\\-name|clitcpka\\-idle|saml\\-sso\\-load|log\\-format\\-sd|tune\\.pipesize|srvtcpka\\-idle|fd\\-hard\\-limit|busy\\-polling|limited\\-quic|zero\\-warning|srvtcpka\\-cnt|stress\\-level|http\\-request|tune\\.chksize|quic\\-initial|set\\-dumpable|clitcpka\\-cnt|tcp\\-response|default\\-path|thread\\-group|use\\-fcgi\\-app|tune\\.bufsize|backing\\-file|default\\-bind|process\\-vary|module\\-load|noreuseport|errorloc302|description|prealloc\\-fd|maxcomprate|maxsessrate|ocsp\\-update|http\\-errors|account\\-key|compression|maxconnrate|errorloc303|tcp\\-request|use_backend|pass\\-header|module\\-path|monitor\\-uri|http\\-reuse|stats\\-file|srvtimeout|log\\-stderr|cpu\\-policy|maxsslrate|contimeout|rate\\-limit|http\\-check|quick\\-exit|ssl\\-engine|use\\-server|maxzlibmem|errorfiles|maxsslconn|http\\-error|clitimeout|nameserver|acme\\-vars|localpeer|ssl\\-f\\-use|reuse\\-key|log\\-steps|noevports|unix\\-bind|errorfile|path\\-info|hash\\-type|set\\-param|challenge|directory|presetenv|maxpipes|crt\\-base|ulimit\\-n|dispatch|nbthread|nosplice|key\\-base|unsetenv|errorloc|retry\\-on|resetenv|nokqueue|fullconn|log\\-tag|declare|max\\-age|contact|cpu\\-map|noepoll|keytype|no\\-quic|retries|docroot|balance|domains|timeout|anonkey|pidfile|ca\\-base|command|cpu\\-set|mailer|daemon|setcap|format|option|maxlen|nopoll|issuer|chroot|filter|setenv|nbproc|grace|index|alias|table|trace|quiet|mode|node|hold|sctl|bind|peer|size|bits|map|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|static\\-rr|url_param|leastconn|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
