te|resolve_retries|wurfl\\-data\\-file|maxcompcpuusage|tune\\.lua\\.maxmem|tune\\.maxaccept|acme\\.scheduler|total\\-max\\-size|clitcpka\\-intvl|x509_v_err_str|debug\\.counters|tune\\.idletimer|ssl\\-mode\\-async|http\\-err\\-codes|ignore\\-persist|default\\-server|srvtcpka\\-intvl|cluster\\-secret|mqtt_is_valid|spread\\-checks|force\\-persist|tune\\.pipesize|thread\\-groups|master\\-worker|strict\\-limits|clitcpka\\-idle|ssl\\-propquery|nogetaddrinfo|http\\-response|srvtcpka\\-idle|log\\-format\\-sd|saml\\-sso\\-load|fd\\-hard\\-limit|provider\\-name|fix_is_valid|busy\\-polling|process\\-vary|srvtcpka\\-cnt|rfc7239_n2np|limited\\-quic|tcp\\-response|tune\\.chksize|clitcpka\\-cnt|rfc7239_n2nn|use\\-fcgi\\-app|backing\\-file|quic\\-initial|default\\-path|default\\-bind|zero\\-warning|thread\\-group|set\\-dumpable|stress\\-level|http\\-request|tune\\.bufsize|compression|log\\-forward|description|maxsessrate|module\\-load|errorloc303|http\\-errors|account\\-key|errorloc302|prealloc\\-fd|maxconnrate|pass\\-header|maxcomprate|stick\\-table|noreuseport|log\\-profile|tcp\\-request|module\\-path|use_backend|ocsp\\-update|monitor\\-uri|cpu\\-policy|srvtimeout|clitimeout|dgram\\-bind|rfc7239_np|http\\-reuse|maxsslconn|http\\-check|contimeout|maxzlibmem|rfc7239_nn|ssl\\-engine|http\\-error|stats\\-file|use\\-server|maxsslrate|nameserver|quick\\-exit|rate\\-limit|errorfiles|unix\\-bind|srv_is_up|presetenv|localpeer|acme\\-vars|hash\\-type|directory|reuse\\-key|path\\-info|port_only|host_only|errorfile|set\\-param|log\\-steps|challenge|noevports|ssl\\-f\\-use|srv_queue|ulimit\\-n|retry\\-on|nbthread|nosplice|cut_crlf|dispatch|nokqueue|key\\-base|fullconn|errorloc|unsetenv|crt\\-base|resetenv|maxpipes|no\\-quic|anonkey|log\\-tag|declare|ca\\-base|balance|timeout|pidfile|retries|cpu\\-map|noepoll|cpu\\-set|keytype|contact|domains|max\\-age|command|ub64dec|docroot|ub64enc|option|maxlen|length|chroot|mailer|b64dec|nbproc|daemon|nopoll|setenv|setcap|issuer|format|filter|base64|nbsrv|base2|table|lower|grace|htonl|quiet|hex2i|index|alias|trace|upper|mode|sctl|even|size|bool|bind|node|peer|date|sha1|bits|hold|map|not|neg|cpl|hex|acl|odd|on)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|url_param|leastconn|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-req|direction|offload|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|send\\-state|unset\\-var|set\\-var|comment|connect|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ forwarded|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(persist)\\s+((?:rdp\\-cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(rate\\-limit)\\s+((?:sessions))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+((?:location))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(req\\.ssl_cipherlist)\\s+((?:binary))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(req\\.ssl_keyshare_groups)\\s+((?:binary))\\b",
