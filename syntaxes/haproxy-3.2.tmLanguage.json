{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|fcgi\\-app|crt\\-list|mailers|program|traces|peers|cache|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|frontend|defaults|fcgi\\-app|crt\\-list|mailers|program|backend|global|listen|traces|peers|cache|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|ssl\\-default\\-server\\-client\\-sigalgs|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.ssl\\.certificate\\-compression|wurfl\\-information\\-list\\-separator|tune\\.quic\\.frontend\\.max\\-data\\-size|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.lua\\.bool\\-sample\\-conversion|ssl\\-default\\-server\\-ciphersuites|tune\\.h2\\.fe\\.initial\\-window\\-size|expose\\-experimental\\-directives|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.quic\\.cc\\.cubic\\.min\\-losses|deviceatlas\\-properties\\-cookie|tune\\.h2\\.fe\\.glitches\\-threshold|httpclient\\.resolvers\\.disabled|tune\\.quic\\.frontend\\.max\\-tx\\-mem|ssl\\-default\\-bind\\-ciphersuites|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.force\\-private\\-cache|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.glitches\\.kill\\.cpu\\-usage|expose\\-deprecated\\-directives|tune\\.listener\\.default\\-shards|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.quic\\.disable\\-tx\\-pacing|httpclient\\.resolvers\\.prefer|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.h2\\.initial\\-window\\-size|load\\-server\\-state\\-from\\-file|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|ssl\\-default\\-server\\-ciphers|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h1\\.zero\\-copy\\-fwd\\-send|warn\\-blocked\\-traffic\\-after|ssl\\-default\\-server\\-options|ssl\\-default\\-server\\-sigalgs|httpclient\\.timeout\\.connect|tune\\.vars\\.global\\-max\\-size|tune\\.ssl\\.default\\-dh\\-param|tune\\.vars\\.reqres\\-max\\-size|tune\\.notsent\\-lowat\\.client|ssl\\-default\\-server\\-curves|tune\\.listener\\.multi\\-queue|tune\\.disable\\-fast\\-forward|tune\\.quic\\.disable\\-udp\\-gso|tune\\.quic\\.retry\\-threshold|tune\\.notsent\\-lowat\\.server|tune\\.h2\\.header\\-table\\-size|tune\\.quic\\.max\\-frame\\-loss|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.service\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|ssl\\-default\\-bind\\-curves|tune\\.vars\\.proc\\-max\\-size|httpclient\\.resolvers\\.id|tune\\.ssl\\.hard\\-maxrecord|tune\\.pattern\\.cache\\-size|tune\\.pool\\-high\\-fd\\-ratio|ssl\\-skip\\-self\\-issued\\-ca|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.sess\\-max\\-size|tune\\.pool\\-low\\-fd\\-ratio|tune\\.epoll\\.mask\\-events|force\\-cfg\\-parser\\-pause|tune\\.h2\\.max\\-frame\\-size|tune\\.quic\\.socket\\-owner|server\\-state\\-file\\-name|ssl\\-load\\-extra\\-del\\-ext|tune\\.sched\\.low\\-latency|tune\\.fd\\.edge\\-triggered|tune\\.vars\\.txn\\-max\\-size|insecure\\-setuid\\-wanted|httpclient\\.ssl\\.ca\\-file|tune\\.lua\\.burst\\-timeout|tune\\.max\\-rules\\-at\\-once|hash\\-preserve\\-affinity|deviceatlas\\-log\\-level|http\\-send\\-name\\-header|deviceatlas\\-json\\-file|httpclient\\.ssl\\.verify|accepted_payload_size|deviceatlas\\-separator|max\\-secondary\\-entries|tune\\.idle\\-pool\\.shared|max\\-session\\-srv\\-conns|tune\\.lua\\.forced\\-yield|tune\\.lua\\.task\\-timeout|ocsp\\-update\\.httpproxy|tune\\.buffers\\.reserve|max\\-keep\\-alive\\-queue|tune\\.rcvbuf\\.frontend|tune\\.quic\\.cc\\-hystart|tune\\.sndbuf\\.frontend|ssl\\-load\\-extra\\-files|ocsp\\-update\\.maxdelay|insecure\\-fork\\-wanted|tune\\.zlib\\.windowsize|ocsp\\-update\\.mindelay|pp2\\-never\\-send\\-local|tune\\.memory\\.hot\\-size|tune\\.lua\\.log\\.loggers|tune\\.runqueue\\-depth|tune\\.http\\.cookielen|tune\\.rcvbuf\\.backend|http\\-after\\-response|tune\\.http\\.logurilen|ocsp\\-update\\.disable|hash\\-balance\\-factor|tune\\.sndbuf\\.backend|tune\\.renice\\.runtime|tune\\.renice\\.startup|tune\\.lua\\.log\\.stderr|h1\\-case\\-adjust\\-file|mworker\\-max\\-reloads|lua\\-load\\-per\\-thread|tune\\.stick\\-counters|tune\\.sndbuf\\.client|issuers\\-chain\\-path|no\\-memory\\-trimming|httpclient\\.retries|tune\\.comp\\.maxlevel|tune\\.h2\\.log\\-errors|tune\\.maxpollevents|tune\\.ssl\\.cachesize|tune\\.sndbuf\\.server|tune\\.zlib\\.memlevel|tune\\.rcvbuf\\.client|ssl\\-security\\-level|tune\\.rcvbuf\\.server|tune\\.buffers\\.limit|tune\\.ssl\\.maxrecord|dynamic\\-cookie\\-key|tune\\.bufsize\\.small|ssl\\-dh\\-param\\-file|close\\-spread\\-time|dns\\-accept\\-family|tune\\.ssl\\.lifetime|log\\-send\\-hostname|max\\-spread\\-checks|ssl\\-provider\\-path|parse\\-resolv\\-conf|ssl\\-server\\-verify|thread\\-hard\\-limit|server\\-state\\-base|tune\\.ring\\.queues|lua\\-prepend\\-path|wurfl\\-patch\\-file|unique\\-id\\-header|numa\\-cpu\\-mapping|wurfl\\-cache\\-size|profiling\\.memory|unique\\-id\\-format|error\\-log\\-format|tune\\.http\\.maxhdr|tune\\.recv_enough|tune\\.h2\\.fe\\.rxbuf|tune\\.h2\\.be\\.rxbuf|ocsp\\-update\\.mode|tune\\.fail\\-alloc|tune\\.ssl\\.keylog|max\\-object\\-size|hard\\-stop\\-after|server\\-template|profiling\\.tasks|default_backend|wurfl\\-data\\-file|resolve_retries|http\\-fail\\-codes|maxcompcpuusage|tune\\.lua\\.maxmem|tune\\.maxrewrite|ssl\\-mode\\-async|ignore\\-persist|srvtcpka\\-intvl|default\\-server|total\\-max\\-size|cluster\\-secret|clitcpka\\-intvl|debug\\.counters|acme\\.scheduler|tune\\.maxaccept|http\\-err\\-codes|tune\\.idletimer|fd\\-hard\\-limit|http\\-response|thread\\-groups|log\\-format\\-sd|saml\\-sso\\-load|srvtcpka\\-idle|master\\-worker|strict\\-limits|spread\\-checks|clitcpka\\-idle|ssl\\-propquery|nogetaddrinfo|force\\-persist|provider\\-name|tune\\.pipesize|srvtcpka\\-cnt|limited\\-quic|stress\\-level|quic\\-initial|tune\\.bufsize|process\\-vary|zero\\-warning|use\\-fcgi\\-app|backing\\-file|http\\-request|default\\-bind|tune\\.chksize|thread\\-group|clitcpka\\-cnt|tcp\\-response|set\\-dumpable|busy\\-polling|default\\-path|errorloc303|errorloc302|use_backend|maxsessrate|maxcomprate|account\\-key|noreuseport|pass\\-header|module\\-path|description|monitor\\-uri|module\\-load|compression|tcp\\-request|prealloc\\-fd|http\\-errors|maxconnrate|ocsp\\-update|maxzlibmem|clitimeout|rate\\-limit|maxsslconn|ssl\\-engine|stats\\-file|maxsslrate|log\\-stderr|nameserver|errorfiles|http\\-error|http\\-check|http\\-reuse|quick\\-exit|use\\-server|cpu\\-policy|contimeout|srvtimeout|directory|set\\-param|log\\-steps|presetenv|localpeer|path\\-info|errorfile|challenge|acme\\-vars|hash\\-type|reuse\\-key|noevports|ssl\\-f\\-use|unix\\-bind|nosplice|dispatch|errorloc|maxpipes|nokqueue|ulimit\\-n|key\\-base|resetenv|fullconn|crt\\-base|retry\\-on|unsetenv|nbthread|balance|noepoll|no\\-quic|pidfile|declare|cpu\\-map|domains|docroot|log\\-tag|retries|keytype|anonkey|command|timeout|max\\-age|contact|cpu\\-set|ca\\-base|chroot|maxlen|nbproc|filter|option|issuer|nopoll|setenv|mailer|daemon|format|setcap|trace|alias|quiet|grace|table|index|size|mode|sctl|bits|node|peer|bind|hold|acl|map)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-req|minsize\\-res|direction|algo\\-res|algo\\-req|offload|algo|type))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|set\\-var|comment|connect|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ http\\-drop\\-response\\-trailers|option\\ accept\\-invalid\\-http\\-request|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ http\\-drop\\-request\\-trailers|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ log\\-separate\\-errors|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ prefer\\-last\\-server|option\\ http\\-ignore\\-probes|option\\ disable\\-h2\\-upgrade|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-accept|option\\ http\\-keep\\-alive|option\\ start\\-on\\-reload|option\\ splice\\-response|option\\ dontlog\\-normal|option\\ splice\\-request|option\\ http\\-no\\-delay|option\\ abortonclose|option\\ socket\\-stats|option\\ splice\\-auto|option\\ transparent|option\\ dontlognull|option\\ checkcache|option\\ get\\-values|option\\ mpxs\\-conns|option\\ redispatch|option\\ allbackups|option\\ keep\\-conn|option\\ forwarded|option\\ httpclose|option\\ clitcpka|option\\ nolinger|option\\ srvtcpka|option\\ logasap|option\\ persist|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
