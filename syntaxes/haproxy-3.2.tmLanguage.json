{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|crt\\-list|fcgi\\-app|program|mailers|traces|cache|peers|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|crt\\-list|defaults|fcgi\\-app|frontend|backend|program|mailers|global|listen|traces|cache|peers|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|ssl\\-default\\-server\\-client\\-sigalgs|h1\\-accept\\-payload\\-with\\-any\\-method|tune\\.disable\\-zero\\-copy\\-forwarding|tune\\.ssl\\.certificate\\-compression|tune\\.quic\\.frontend\\.max\\-data\\-size|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.applet\\.zero\\-copy\\-forwarding|ssl\\-default\\-server\\-ciphersuites|ssl\\-default\\-bind\\-client\\-sigalgs|tune\\.lua\\.bool\\-sample\\-conversion|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|tune\\.events\\.max\\-events\\-at\\-once|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|expose\\-experimental\\-directives|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.h2\\.fe\\.glitches\\-threshold|ssl\\-default\\-bind\\-ciphersuites|tune\\.ssl\\.ocsp\\-update\\.maxdelay|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|httpclient\\.resolvers\\.disabled|deviceatlas\\-properties\\-cookie|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.h2\\.be\\.glitches\\-threshold|expose\\-deprecated\\-directives|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.ssl\\.force\\-private\\-cache|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.listener\\.default\\-shards|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.pt\\.zero\\-copy\\-forwarding|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|tune\\.quic\\.disable\\-tx\\-pacing|load\\-server\\-state\\-from\\-file|tune\\.h2\\.initial\\-window\\-size|httpclient\\.resolvers\\.prefer|warn\\-blocked\\-traffic\\-after|httpclient\\.timeout\\.connect|tune\\.max\\-checks\\-per\\-thread|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|ssl\\-default\\-server\\-options|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h2\\.zero\\-copy\\-fwd\\-send|ssl\\-default\\-server\\-sigalgs|ssl\\-default\\-server\\-ciphers|tune\\.disable\\-fast\\-forward|tune\\.ssl\\.default\\-dh\\-param|tune\\.listener\\.multi\\-queue|tune\\.vars\\.reqres\\-max\\-size|tune\\.vars\\.global\\-max\\-size|tune\\.h2\\.header\\-table\\-size|ssl\\-default\\-server\\-curves|tune\\.quic\\.disable\\-udp\\-gso|tune\\.quic\\.retry\\-threshold|tune\\.notsent\\-lowat\\.server|tune\\.notsent\\-lowat\\.client|ssl\\-default\\-bind\\-ciphers|ssl\\-default\\-bind\\-options|tune\\.lua\\.service\\-timeout|tune\\.lua\\.session\\-timeout|tune\\.vars\\.check\\-max\\-size|tune\\.quic\\.max\\-frame\\-loss|ssl\\-default\\-bind\\-sigalgs|ssl\\-skip\\-self\\-issued\\-ca|tune\\.quic\\.reorder\\-ratio|tune\\.vars\\.sess\\-max\\-size|tune\\.vars\\.proc\\-max\\-size|tune\\.pattern\\.cache\\-size|tune\\.ssl\\.hard\\-maxrecord|tune\\.pool\\-high\\-fd\\-ratio|httpclient\\.resolvers\\.id|ssl\\-default\\-bind\\-curves|tune\\.pool\\-low\\-fd\\-ratio|insecure\\-setuid\\-wanted|tune\\.fd\\.edge\\-triggered|tune\\.vars\\.txn\\-max\\-size|tune\\.max\\-rules\\-at\\-once|tune\\.lua\\.burst\\-timeout|tune\\.sched\\.low\\-latency|tune\\.h2\\.max\\-frame\\-size|force\\-cfg\\-parser\\-pause|hash\\-preserve\\-affinity|ssl\\-load\\-extra\\-del\\-ext|httpclient\\.ssl\\.ca\\-file|server\\-state\\-file\\-name|tune\\.epoll\\.mask\\-events|tune\\.quic\\.socket\\-owner|tune\\.lua\\.forced\\-yield|http\\-send\\-name\\-header|tune\\.lua\\.task\\-timeout|accepted_payload_size|deviceatlas\\-separator|httpclient\\.ssl\\.verify|tune\\.idle\\-pool\\.shared|deviceatlas\\-json\\-file|max\\-secondary\\-entries|max\\-session\\-srv\\-conns|ocsp\\-update\\.httpproxy|deviceatlas\\-log\\-level|tune\\.zlib\\.windowsize|tune\\.quic\\.cc\\-hystart|pp2\\-never\\-send\\-local|ocsp\\-update\\.mindelay|max\\-keep\\-alive\\-queue|tune\\.memory\\.hot\\-size|insecure\\-fork\\-wanted|ocsp\\-update\\.maxdelay|tune\\.buffers\\.reserve|tune\\.rcvbuf\\.frontend|tune\\.sndbuf\\.frontend|ssl\\-load\\-extra\\-files|tune\\.lua\\.log\\.loggers|tune\\.renice\\.runtime|tune\\.renice\\.startup|ocsp\\-update\\.disable|tune\\.rcvbuf\\.backend|tune\\.http\\.logurilen|http\\-after\\-response|tune\\.http\\.cookielen|hash\\-balance\\-factor|tune\\.sndbuf\\.backend|tune\\.lua\\.log\\.stderr|lua\\-load\\-per\\-thread|tune\\.stick\\-counters|tune\\.runqueue\\-depth|mworker\\-max\\-reloads|h1\\-case\\-adjust\\-file|ssl\\-security\\-level|tune\\.ssl\\.maxrecord|tune\\.zlib\\.memlevel|httpclient\\.retries|dynamic\\-cookie\\-key|tune\\.maxpollevents|issuers\\-chain\\-path|tune\\.buffers\\.limit|tune\\.rcvbuf\\.client|tune\\.h2\\.log\\-errors|tune\\.bufsize\\.small|no\\-memory\\-trimming|tune\\.ssl\\.cachesize|tune\\.rcvbuf\\.server|tune\\.sndbuf\\.server|tune\\.sndbuf\\.client|tune\\.comp\\.maxlevel|max\\-spread\\-checks|dns\\-accept\\-family|server\\-state\\-base|ssl\\-dh\\-param\\-file|log\\-send\\-hostname|tune\\.ssl\\.lifetime|parse\\-resolv\\-conf|close\\-spread\\-time|thread\\-hard\\-limit|ssl\\-provider\\-path|ssl\\-server\\-verify|tune\\.recv_enough|profiling\\.memory|tune\\.http\\.maxhdr|error\\-log\\-format|numa\\-cpu\\-mapping|tune\\.h2\\.fe\\.rxbuf|tune\\.h2\\.be\\.rxbuf|ocsp\\-update\\.mode|lua\\-prepend\\-path|tune\\.ring\\.queues|unique\\-id\\-header|unique\\-id\\-format|http\\-fail\\-codes|profiling\\.tasks|tune\\.maxrewrite|tune\\.fail\\-alloc|tune\\.lua\\.maxmem|hard\\-stop\\-after|maxcompcpuusage|resolve_retries|max\\-object\\-size|server\\-template|tune\\.ssl\\.keylog|default_backend|acme\\.scheduler|tune\\.maxaccept|cluster\\-secret|default\\-server|debug\\.counters|tune\\.idletimer|clitcpka\\-intvl|http\\-err\\-codes|ssl\\-mode\\-async|srvtcpka\\-intvl|total\\-max\\-size|ignore\\-persist|nogetaddrinfo|fd\\-hard\\-limit|thread\\-groups|force\\-persist|ssl\\-propquery|saml\\-sso\\-load|log\\-format\\-sd|spread\\-checks|master\\-worker|strict\\-limits|http\\-response|tune\\.pipesize|srvtcpka\\-idle|clitcpka\\-idle|provider\\-name|limited\\-quic|zero\\-warning|clitcpka\\-cnt|process\\-vary|use\\-fcgi\\-app|srvtcpka\\-cnt|busy\\-polling|default\\-bind|quic\\-initial|tune\\.chksize|tune\\.bufsize|tcp\\-response|http\\-request|set\\-dumpable|thread\\-group|stress\\-level|default\\-path|backing\\-file|use_backend|account\\-key|description|maxsessrate|tcp\\-request|errorloc302|maxconnrate|compression|ocsp\\-update|noreuseport|pass\\-header|module\\-load|http\\-errors|module\\-path|monitor\\-uri|maxcomprate|errorloc303|prealloc\\-fd|nameserver|errorfiles|srvtimeout|maxsslconn|stats\\-file|log\\-stderr|http\\-check|use\\-server|cpu\\-policy|rate\\-limit|ssl\\-engine|maxsslrate|http\\-error|maxzlibmem|quick\\-exit|contimeout|http\\-reuse|clitimeout|noevports|acme\\-vars|ssl\\-f\\-use|reuse\\-key|presetenv|directory|path\\-info|localpeer|unix\\-bind|log\\-steps|challenge|set\\-param|errorfile|hash\\-type|unsetenv|nosplice|fullconn|crt\\-base|maxpipes|errorloc|resetenv|key\\-base|retry\\-on|dispatch|ulimit\\-n|nbthread|nokqueue|balance|declare|no\\-quic|docroot|domains|contact|noepoll|keytype|anonkey|cpu\\-map|ca\\-base|cpu\\-set|log\\-tag|pidfile|retries|command|max\\-age|timeout|nopoll|nbproc|daemon|mailer|format|setcap|chroot|issuer|maxlen|setenv|filter|option|alias|grace|trace|quiet|index|table|size|bind|bits|mode|hold|node|sctl|peer|acl|map)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|static\\-rr|url_param|random|source|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
