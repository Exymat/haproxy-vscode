{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HAProxy 3.2",
  "scopeName": "source.haproxy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor-directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives-with-values"
    },
    {
      "include": "#directives-multiword"
    },
    {
      "include": "#cache-keywords"
    },
    {
      "include": "#schema-directives"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#rule-actions"
    },
    {
      "include": "#check-actions"
    },
    {
      "include": "#log-line"
    },
    {
      "include": "#bind-param-pairs"
    },
    {
      "include": "#single-arg-directives"
    },
    {
      "include": "#redirect-keywords"
    },
    {
      "include": "#addresses"
    },
    {
      "include": "#http-methods"
    },
    {
      "include": "#versions"
    },
    {
      "include": "#sample-fetches"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#filenames"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.haproxy",
          "match": "#.*$"
        }
      ]
    },
    "preprocessor-directives": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.haproxy",
          "match": "^\\s*\\.(?:if|elif|else|endif|diag|notice|warning|alert)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.haproxy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.haproxy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.haproxy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "(?m)^(?:\\t| )*(defaults)\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:frontend|backend|listen))\\s+(\\S+)(?:\\s+(from)\\s+(\\S+))?",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            },
            "3": {
              "name": "keyword.other.directive.haproxy"
            },
            "4": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|userlist|fcgi\\-app|crt\\-list|program|mailers|traces|peers|cache|ring|acme))\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.type.section.haproxy"
            },
            "2": {
              "name": "entity.name.type.class.proxy.haproxy"
            }
          }
        },
        {
          "name": "entity.name.type.section.haproxy",
          "match": "(?m)^(?:\\t| )*((?:http\\-errors|resolvers|crt\\-store|frontend|defaults|userlist|fcgi\\-app|crt\\-list|backend|program|mailers|traces|listen|global|peers|cache|ring|acme))\\b"
        }
      ]
    },
    "cache-keywords": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:max\\-secondary\\-entries|max\\-object\\-size|total\\-max\\-size|process\\-vary|max\\-age)\\b"
        }
      ]
    },
    "schema-directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.haproxy",
          "match": "\\b(?:h1\\-do\\-not\\-close\\-on\\-insecure\\-transfer\\-encoding|tune\\.quic\\.frontend\\.default\\-max\\-window\\-size|tune\\.quic\\.frontend\\.conn\\-tx\\-buffers\\.limit|h2\\-workaround\\-bogus\\-websocket\\-clients|tune\\.quic\\.frontend\\.glitches\\-threshold|tune\\.quic\\.frontend\\.stream\\-data\\-ratio|tune\\.quic\\.frontend\\.max\\-idle\\-timeout|tune\\.quic\\.frontend\\.max\\-streams\\-bidi|harden\\.reject\\-privileged\\-ports\\.quic|tune\\.takeover\\-other\\-tg\\-connections|harden\\.reject\\-privileged\\-ports\\.tcp|ssl\\-default\\-server\\-client\\-sigalgs|tune\\.h2\\.fe\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.max\\-concurrent\\-streams|tune\\.disable\\-zero\\-copy\\-forwarding|h1\\-accept\\-payload\\-with\\-any\\-method|wurfl\\-information\\-list\\-separator|tune\\.ssl\\.capture\\-cipherlist\\-size|tune\\.ssl\\.certificate\\-compression|tune\\.applet\\.zero\\-copy\\-forwarding|tune\\.quic\\.frontend\\.max\\-data\\-size|ssl\\-default\\-bind\\-client\\-sigalgs|ssl\\-default\\-server\\-ciphersuites|tune\\.lua\\.bool\\-sample\\-conversion|tune\\.events\\.max\\-events\\-at\\-once|expose\\-experimental\\-directives|tune\\.h2\\.fe\\.initial\\-window\\-size|tune\\.h2\\.max\\-concurrent\\-streams|tune\\.h2\\.be\\.initial\\-window\\-size|tune\\.peers\\.max\\-updates\\-at\\-once|deviceatlas\\-properties\\-cookie|tune\\.h2\\.fe\\.max\\-frames\\-at\\-once|tune\\.h2\\.fe\\.glitches\\-threshold|tune\\.ssl\\.ocsp\\-update\\.mindelay|tune\\.quic\\.cc\\.cubic\\.min\\-losses|tune\\.h2\\.be\\.glitches\\-threshold|tune\\.h2\\.be\\.max\\-frames\\-at\\-once|ssl\\-default\\-bind\\-ciphersuites|tune\\.quic\\.frontend\\.max\\-tx\\-mem|tune\\.ssl\\.ocsp\\-update\\.maxdelay|httpclient\\.resolvers\\.disabled|tune\\.ssl\\.force\\-private\\-cache|expose\\-deprecated\\-directives|tune\\.quic\\.zero\\-copy\\-fwd\\-send|tune\\.listener\\.default\\-shards|tune\\.h2\\.fe\\.max\\-total\\-streams|tune\\.glitches\\.kill\\.cpu\\-usage|tune\\.ssl\\.capture\\-buffer\\-size|tune\\.pt\\.zero\\-copy\\-forwarding|load\\-server\\-state\\-from\\-file|tune\\.quic\\.disable\\-tx\\-pacing|httpclient\\.resolvers\\.prefer|tune\\.h2\\.initial\\-window\\-size|tune\\.ssl\\.ssl\\-ctx\\-cache\\-size|ssl\\-default\\-server\\-ciphers|tune\\.h2\\.fe\\.max\\-rst\\-at\\-once|ssl\\-default\\-server\\-sigalgs|tune\\.h2\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-send|tune\\.h1\\.zero\\-copy\\-fwd\\-recv|ssl\\-default\\-server\\-options|httpclient\\.timeout\\.connect|warn\\-blocked\\-traffic\\-after|tune\\.max\\-checks\\-per\\-thread|tune\\.quic\\.disable\\-udp\\-gso|tune\\.listener\\.multi\\-queue|tune\\.notsent\\-lowat\\.client|tune\\.vars\\.global\\-max\\-size|tune\\.h2\\.header\\-table\\-size|tune\\.quic\\.retry\\-threshold|tune\\.disable\\-fast\\-forward|tune\\.vars\\.reqres\\-max\\-size|ssl\\-default\\-server\\-curves|tune\\.notsent\\-lowat\\.server|tune\\.ssl\\.default\\-dh\\-param|ssl\\-default\\-bind\\-options|ssl\\-default\\-bind\\-sigalgs|tune\\.vars\\.check\\-max\\-size|tune\\.lua\\.service\\-timeout|tune\\.quic\\.max\\-frame\\-loss|tune\\.lua\\.session\\-timeout|ssl\\-default\\-bind\\-ciphers|tune\\.vars\\.proc\\-max\\-size|ssl\\-skip\\-self\\-issued\\-ca|tune\\.pattern\\.cache\\-size|tune\\.quic\\.reorder\\-ratio|tune\\.pool\\-high\\-fd\\-ratio|tune\\.ssl\\.hard\\-maxrecord|httpclient\\.resolvers\\.id|tune\\.vars\\.sess\\-max\\-size|ssl\\-default\\-bind\\-curves|httpclient\\.ssl\\.ca\\-file|insecure\\-setuid\\-wanted|tune\\.fd\\.edge\\-triggered|ssl\\-load\\-extra\\-del\\-ext|tune\\.lua\\.burst\\-timeout|server\\-state\\-file\\-name|tune\\.quic\\.socket\\-owner|tune\\.epoll\\.mask\\-events|force\\-cfg\\-parser\\-pause|tune\\.vars\\.txn\\-max\\-size|tune\\.h2\\.max\\-frame\\-size|hash\\-preserve\\-affinity|tune\\.sched\\.low\\-latency|tune\\.max\\-rules\\-at\\-once|tune\\.pool\\-low\\-fd\\-ratio|ocsp\\-update\\.httpproxy|tune\\.lua\\.task\\-timeout|deviceatlas\\-log\\-level|tune\\.lua\\.forced\\-yield|deviceatlas\\-json\\-file|deviceatlas\\-separator|max\\-secondary\\-entries|accepted_payload_size|http\\-send\\-name\\-header|httpclient\\.ssl\\.verify|tune\\.idle\\-pool\\.shared|max\\-session\\-srv\\-conns|tune\\.buffers\\.reserve|insecure\\-fork\\-wanted|ocsp\\-update\\.mindelay|ssl\\-load\\-extra\\-files|ocsp\\-update\\.maxdelay|tune\\.sndbuf\\.frontend|pp2\\-never\\-send\\-local|tune\\.zlib\\.windowsize|tune\\.lua\\.log\\.loggers|max\\-keep\\-alive\\-queue|tune\\.memory\\.hot\\-size|tune\\.rcvbuf\\.frontend|tune\\.quic\\.cc\\-hystart|ocsp\\-update\\.disable|lua\\-load\\-per\\-thread|tune\\.lua\\.log\\.stderr|tune\\.stick\\-counters|tune\\.http\\.cookielen|tune\\.runqueue\\-depth|h1\\-case\\-adjust\\-file|tune\\.sndbuf\\.backend|tune\\.renice\\.startup|tune\\.http\\.logurilen|hash\\-balance\\-factor|mworker\\-max\\-reloads|tune\\.renice\\.runtime|tune\\.rcvbuf\\.backend|http\\-after\\-response|tune\\.maxpollevents|tune\\.rcvbuf\\.client|tune\\.sndbuf\\.server|no\\-memory\\-trimming|tune\\.comp\\.maxlevel|tune\\.rcvbuf\\.server|tune\\.ssl\\.maxrecord|tune\\.sndbuf\\.client|tune\\.buffers\\.limit|tune\\.bufsize\\.small|tune\\.h2\\.log\\-errors|tune\\.ssl\\.cachesize|ssl\\-security\\-level|issuers\\-chain\\-path|dynamic\\-cookie\\-key|httpclient\\.retries|tune\\.zlib\\.memlevel|thread\\-hard\\-limit|dns\\-accept\\-family|log\\-send\\-hostname|ssl\\-dh\\-param\\-file|ssl\\-provider\\-path|tune\\.ssl\\.lifetime|max\\-spread\\-checks|ssl\\-server\\-verify|parse\\-resolv\\-conf|server\\-state\\-base|close\\-spread\\-time|tune\\.ring\\.queues|error\\-log\\-format|numa\\-cpu\\-mapping|tune\\.h2\\.be\\.rxbuf|tune\\.recv_enough|unique\\-id\\-header|tune\\.h2\\.fe\\.rxbuf|wurfl\\-cache\\-size|lua\\-prepend\\-path|ocsp\\-update\\.mode|wurfl\\-patch\\-file|unique\\-id\\-format|profiling\\.memory|tune\\.http\\.maxhdr|tune\\.maxrewrite|maxcompcpuusage|max\\-object\\-size|default_backend|resolve_retries|http\\-fail\\-codes|tune\\.lua\\.maxmem|profiling\\.tasks|tune\\.fail\\-alloc|tune\\.ssl\\.keylog|wurfl\\-data\\-file|server\\-template|hard\\-stop\\-after|default\\-server|tune\\.maxaccept|cluster\\-secret|srvtcpka\\-intvl|http\\-err\\-codes|clitcpka\\-intvl|ignore\\-persist|acme\\.scheduler|tune\\.idletimer|debug\\.counters|ssl\\-mode\\-async|total\\-max\\-size|force\\-persist|saml\\-sso\\-load|log\\-format\\-sd|strict\\-limits|provider\\-name|ssl\\-propquery|nogetaddrinfo|thread\\-groups|http\\-response|clitcpka\\-idle|master\\-worker|fd\\-hard\\-limit|srvtcpka\\-idle|tune\\.pipesize|spread\\-checks|clitcpka\\-cnt|srvtcpka\\-cnt|tune\\.chksize|quic\\-initial|tcp\\-response|zero\\-warning|stress\\-level|thread\\-group|busy\\-polling|http\\-request|limited\\-quic|process\\-vary|backing\\-file|default\\-path|default\\-bind|set\\-dumpable|tune\\.bufsize|use\\-fcgi\\-app|noreuseport|maxsessrate|module\\-load|ocsp\\-update|maxcomprate|compression|description|monitor\\-uri|tcp\\-request|use_backend|account\\-key|http\\-errors|maxconnrate|module\\-path|prealloc\\-fd|errorloc303|errorloc302|pass\\-header|maxsslconn|errorfiles|ssl\\-engine|srvtimeout|rate\\-limit|contimeout|cpu\\-policy|use\\-server|http\\-check|maxsslrate|maxzlibmem|stats\\-file|clitimeout|nameserver|log\\-stderr|http\\-reuse|http\\-error|quick\\-exit|localpeer|log\\-steps|noevports|presetenv|directory|challenge|errorfile|path\\-info|reuse\\-key|ssl\\-f\\-use|unix\\-bind|acme\\-vars|hash\\-type|set\\-param|fullconn|crt\\-base|unsetenv|key\\-base|dispatch|nokqueue|ulimit\\-n|errorloc|nbthread|nosplice|retry\\-on|maxpipes|resetenv|cpu\\-map|pidfile|domains|anonkey|balance|contact|keytype|timeout|docroot|ca\\-base|declare|no\\-quic|retries|cpu\\-set|log\\-tag|noepoll|command|max\\-age|nbproc|issuer|chroot|daemon|setcap|setenv|maxlen|nopoll|mailer|format|filter|option|alias|quiet|index|table|grace|trace|bits|bind|hold|size|mode|node|peer|sctl|map|acl)\\b"
        }
      ]
    },
    "directives-with-values": {
      "patterns": [
        {
          "match": "\\b(bind)\\s+(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "patterns": [
                {
                  "include": "#comments"
                },
                {
                  "include": "#bind-param-pairs"
                },
                {
                  "include": "#addresses"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "match": "\\b(server)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+(\\S+)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(acl)\\s+(\\S+)\\s+([\\w.-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.other.attribute-name.acl.haproxy"
            },
            "3": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(cookie)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "entity.name.type.proxy.haproxy"
            }
          }
        },
        {
          "match": "\\b(lua-load(?:-per-thread|-per-worker)?)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(redirect)\\s+(location|prefix|scheme)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            },
            "3": {
              "name": "string.unquoted.haproxy"
            }
          }
        },
        {
          "match": "\\b(option)\\s+([\\w-]+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(mode)\\s+((?:health|http|tcp))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(balance)\\s+((?:roundrobin|leastconn|url_param|static\\-rr|source|random|first|hash|uri))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "storage.type"
            }
          }
        },
        {
          "match": "\\b(maxconn)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "constant.numeric.haproxy"
            }
          }
        }
      ]
    },
    "directives-multiword": {
      "patterns": [
        {
          "match": "\\b(no)\\s+(option)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.modifier.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(capture)\\s+((?:response\\ header|request\\ header|cookie))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(compression)\\s+((?:minsize\\-req|minsize\\-res|direction|algo\\-res|algo\\-req|offload|type|algo))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(declare)\\s+((?:capture))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(email\\-alert)\\s+((?:myhostname|mailers|level|from|to))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(external\\-check)\\s+((?:command|path))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-check)\\s+((?:disable\\-on\\-404|set\\-var\\-fmt|send\\-state|unset\\-var|set\\-var|connect|comment|expect|send))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(http\\-error)\\s+((?:status))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(log\\-stderr)\\s+((?:global))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(monitor)\\s+((?:fail))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
        },
        {
          "match": "\\b(no)\\s+((?:option\\ accept\\-unsafe\\-violations\\-in\\-http\\-response|option\\ accept\\-unsafe\\-violations\\-in\\-http\\-request|option\\ accept\\-invalid\\-http\\-response|option\\ h1\\-case\\-adjust\\-bogus\\-client|option\\ accept\\-invalid\\-http\\-request|option\\ http\\-drop\\-response\\-trailers|option\\ h1\\-case\\-adjust\\-bogus\\-server|option\\ http\\-drop\\-request\\-trailers|option\\ idle\\-close\\-on\\-response|option\\ http\\-pretend\\-keepalive|option\\ http\\-use\\-proxy\\-header|option\\ log\\-separate\\-errors|option\\ independent\\-streams|option\\ http\\-buffer\\-request|option\\ disable\\-h2\\-upgrade|option\\ http\\-ignore\\-probes|option\\ prefer\\-last\\-server|option\\ log\\-health\\-checks|option\\ tcp\\-smart\\-connect|option\\ http\\-server\\-close|option\\ tcp\\-smart\\-accept|option\\ splice\\-response|option\\ http\\-keep\\-alive|option\\ start\\-on\\-reload|option\\ splice\\-request|option\\ dontlog\\-normal|option\\ http\\-no\\-delay|option\\ abortonclose|option\\ socket\\-stats|option\\ splice\\-auto|option\\ transparent|option\\ dontlognull|option\\ checkcache|option\\ mpxs\\-conns|option\\ redispatch|option\\ get\\-values|option\\ allbackups|option\\ keep\\-conn|option\\ forwarded|option\\ httpclose|option\\ nolinger|option\\ clitcpka|option\\ srvtcpka|option\\ persist|option\\ logasap|log))\\b",
          "captures": {
            "1": {
              "name": "keyword.other.directive.haproxy"
            },
            "2": {
              "name": "keyword.other.directive.haproxy"
            }
          }
